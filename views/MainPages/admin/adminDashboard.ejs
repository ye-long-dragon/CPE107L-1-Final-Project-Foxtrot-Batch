<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MMCM Chalkboard | Admin Portal</title>
    <link rel="icon" type="image/x-icon" href="/common/img/chalkboardLogo.ico">
    <link rel="stylesheet" href="/common/css/variables.css">
    
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--page-bg, #f4f4f4);
            color: #333;
        }

        .page-layout {
            display: grid;
            grid-template-columns: 250px 1fr; 
            min-height: 100vh;
        }

        .side-menu-container {
            background-color: var(--sidebar-bg, #2c3e50);
            height: 100vh;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .main-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 100%;
            padding-bottom: 80px;
            overflow-y: auto;
        }

        .admin-hero {
            width: 100%;
            min-height: 300px;
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), 
                        url('/common/img/background.jpg') no-repeat center center/cover;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: var(--text-on-dark, #fff);
            text-align: center;
            flex-shrink: 0; 
        }

        /* The Dashboard Container */
        .admin-panel {
            background-color: #fff;
            padding: 40px; 
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            max-width: 800px;
            width: 90%;
            margin: 60px auto 30px auto;
            z-index: 10;
            position: relative;
        }

        .form-title {
            color: var(--accent-primary, #a01a1e);
            margin-bottom: 25px;
            font-size: 1.4rem;
            border-bottom: 2px solid #f8f8f8;
            padding-bottom: 15px;
            font-weight: 700;
        }

        .admin-form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .form-group { margin-bottom: 20px; }
        .full-width { grid-column: span 2; }

        .admin-input-style label {
            display: block;
            font-weight: 700;
            font-size: 0.75rem;
            margin-bottom: 10px; 
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .admin-input-style input, 
        .admin-input-style textarea, 
        .admin-input-style select {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            font-family: inherit;
            font-size: 0.9rem;
            color: #444;
            background-color: #fafafa;
            box-sizing: border-box;
            transition: all 0.2s ease;
        }

        .admin-input-style input:focus, 
        .admin-input-style textarea:focus {
            outline: none;
            border-color: var(--accent-primary, #a01a1e);
            background-color: #fff;
            box-shadow: 0 0 0 4px rgba(160, 26, 30, 0.05);
        }

        .btn-submit {
            background-color: var(--accent-primary, #a01a1e);
            color: white;
            padding: 14px 35px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 700;
            font-size: 1rem;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

        .btn-submit:hover {
            background-color: var(--accent-primary-hover, #7d1417);
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(160, 26, 30, 0.3);
        }

        .announcement-box {
            background-color: #fff;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            max-width: 800px;
            width: 90%;
            margin: 20px auto;
            display: block;
        }

        .announcement-item {
            padding: 20px 0;
            border-bottom: 1px solid #eee;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .announcement-info { flex: 1; }

        .meta-tag {
            font-size: 0.7rem;
            color: #888;
            font-weight: 700;
            text-transform: uppercase;
            display: block;
            margin-bottom: 5px;
        }

        .btn-delete {
            background-color: transparent;
            color: #dc3545;
            border: 1px solid #dc3545;
            padding: 6px 15px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.8rem;
            font-weight: 600;
            transition: 0.2s;
        }

        .btn-delete:hover {
            background-color: #dc3545;
            color: white;
        }

        .btn-proj-overview {
            display: inline-block;
            padding: 15px 40px;
            background-color: var(--accent-primary, #a01a1e);
            color: #fff;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.95rem;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
            margin-top: 20px;
        }

        .btn-proj-overview:hover {
            background-color: var(--accent-primary-hover, #7d1417);
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.3);
        }

        /* --- MODAL SPECIFIC STYLES --- */
        .modal-overlay {
            display: none; 
            position: fixed; 
            z-index: 2000;
            left: 0;
            top: 0;
            width: 100%; 
            height: 100%; 
            background-color: rgba(0,0,0,0.7); 
            backdrop-filter: blur(5px);
        }

        .modal-content {
            background-color: #fff;
            margin: 5vh auto;
            padding: 35px;
            border-radius: 20px;
            width: 90%;
            max-width: 650px;
            max-height: 85vh;
            position: relative;
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
            animation: slideDown 0.3s ease-out;
            overflow-y: auto;
            scrollbar-width: thin;
        }

        @keyframes slideDown {
            from { transform: translateY(-30px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        /* Custom Scrollbar */
        .modal-content::-webkit-scrollbar { width: 6px; }
        .modal-content::-webkit-scrollbar-thumb { background: #ccc; border-radius: 10px; }

        .close-btn {
            position: absolute;
            right: 20px;
            top: 15px;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
            color: #aaa;
            transition: 0.2s;
        }

        .close-btn:hover { color: var(--accent-primary, #a01a1e); }

        .team-section { margin-top: 25px; text-align: left; }
        .team-section h3 { 
            color: var(--color-mapua-blue, #002455); 
            border-bottom: 2px solid #f0f0f0; 
            padding-bottom: 10px; 
        }

        .team-group-label {
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            color: var(--color-mapua-blue, #002455);
            margin-top: 15px;
            margin-bottom: 5px;
            letter-spacing: 1px;
            opacity: 0.7;
        }

        .team-list { display: flex; flex-direction: column; gap: 8px; }

        .team-member {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.9rem;
            padding: 10px 15px;
            background: #f9f9f9;
            border-radius: 8px;
            border-left: 4px solid var(--accent-primary, #a01a1e);
            transition: 0.2s;
        }

        .team-member:hover { transform: translateX(5px); background: #f0f0f0; }
        
        /* Highlight Leadership */
        .team-member.leadership {
            background: #fffafa;
            border-left: 4px solid var(--color-mapua-blue, #002455);
        }

        .team-member small {
            color: #666;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
        }
    </style>
</head>
<body>

    <div class="page-layout">
        <aside class="side-menu-container">
            <%- include('partials/adminSideMenuBar') %>
        </aside>

        <main class="main-content">
            <div class="admin-hero">
                <h1>Admin Command Center</h1>
                <p>MMCM Chalkboard Enterprise Resource Planning</p>
                <button class="btn-proj-overview">Project Overview</button>
            </div>

            <div id="projectModal" class="modal-overlay">
                <div class="modal-content">
                    <span class="close-btn">&times;</span>
                    <h2>Project Overview</h2>
                    <p style="line-height: 1.6; color: var(--text-on-light);">
                        MMCM Chalkboard is a centralized repository designed to eliminate manual tracking inefficiencies. 
                        By automating faculty workflows, the system ensures that all academic materials are 
                        organized, accessible, and synchronized across the institution.
                    </p>
                    <hr style="border: 0; border-top: 3px dashed var(--text-muted); margin: 20px 0;">
                    <p style="margin: 5px 0; font-size: 0.9rem;">
                        This is a <strong>Final Project</strong> for 
                        <span style="color: var(--color-mapua-blue, #002455); font-weight: bold;">CPE107-1L SOFTWARE DESIGN LABORATORY</span>
                    </p>
                    <p style="margin: 5px 0; font-size: 0.9rem;">
                        Developed by <strong style="color: var(--accent-primary);">Section A361</strong> | A.Y. 2025-2026
                    </p>

                    <div class="team-section">
                        <h3>Development Team - Section A361</h3>
                        <div class="team-list">
                            <div class="team-group-label">Leadership</div>
                            <div class="team-member leadership"><span>Leah Rouse Cruzo</span> <small>Project Lead</small></div>
                            <div class="team-member leadership"><span>Vince Lawrence Baraclan</span> <small>Asst. Team Lead</small></div>

                            <div class="team-group-label">Syllabus Module</div>
                            <div class="team-member"><span>Alain Bibaoco</span> <small>Team Lead</small></div>
                            <div class="team-member"><span>Candesse Gabrielle Bartolome</span> <small>Assistant Lead</small></div>
                            <div class="team-member"><span>Vincent Rafael Apog</span> <small>System Analyst</small></div>
                            <div class="team-member"><span>Aleexa Villafuerte</span> <small>UI/UX Designer</small></div>
                            <div class="team-member"><span>Ariff Jibran Mantil</span> <small>QA / Documentation</small></div>
                            <div class="team-member"><span>Hannah Kyla Barol</span> <small>Developer</small></div>
                            <div class="team-member"><span>Cyrile Jane Damos</span> <small>Developer</small></div>
                            <div class="team-member"><span>Marjomillen Reave N Sy</span> <small>Developer</small></div>
                            <div class="team-member"><span>Andrea Cassandra Caunga</span> <small>Developer</small></div>
                            <div class="team-member"><span>Anja Alegarme</span> <small>Developer</small></div>

                            <div class="team-group-label">ATA Module</div>
                            <div class="team-member"><span>Mohammad Jameel Jibreel Mamogkat</span> <small>Team Lead</small></div>
                            <div class="team-member"><span>Duff Bastasa</span> <small>Assistant Lead</small></div>
                            <div class="team-member"><span>Kriszzia Shane Longakit</span> <small>System Analyst</small></div>
                            <div class="team-member"><span>Patrick Thomas Aureada</span> <small>UI/UX Designer</small></div>
                            <div class="team-member"><span>Honey Mae Milana</span> <small>QA / Documentation</small></div>
                            <div class="team-member"><span>Lymel Bonzo</span> <small>Developer</small></div>

                            <div class="team-group-label">TWS Module</div>
                            <div class="team-member"><span>Kevin D Enerio</span> <small>Team Lead</small></div>
                            <div class="team-member"><span>Sharmayne Andrea Cena</span> <small>Assistant Lead</small></div>
                            <div class="team-member"><span>Mhar Jethro Zacal</span> <small>System Analyst</small></div>
                            <div class="team-member"><span>Clark Kent Alaan</span> <small>UI/UX Designer</small></div>
                            <div class="team-member"><span>Allen Dayle Ang</span> <small>QA / Documentation</small></div>
                            <div class="team-member"><span>Christina Heliane Sevilla</span> <small>Developer</small></div>
                            <div class="team-member"><span>Najiep Ali</span> <small>Developer</small></div>

                            <div class="team-group-label">TLA Module</div>
                            <div class="team-member"><span>Jon Clyde Dagaang</span> <small>Team Lead</small></div>
                            <div class="team-member"><span>Jaryl Kurt Benedicto</span> <small>Assistant Lead</small></div>
                            <div class="team-member"><span>Kris Matthew Deximo</span> <small>System Analyst</small></div>
                            <div class="team-member"><span>Sophia Angel Managbanag</span> <small>UI/UX Designer</small></div>
                            <div class="team-member"><span>Andrea Luisa Tan</span> <small>QA / Documentation</small></div>
                            <div class="team-member"><span>Kurt Adrian Luzoraga</span> <small>Developer</small></div>
                            <div class="team-member"><span>Zoey Liana Gonzales</span> <small>Developer</small></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="admin-panel">
                <h3 class="form-title">Create New System Announcement</h3>
                <form id="adminAnnouncementForm">
                    <div class="admin-form-grid">
                        <div class="form-group admin-input-style">
                            <label>Department/Office</label>
                            <input type="text" name="department" placeholder="e.g. Dean's Office" required>
                        </div>
                        <div class="form-group admin-input-style">
                            <label>Category</label>
                            <select name="category">
                                <option value="Academic">Academic Requirement</option>
                                <option value="Administrative">Administrative Update</option>
                                <option value="Event">Institutional Event</option>
                                <option value="Urgent">Urgent Notice</option>
                            </select>
                        </div>
                        <div class="form-group full-width admin-input-style">
                            <label>Headline</label>
                            <input type="text" name="headline" placeholder="Main title of the announcement" required>
                        </div>
                        <div class="form-group full-width admin-input-style">
                            <label>Message Detail</label>
                            <textarea name="content" rows="4" placeholder="Detailed information for faculty members..." required></textarea>
                        </div>
                    </div>
                    <button type="submit" class="btn-submit">Post Announcement</button>
                </form>
            </div>

            <div class="announcement-box">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h2 style="margin: 0; color: var(--color-mapua-blue, #002455); font-size: 1.2rem;">Live Announcements</h2>
                    <span style="font-size: 0.8rem; color: #666;">Showing: All Departments</span>
                </div>
                
                <% if (typeof announcements !== 'undefined' && announcements.length > 0) { %>
                    <% announcements.forEach(item => { %>
                        <div class="announcement-item" data-id="<%= item._id %>">
                            <div class="announcement-info">
                                <span class="meta-tag"><%= item.department %> • <%= item.category %></span>
                                <p style="margin: 5px 0;"><strong><%= item.headline %>:</strong> <%= item.content %></p>
                            </div>
                            <button class="btn-delete" title="Remove post">Delete</button>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="announcement-item">
                        <div class="announcement-info">
                            <span class="meta-tag">System • Preview Mode</span>
                            <p><strong>Notice:</strong> No real announcements found in database. Showing placeholders.</p>
                        </div>
                        <button class="btn-delete">Delete</button>
                    </div>
                <% } %>
            </div>
        </main>
    </div>

    <script src="/MainPages/js/projectDetailsScript.js"></script>
</body>
</html>