<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MMCM Chalkboard | Admin Portal</title>
    <link rel="icon" type="image/x-icon" href="/common/img/chalkboardLogo.ico">
    <link rel="stylesheet" href="/common/css/variables.css">
    
    <style>
        :root {
            --accent-primary: #a01a1e;
            --accent-hover: #7d1417;
            --accent-light: rgba(160, 26, 30, 0.08);
            --editor-border: #ddd;
            --toolbar-bg: #f7f7f7;
            --toolbar-border: #e0e0e0;
            --btn-hover: #e8e8e8;
            --dropdown-shadow: 0 4px 16px rgba(0,0,0,0.13);
            --page-bg: #f4f4f4;
            --text-on-dark: #fff;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0; padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--page-bg);
            color: #333;
        }

        .page-layout {
            display: grid;
            grid-template-columns: 250px 1fr;
            min-height: 100vh;
        }

        .side-menu-container {
            background-color: var(--sidebar-bg);
            height: 100vh;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .main-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 100%;
            padding-bottom: 80px;
            overflow-y: auto;
        }

        .admin-hero {
            width: 100%;
            min-height: 300px;
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)),
                        url('/common/img/background.jpg') no-repeat center center/cover;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: var(--text-on-dark);
            text-align: center;
            flex-shrink: 0;
        }

        .admin-panel {
            background-color: #fff;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            max-width: 860px;
            width: 90%;
            margin: 60px auto 30px auto;
            z-index: 10;
            position: relative;
        }

        .form-title {
            color: var(--accent-primary);
            margin-bottom: 25px;
            font-size: 1.4rem;
            border-bottom: 2px solid #f8f8f8;
            padding-bottom: 15px;
            font-weight: 700;
        }

        .admin-form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .form-group { margin-bottom: 20px; }
        .full-width { grid-column: span 2; }

        .admin-input-style label {
            display: block;
            font-weight: 700;
            font-size: 0.75rem;
            margin-bottom: 10px;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .admin-input-style input,
        .admin-input-style select {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            font-family: inherit;
            font-size: 0.9rem;
            color: #444;
            background-color: #fafafa;
            transition: all 0.2s ease;
        }

        .admin-input-style input:focus,
        .admin-input-style select:focus {
            outline: none;
            border-color: var(--accent-primary);
            background-color: #fff;
            box-shadow: 0 0 0 4px rgba(160, 26, 30, 0.05);
        }

        /* ===================== RICH TEXT EDITOR ===================== */
        .rte-wrapper {
            border: 1px solid var(--editor-border);
            border-radius: 8px;
            overflow: visible;
            background: #fff;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .rte-wrapper:focus-within {
            border-color: var(--accent-primary);
            box-shadow: 0 0 0 4px rgba(160, 26, 30, 0.05);
        }

        /* Toolbar */
        .rte-toolbar {
            background: var(--toolbar-bg);
            border-bottom: 1px solid var(--toolbar-border);
            padding: 6px 8px;
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 2px;
            border-radius: 8px 8px 0 0;
            position: relative;
        }

        .toolbar-divider {
            width: 1px;
            height: 22px;
            background: var(--toolbar-border);
            margin: 0 4px;
            flex-shrink: 0;
        }

        /* Toolbar Buttons */
        .rte-btn {
            background: none;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            padding: 5px 7px;
            font-size: 0.85rem;
            color: #444;
            line-height: 1;
            transition: background 0.15s, color 0.15s;
            display: inline-flex;
            align-items: center;
            gap: 3px;
            white-space: nowrap;
            position: relative;
        }

        .rte-btn:hover { background: var(--btn-hover); }
        .rte-btn.active { background: #e0d0f5; color: #7b2fa8; }
        .rte-btn svg { width: 15px; height: 15px; flex-shrink: 0; }

        /* Dropdown Menus */
        .rte-dropdown { position: relative; display: inline-block; }

        .rte-dropdown-menu {
            display: none;
            position: absolute;
            top: calc(100% + 4px);
            left: 0;
            background: #fff;
            border: 1px solid #ddd;
            border-radius: 8px;
            box-shadow: var(--dropdown-shadow);
            z-index: 9999;
            min-width: 160px;
            padding: 4px 0;
            animation: dropIn 0.12s ease;
        }

        @keyframes dropIn {
            from { opacity: 0; transform: translateY(-4px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .rte-dropdown-menu.open { display: block; }

        .rte-dropdown-item {
            padding: 8px 14px;
            cursor: pointer;
            font-size: 0.85rem;
            color: #333;
            transition: background 0.12s;
            white-space: nowrap;
        }

        .rte-dropdown-item:hover { background: #f0f0f0; }
        .rte-dropdown-item.active { background: #e0d0f5; color: #7b2fa8; font-weight: 600; }

        /* Extra Row (revealed by "...") */
        .rte-extra-row {
            display: none;
            background: var(--toolbar-bg);
            border-bottom: 1px solid var(--toolbar-border);
            padding: 4px 8px;
            gap: 2px;
            align-items: center;
            flex-wrap: wrap;
        }

        .rte-extra-row.visible { display: flex; }

        /* Table Grid Picker */
        .table-grid-picker {
            padding: 10px;
            min-width: 200px;
        }

        .table-grid-label {
            font-size: 0.75rem;
            color: #666;
            margin-bottom: 6px;
            text-align: center;
        }

        .table-cells {
            display: grid;
            grid-template-columns: repeat(10, 18px);
            gap: 2px;
        }

        .table-cell {
            width: 18px;
            height: 18px;
            border: 1px solid #ccc;
            border-radius: 2px;
            cursor: pointer;
            background: #fafafa;
            transition: background 0.1s, border-color 0.1s;
        }

        .table-cell.highlight {
            background: #d4b0f0;
            border-color: #9b59b6;
        }

        .table-insert-btn {
            margin-top: 8px;
            width: 100%;
            padding: 6px;
            background: var(--accent-primary);
            color: #fff;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.8rem;
            font-weight: 600;
        }

        /* Link Modal */
        .rte-modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.4);
            z-index: 10000;
            align-items: center;
            justify-content: center;
        }

        .rte-modal-overlay.open { display: flex; }

        .rte-modal {
            background: #fff;
            border-radius: 10px;
            padding: 24px 28px;
            width: 380px;
            max-width: 95vw;
            box-shadow: 0 8px 32px rgba(0,0,0,0.18);
        }

        .rte-modal h4 {
            margin: 0 0 16px 0;
            font-size: 1rem;
            color: #333;
        }

        .rte-modal label {
            font-size: 0.75rem;
            font-weight: 700;
            color: #888;
            text-transform: uppercase;
            display: block;
            margin-bottom: 5px;
        }

        .rte-modal input {
            width: 100%;
            padding: 9px 12px;
            border: 1px solid #ddd;
            border-radius: 6px;
            margin-bottom: 12px;
            font-size: 0.9rem;
            font-family: inherit;
        }

        .rte-modal input:focus {
            outline: none;
            border-color: var(--accent-primary);
            box-shadow: 0 0 0 3px rgba(160,26,30,0.08);
        }

        .rte-modal-actions {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            margin-top: 4px;
        }

        .rte-modal-actions button {
            padding: 8px 20px;
            border-radius: 6px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.85rem;
        }

        .rte-modal-actions .btn-cancel {
            background: #f0f0f0;
            color: #555;
        }

        .rte-modal-actions .btn-insert {
            background: var(--accent-primary);
            color: #fff;
        }

        /* Editor Area */
        .rte-content {
            min-height: 180px;
            padding: 14px 16px;
            outline: none;
            font-size: 0.9rem;
            line-height: 1.6;
            color: #333;
            border-radius: 0 0 8px 8px;
        }

        .rte-content:empty::before {
            content: attr(data-placeholder);
            color: #aaa;
            pointer-events: none;
        }

        .rte-content table {
            border-collapse: collapse;
            width: 100%;
            margin: 8px 0;
        }

        .rte-content table td, .rte-content table th {
            border: 1px solid #ccc;
            padding: 6px 10px;
            min-width: 60px;
        }

        .rte-content code {
            background: #f4f4f4;
            border: 1px solid #e0e0e0;
            border-radius: 4px;
            padding: 1px 6px;
            font-family: 'Courier New', monospace;
            font-size: 0.85em;
        }

        .rte-footer {
            padding: 4px 12px 6px;
            font-size: 0.72rem;
            color: #aaa;
            background: var(--toolbar-bg);
            border-top: 1px solid var(--toolbar-border);
            border-radius: 0 0 8px 8px;
        }

        /* Attachment preview */
        .attachment-preview {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 8px;
        }

        .attachment-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #f0f0f0;
            border: 1px solid #ddd;
            border-radius: 20px;
            padding: 4px 10px;
            font-size: 0.78rem;
            color: #555;
        }

        .attachment-chip button {
            background: none;
            border: none;
            color: #999;
            cursor: pointer;
            font-size: 0.85rem;
            padding: 0;
            line-height: 1;
        }

        .attachment-chip button:hover { color: #c00; }

        /* Submit Button */
        .btn-submit {
            background-color: var(--accent-primary);
            color: white;
            padding: 14px 35px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 700;
            font-size: 1rem;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

        .btn-submit:hover {
            background-color: var(--accent-hover);
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(160, 26, 30, 0.3);
        }

        /* Announcement List */
        .announcement-box {
            background: #fff;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            max-width: 860px;
            width: 90%;
            margin: 20px auto;
        }

        .announcement-item {
            padding: 20px 0;
            border-bottom: 1px solid #eee;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
        }

        .announcement-info { flex: 1; }

        .meta-tag {
            font-size: 0.7rem;
            color: #888;
            font-weight: 700;
            text-transform: uppercase;
            display: block;
            margin-bottom: 5px;
        }

        .announcement-content-preview {
            font-size: 0.88rem;
            color: #444;
            margin: 5px 0 0;
            line-height: 1.5;
        }

        .btn-delete {
            background: transparent;
            color: #dc3545;
            border: 1px solid #dc3545;
            padding: 6px 15px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.8rem;
            font-weight: 600;
            transition: 0.2s;
            flex-shrink: 0;
        }

        .btn-delete:hover { background: #dc3545; color: white; }

        .btn-proj-overview {
            display: inline-block;
            padding: 15px 40px;
            background-color: var(--accent-primary);
            color: #fff;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.95rem;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            margin-top: 20px;
        }

        .btn-proj-overview:hover {
            background-color: var(--accent-hover);
            transform: translateY(-2px);
        }

        /* Toast notification */
        .rte-toast {
            position: fixed;
            bottom: 28px;
            right: 28px;
            background: #333;
            color: #fff;
            padding: 12px 22px;
            border-radius: 8px;
            font-size: 0.88rem;
            z-index: 99999;
            opacity: 0;
            transform: translateY(12px);
            transition: opacity 0.3s, transform 0.3s;
            pointer-events: none;
        }

        .rte-toast.show { opacity: 1; transform: translateY(0); }
        .rte-toast.success { background: #27ae60; }
        .rte-toast.error { background: #c0392b; }

        /* ===== PROJECT MODAL — paste inside your existing <style> block ===== */


        .modal-overlay {
            position: fixed;
            inset: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0, 0, 0, 0.55);
            z-index: 20000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 30px 16px;
            overflow-y: auto;
            transform: none !important;
        }

        .modal-overlay.open {
            display: flex;
        }

        .modal-content {
            background: #fff;
            border-radius: 14px;
            padding: 36px 40px;
            width: 100%;
            max-width: 680px;
            max-height: 85vh;
            overflow-y: auto;
            box-shadow: 0 16px 48px rgba(0, 0, 0, 0.25);
            position: relative;
            margin: auto;
            animation: modalIn 0.2s ease;
        }

        @keyframes modalIn {
            from { opacity: 0; transform: translateY(-14px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .modal-content h2 {
            margin: 0 0 14px;
            color: var(--accent-primary, #a01a1e);
            font-size: 1.4rem;
        }

        .modal-content h3 {
            margin: 20px 0 10px;
            font-size: 1rem;
            color: #002455;
        }

        .close-btn {
            position: absolute;
            top: 14px;
            right: 18px;
            font-size: 1.5rem;
            color: #999;
            cursor: pointer;
            line-height: 1;
            transition: color 0.15s;
            user-select: none;
        }

        .close-btn:hover { color: #333; }

        .team-section { margin-top: 24px; }

        .team-list {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6px 20px;
            margin-top: 8px;
        }

        .team-group-label {
            grid-column: span 2;
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: #a01a1e;
            margin-top: 14px;
            padding-bottom: 4px;
            border-bottom: 1px solid #eee;
        }

        .team-member {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 0.83rem;
            background: #fafafa;
            border: 1px solid #f0f0f0;
        }

        .team-member span  { font-weight: 600; color: #222; }
        .team-member small { color: #888; font-size: 0.75rem; }

        .team-member.leadership {
            background: #fff8f8;
            border-color: rgba(160, 26, 30, 0.15);
        }
        .team-member.leadership span { color: var(--accent-primary, #a01a1e); }
    </style>
</head>
<body>

<div class="page-layout">
