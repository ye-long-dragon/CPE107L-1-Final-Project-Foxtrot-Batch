        <div class="admin-panel">
            <h3 class="form-title">Create New System Announcement</h3>
            <form id="adminAnnouncementForm">
                <div class="admin-form-grid">
                    <div class="form-group admin-input-style">
                        <label>Department/Office</label>
                        <input type="text" name="department" placeholder="e.g. Dean's Office" required>
                    </div>
                    <div class="form-group admin-input-style">
                        <label>Category</label>
                        <select name="category">
                            <option value="Academic">Academic Requirement</option>
                            <option value="Administrative">Administrative Update</option>
                            <option value="Event">Institutional Event</option>
                            <option value="Urgent">Urgent Notice</option>
                        </select>
                    </div>
                    <div class="form-group full-width admin-input-style">
                        <label>Headline</label>
                        <input type="text" name="headline" placeholder="Main title of the announcement" required>
                    </div>
                    <div class="form-group full-width admin-input-style">
                        <label>Message Detail</label>

                        <!-- ====== RICH TEXT EDITOR ====== -->
                        <div class="rte-wrapper" id="rteWrapper">

                            <!-- PRIMARY TOOLBAR ROW -->
                            <div class="rte-toolbar" id="rteToolbar">

                                <!-- 1. Text Style (A with pencil) -->
                                <div class="rte-dropdown" id="ddStyle">
                                    <button type="button" class="rte-btn" id="btnStyle" title="Text Style">
                                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><text x="1" y="13" font-size="12" fill="currentColor" stroke="none" font-family="serif" font-weight="bold">A</text><line x1="11" y1="10" x2="15" y2="14" stroke-width="2"/><circle cx="13" cy="12" r="2.5" fill="none"/></svg>
                                        <svg viewBox="0 0 8 8" fill="currentColor"><path d="M2 3l2 2 4-4"/></svg>
                                    </button>
                                    <div class="rte-dropdown-menu" id="menuStyle">
                                        <div class="rte-dropdown-item" data-cmd="formatBlock" data-val="h2">Title <small style="color:#aaa">(H2)</small></div>
                                        <div class="rte-dropdown-item" data-cmd="formatBlock" data-val="h3">Header <small style="color:#aaa">(H3)</small></div>
                                        <div class="rte-dropdown-item" data-cmd="formatBlock" data-val="h4">Subheader <small style="color:#aaa">(H4)</small></div>
                                        <div class="rte-dropdown-item" data-cmd="formatBlock" data-val="p">Paragraph</div>
                                    </div>
                                </div>

                                <!-- 2. Font Family (T) -->
                                <div class="rte-dropdown" id="ddFont">
                                    <button type="button" class="rte-btn" id="btnFont" title="Font">
                                        <svg viewBox="0 0 16 16" fill="currentColor"><text x="1" y="13" font-size="13" font-family="serif" font-weight="bold">T</text></svg>
                                        <svg viewBox="0 0 8 8" fill="currentColor"><path d="M1 2l3 4 3-4"/></svg>
                                    </button>
                                    <div class="rte-dropdown-menu" id="menuFont">
                                        <div class="rte-dropdown-item" data-cmd="fontName" data-val="Arial" style="font-family:Arial">Arial</div>
                                        <div class="rte-dropdown-item" data-cmd="fontName" data-val="Comic Sans MS" style="font-family:'Comic Sans MS'">Comic Sans MS</div>
                                        <div class="rte-dropdown-item" data-cmd="fontName" data-val="Courier New" style="font-family:'Courier New'">Courier New</div>
                                        <div class="rte-dropdown-item" data-cmd="fontName" data-val="Noto Serif" style="font-family:'Noto Serif'">Noto Serif</div>
                                        <div class="rte-dropdown-item" data-cmd="fontName" data-val="Open Sans" style="font-family:'Open Sans'">Open Sans</div>
                                        <div class="rte-dropdown-item" data-cmd="fontName" data-val="Times New Roman" style="font-family:'Times New Roman'">Times New Roman</div>
                                        <div class="rte-dropdown-item" data-cmd="fontName" data-val="Verdana" style="font-family:Verdana">Verdana</div>
                                    </div>
                                </div>

                                <!-- 3. Font Size (AA) -->
                                <div class="rte-dropdown" id="ddSize">
                                    <button type="button" class="rte-btn" id="btnSize" title="Font Size">
                                        <span style="font-size:0.95em;font-weight:700;letter-spacing:-1px">AA</span>
                                        <svg viewBox="0 0 8 8" fill="currentColor"><path d="M1 2l3 4 3-4"/></svg>
                                    </button>
                                    <div class="rte-dropdown-menu" id="menuSize">
                                        <div class="rte-dropdown-item" data-cmd="fontSize" data-val="1">10</div>
                                        <div class="rte-dropdown-item" data-cmd="fontSize" data-val="2">12</div>
                                        <div class="rte-dropdown-item" data-cmd="fontSize" data-val="3">14</div>
                                        <div class="rte-dropdown-item" data-cmd="fontSize" data-val="4">18</div>
                                        <div class="rte-dropdown-item" data-cmd="fontSize" data-val="5">24</div>
                                        <div class="rte-dropdown-item" data-cmd="fontSize" data-val="6">36</div>
                                        <div class="rte-dropdown-item" data-cmd="fontSize" data-val="7">48</div>
                                    </div>
                                </div>

                                <!-- 4. Text Color (Paint) -->
                                <div class="rte-dropdown" id="ddColor">
                                    <button type="button" class="rte-btn" id="btnColor" title="Text Color">
                                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M3 13 L8 2 L13 13" stroke-linecap="round"/><line x1="5" y1="9" x2="11" y2="9"/><rect x="2" y="13.5" width="12" height="2" rx="1" fill="#333" stroke="none" id="colorBar"/></svg>
                                        <svg viewBox="0 0 8 8" fill="currentColor"><path d="M1 2l3 4 3-4"/></svg>
                                    </button>
                                    <div class="rte-dropdown-menu" id="menuColor">
                                        <div class="rte-dropdown-item" data-cmd="foreColor" data-val="#111111" style="display:flex;align-items:center;gap:8px"><span style="width:14px;height:14px;border-radius:50%;background:#111;display:inline-block;border:1px solid #ccc"></span>Black</div>
                                        <div class="rte-dropdown-item" data-cmd="foreColor" data-val="#666666" style="display:flex;align-items:center;gap:8px"><span style="width:14px;height:14px;border-radius:50%;background:#666;display:inline-block;border:1px solid #ccc"></span>Grey</div>
                                        <div class="rte-dropdown-item" data-cmd="foreColor" data-val="#7b2fa8" style="display:flex;align-items:center;gap:8px"><span style="width:14px;height:14px;border-radius:50%;background:#7b2fa8;display:inline-block"></span>Purple</div>
                                        <div class="rte-dropdown-item" data-cmd="foreColor" data-val="#1a56db" style="display:flex;align-items:center;gap:8px"><span style="width:14px;height:14px;border-radius:50%;background:#1a56db;display:inline-block"></span>Blue</div>
                                        <div class="rte-dropdown-item" data-cmd="foreColor" data-val="#1a7a3c" style="display:flex;align-items:center;gap:8px"><span style="width:14px;height:14px;border-radius:50%;background:#1a7a3c;display:inline-block"></span>Green</div>
                                        <div class="rte-dropdown-item" data-cmd="foreColor" data-val="#a01a1e" style="display:flex;align-items:center;gap:8px"><span style="width:14px;height:14px;border-radius:50%;background:#a01a1e;display:inline-block"></span>Red</div>
                                    </div>
                                </div>

                                <div class="toolbar-divider"></div>

                                <!-- 5. Bold -->
                                <button type="button" class="rte-btn" id="btnBold" data-cmd="bold" title="Bold"><strong>B</strong></button>
                                <!-- 6. Italic -->
                                <button type="button" class="rte-btn" id="btnItalic" data-cmd="italic" title="Italic"><em>I</em></button>
                                <!-- 7. Underline -->
                                <button type="button" class="rte-btn" id="btnUnderline" data-cmd="underline" title="Underline"><u>U</u></button>

                                <!-- 8. More (...) -->
                                <button type="button" class="rte-btn" id="btnMore" title="More formatting">
                                    <svg viewBox="0 0 16 6" fill="currentColor"><circle cx="2" cy="3" r="1.5"/><circle cx="8" cy="3" r="1.5"/><circle cx="14" cy="3" r="1.5"/></svg>
                                </button>

                                <div class="toolbar-divider"></div>

                                <!-- 9. Table -->
                                <div class="rte-dropdown" id="ddTable">
                                    <button type="button" class="rte-btn" id="btnTable" title="Insert Table">
                                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="1" y="1" width="14" height="14" rx="1.5"/><line x1="1" y1="5" x2="15" y2="5"/><line x1="1" y1="9" x2="15" y2="9"/><line x1="1" y1="13" x2="15" y2="13"/><line x1="5" y1="1" x2="5" y2="15"/><line x1="10" y1="1" x2="10" y2="15"/></svg>
                                        <svg viewBox="0 0 8 8" fill="currentColor"><path d="M1 2l3 4 3-4"/></svg>
                                    </button>
                                    <div class="rte-dropdown-menu" id="menuTable" style="min-width:220px">
                                        <div class="table-grid-picker">
                                            <div class="table-grid-label" id="tableGridLabel">1 × 1 Table</div>
                                            <div class="table-cells" id="tableGridCells"></div>
                                            <button type="button" class="table-insert-btn" id="tableInsertBtn">Insert Table</button>
                                        </div>
                                    </div>
                                </div>

                                <!-- 10. Alignment -->
                                <div class="rte-dropdown" id="ddAlign">
                                    <button type="button" class="rte-btn" id="btnAlign" title="Alignment">
                                        <svg viewBox="0 0 16 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="1" y1="2" x2="15" y2="2"/><line x1="1" y1="6" x2="11" y2="6"/><line x1="1" y1="10" x2="15" y2="10"/><line x1="1" y1="14" x2="9" y2="14"/></svg>
                                        <svg viewBox="0 0 8 8" fill="currentColor"><path d="M1 2l3 4 3-4"/></svg>
                                    </button>
                                    <div class="rte-dropdown-menu" id="menuAlign">
                                        <div class="rte-dropdown-item" data-cmd="justifyLeft">Left</div>
                                        <div class="rte-dropdown-item" data-cmd="justifyCenter">Center</div>
                                        <div class="rte-dropdown-item" data-cmd="justifyRight">Right</div>
                                        <div class="rte-dropdown-item" data-cmd="justifyFull">Justify</div>
                                    </div>
                                </div>

                                <!-- 11. Paragraph (flipped P) -->
                                <div class="rte-dropdown" id="ddPara">
                                    <button type="button" class="rte-btn" id="btnPara" title="Paragraph options">
                                        <svg viewBox="0 0 12 16" fill="currentColor"><path d="M5 0h5v2H9v14H7V2H6v14H4V9A4 4 0 014 1z"/></svg>
                                        <svg viewBox="0 0 8 8" fill="currentColor"><path d="M1 2l3 4 3-4"/></svg>
                                    </button>
                                    <div class="rte-dropdown-menu" id="menuPara">
                                        <div class="rte-dropdown-item" data-cmd="insertUnorderedList">
                                            <svg viewBox="0 0 16 12" fill="currentColor" style="width:13px;height:13px;margin-right:6px;vertical-align:middle"><circle cx="2" cy="2" r="1.5"/><circle cx="2" cy="6" r="1.5"/><circle cx="2" cy="10" r="1.5"/><rect x="5" y="1" width="10" height="2" rx="1"/><rect x="5" y="5" width="10" height="2" rx="1"/><rect x="5" y="9" width="10" height="2" rx="1"/></svg>
                                            Unordered List
                                        </div>
                                        <div class="rte-dropdown-item" data-cmd="insertOrderedList">
                                            <svg viewBox="0 0 16 12" fill="currentColor" style="width:13px;height:13px;margin-right:6px;vertical-align:middle"><text x="0" y="4" font-size="4">1.</text><text x="0" y="8" font-size="4">2.</text><text x="0" y="12" font-size="4">3.</text><rect x="5" y="1" width="10" height="2" rx="1"/><rect x="5" y="5" width="10" height="2" rx="1"/><rect x="5" y="9" width="10" height="2" rx="1"/></svg>
                                            Ordered List
                                        </div>
                                        <hr style="margin:4px 0;border:none;border-top:1px solid #eee">
                                        <div style="padding:6px 14px;font-size:0.72rem;color:#aaa;font-weight:700;text-transform:uppercase">Line Height</div>
                                        <div class="rte-dropdown-item" data-cmd="lineHeight" data-val="1">Single</div>
                                        <div class="rte-dropdown-item" data-cmd="lineHeight" data-val="1.15">1.15</div>
                                        <div class="rte-dropdown-item active" data-cmd="lineHeight" data-val="1.5">1.5</div>
                                        <div class="rte-dropdown-item" data-cmd="lineHeight" data-val="2">Double</div>
                                    </div>
                                </div>

                                <div class="toolbar-divider"></div>

                                <!-- 12. Undo -->
                                <button type="button" class="rte-btn" data-cmd="undo" title="Undo">
                                    <svg viewBox="0 0 16 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M3 3L1 6l3 2"/><path d="M1.5 6A6.5 6.5 0 1015 8"/></svg>
                                </button>

                                <!-- 13. Clear Format -->
                                <button type="button" class="rte-btn" data-cmd="removeFormat" title="Clear Formatting">
                                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="3" y1="3" x2="13" y2="13"/><line x1="13" y1="3" x2="3" y2="13"/></svg>
                                </button>

                                <!-- 14. Embed Link -->
                                <button type="button" class="rte-btn" id="btnLink" title="Insert Link">
                                    <svg viewBox="0 0 18 10" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M6 5h6"/><path d="M3 5a4 4 0 000 0 4 4 0 004 4h2"/><path d="M15 5a4 4 0 000 0 4 4 0 00-4-4H9"/></svg>
                                </button>

                                <!-- 15. Attach File -->
                                <button type="button" class="rte-btn" id="btnAttach" title="Attach File">
                                    <svg viewBox="0 0 14 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 9v4a5 5 0 01-10 0V5a3 3 0 016 0v8a1 1 0 01-2 0V6"/></svg>
                                </button>
                                <input type="file" id="fileInput" style="display:none" multiple>

                                <!-- 16. Insert Image -->
                                <button type="button" class="rte-btn" id="btnImage" title="Insert Image">
                                    <svg viewBox="0 0 18 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="1" y="1" width="16" height="12" rx="2"/><circle cx="5.5" cy="5" r="1.5"/><path d="M1 10l4-3 3 3 3-4 5 4"/></svg>
                                </button>
                                <input type="file" id="imageInput" style="display:none" accept="image/*" multiple>

                            </div>
                            <!-- END PRIMARY TOOLBAR -->

                            <!-- EXTRA ROW (revealed by ...) -->
                            <div class="rte-extra-row" id="rteExtraRow">
                                <!-- Strikethrough -->
                                <button type="button" class="rte-btn" data-cmd="strikeThrough" title="Strikethrough">
                                    <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M2 10c0 1.7 1.3 3 5 3s5-1.3 5-3-1.5-2.5-5-3"/><path d="M12 4c0-1.7-1.3-3-5-3S2 2.3 2 4c0 1.5 1 2.3 3 2.8"/><line x1="1" y1="7" x2="13" y2="7"/></svg>
                                    <span style="font-size:0.78rem">S</span>
                                </button>
                                <!-- Superscript -->
                                <button type="button" class="rte-btn" data-cmd="superscript" title="Superscript">
                                    x<sup>2</sup>
                                </button>
                                <!-- Subscript -->
                                <button type="button" class="rte-btn" data-cmd="subscript" title="Subscript">
                                    x<sub>2</sub>
                                </button>
                                <!-- Code snippet -->
                                <button type="button" class="rte-btn" id="btnCode" title="Code Snippet">
                                    <svg viewBox="0 0 18 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="5,1 1,6 5,11"/><polyline points="13,1 17,6 13,11"/></svg>
                                </button>
                            </div>

                            <!-- EDITOR CONTENT AREA -->
                            <div class="rte-content" id="rteContent" contenteditable="true"
                                 data-placeholder="Detailed information for faculty members..."></div>

                            <!-- ATTACHMENT CHIPS -->
                            <div class="attachment-preview" id="attachmentPreview" style="padding:0 12px 8px"></div>

                            <!-- FOOTER: word count -->
                            <div class="rte-footer">Word count: <span id="wordCount">0</span></div>
                        </div>
                        <!-- hidden textarea that stores base64 content -->
                        <textarea name="messageDetail" id="messageDetailField" style="display:none"></textarea>
                    </div>
                </div>
                <button type="submit" class="btn-submit">Post Announcement</button>
            </form>
        </div>

        <!-- LIVE ANNOUNCEMENTS -->
        <div class="announcement-box">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
                <h2 style="margin:0;color:#002455;font-size:1.2rem">Live Announcements</h2>
                <span style="font-size:0.8rem;color:#666">Showing: All Departments</span>
            </div>

            <% if (typeof announcements !== 'undefined' && announcements.length > 0) { %>
                <% announcements.forEach(item => { %>
                    <div class="announcement-item" data-id="<%= item._id %>">
                        <div class="announcement-info">
                            <span class="meta-tag">
                                <% 
                                    const p = item.postedBy;
                                    let posterName = 'System';
                                    let posterRole = '';
                                    if (p) {
                                        posterName = ((p.firstName || '') + ' ' + (p.lastName || '')).trim().toUpperCase();
                                        if (p.role === 'Admin' || p.role === 'Super-Admin') {
                                            posterRole = 'Admin';
                                        } else {
                                            posterRole = ((p.department || '') + ' ' + (p.role || '')).trim();
                                        }
                                    }
                                %>
                                <span style="color:#002455; font-weight:800;"><%= posterName %></span>
                                &nbsp;•&nbsp;
                                <span style="color:#002455; font-weight:800;"><%= posterRole %></span>
                                &nbsp;|&nbsp; <%= item.category %>
                                <span style="float:right; font-weight:400; text-transform:none;">
                                    <%= new Date(item.createdAt).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }) %>
                                </span>
                            </span>
                            <strong><%= item.headline %></strong>
                            <div class="announcement-content-preview">
                                <%- item.messageDetail ? Buffer.from(item.messageDetail, 'base64').toString('utf8') : '' %>
                            </div>
                        </div>
                        <button class="btn-delete" title="Remove post">Delete</button>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="announcement-item">
                    <div class="announcement-info">
                        <span class="meta-tag">System • Preview Mode</span>
                        <p><strong>Notice:</strong> No announcements found in database.</p>
                    </div>
                    <button class="btn-delete">Delete</button>
                </div>
            <% } %>
        </div>
    </main>
</div>

<!-- LINK MODAL -->
<div class="rte-modal-overlay" id="linkModal">
    <div class="rte-modal">
        <h4>Insert Link</h4>
        <label>Display Text</label>
        <input type="text" id="linkText" placeholder="e.g. Click here">
        <label>URL</label>
        <input type="url" id="linkUrl" placeholder="https://example.com">
        <div class="rte-modal-actions">
            <button type="button" class="btn-cancel" id="linkCancel">Cancel</button>
            <button type="button" class="btn-insert" id="linkInsert">Insert</button>
        </div>
    </div>
</div>

<!-- TOAST -->
<div class="rte-toast" id="rteToast"></div>

</body>

<script src="/MainPages/js/projectDetailsScript.js"></script>
</html>
