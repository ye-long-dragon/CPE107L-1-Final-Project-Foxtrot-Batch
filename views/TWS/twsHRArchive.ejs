<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TWS - HR / Admin</title>
  <link rel="stylesheet" href="/common/css/variables.css" />
  <link rel="stylesheet" href="/TWS/css/twsDashboard.css" />
  <link rel="icon" href="/common/img/chalkboardLogo.ico" type="image/x-icon">

  <style>
    .tws-board-caption-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
      flex-wrap: wrap;
    }

    .tws-modal-bg {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.38);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 16px;
      z-index: 9999;
    }

    .tws-modal {
      width: min(520px, 94vw);
      max-height: 88vh;
      background: #dfe3e8;
      border-radius: 18px;
      padding: 18px 16px;
      box-sizing: border-box;
      overflow-y: auto;
    }

    .tws-form-stack {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .tws-inline-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .tws-modal-title {
      font-size: 24px;
      font-weight: 800;
      color: #10284f;
      margin-bottom: 14px;
    }

    .tws-modal label {
      display: block;
      margin-bottom: 6px;
      font-size: 13px;
      font-weight: 800;
      color: var(--tws-text, #1f2937);
    }

    .tws-modal input[type="text"] {
      width: 100%;
      height: 42px;
      border-radius: 14px;
      border: 1px solid var(--tws-input-border, #b8c1cc);
      background: #fff;
      color: var(--tws-input-text, #1f2937);
      padding: 0 14px;
      outline: none;
      font-size: 13px;
      box-sizing: border-box;
    }

    .tws-modal input[type="text"]:focus {
      border-color: var(--tws-secondary, #0d6efd);
      box-shadow: 0 0 0 2px rgba(13, 110, 253, 0.08);
    }

    .tws-modal-actions {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      margin-top: 10px;
      flex-wrap: wrap;
    }

    .tws-modal-cancel,
    .tws-modal-add {
      height: 42px;
      padding: 0 18px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      border: 1px solid transparent;
      white-space: nowrap;
    }

    .tws-modal-cancel {
      background: #fff;
      color: #10284f;
      border-color: #c9d1db;
    }

    .tws-modal-add {
      background: #b30000;
      color: #fff;
    }

    .tws-btn-red {
      background: #b30000;
      color: #fff;
      border: none;
      height: 40px;
      padding: 0 20px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.2s ease;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .tws-btn-red:hover {
      background: #8f0000;
    }

    .tws-modal::-webkit-scrollbar {
      width: 8px;
    }

    .tws-modal::-webkit-scrollbar-thumb {
      background: #b9c0c8;
      border-radius: 999px;
    }

    .tws-modal::-webkit-scrollbar-track {
      background: transparent;
    }

    @media (max-width: 700px) {
      .tws-inline-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body class="tws-board-page">
  <%
    function statusClass(status) {
      const st = String(status || 'Draft').toLowerCase();
      if (st === 'approved') return 'tws-status-approved';
      if (st === 'archived') return 'tws-status-archived';
      if (st === 'rejected') return 'tws-status-rejected';
      if (st === 'faculty approved') return 'tws-status-sent';
      if (st.includes('returned')) return 'tws-status-returned';
      if (st.includes('sent')) return 'tws-status-sent';
      return 'tws-status-draft';
    }

    function formatDate(value) {
      if (!value) return '—';
      const d = new Date(value);
      if (isNaN(d.getTime())) return '—';
      return d.toLocaleDateString('en-US', {
        month: 'long',
        day: 'numeric',
        year: 'numeric',
        timeZone: 'Asia/Manila',
      });
    }
  %>

  <div class="tws-board-layout">
    <% const role = user.role.toLowerCase(); %>

    <aside class="tws-sidebar">
      <% if (role.includes("prog")) { %>

        <%- include("../MainPages/progChair/partials/progChairMenuBar", { currentPageCategory: "tws", user }) %>

      <% } else if (role.includes("dean")) { %>

        <%- include("../MainPages/dean/partials/deanMenuBar", { currentPageCategory: "tws", user }) %>

      <% } else if (role.includes("admin")) { %>

        <%- include("../MainPages/admin/partials/adminSideMenuBar", { currentPageCategory: "tws", user }) %>

      <% } else { %>

        <%- include("../partials/sideMenuBar", { currentPageCategory: "tws", user }) %>

      <% } %>
    </aside>

    <main class="tws-board-main">
      <div class="tws-board-shell">
        <div class="tws-board-header">
          <h1 class="tws-board-title">Teaching Workload Sheet</h1>
        </div>

        <div class="tws-board-content">
          <div class="tws-board-toolbar">
            <div class="tws-board-search">
              <span class="material-symbols-outlined">search</span>
              <input type="text" id="hrSearch" placeholder="Search Faculty" />
            </div>

            <select class="tws-board-filter" id="hrDepartmentFilter">
              <option value="">Department</option>
              <option value="ATYCB">ATYCB</option>
              <option value="CAS">CAS</option>
              <option value="CCIS">CCIS</option>
              <option value="CEA">CEA</option>
              <option value="CHS">CHS</option>
            </select>

            <select class="tws-board-filter" id="hrProgramFilter">
              <option value="">Program</option>
            </select>

            <select class="tws-board-filter" id="hrAcademicYearFilter">
              <option value="">Academic Year</option>
            </select>

            <select class="tws-board-filter" id="hrTermFilter">
              <option value="">Term</option>
              <option value="1st Term">1st Term</option>
              <option value="2nd Term">2nd Term</option>
              <option value="3rd Term">3rd Term</option>
              <option value="Summer">Summer</option>
            </select>
          </div>

          <div class="tws-board-caption-row">
            <div class="tws-board-caption">HR / Admin Archive Dashboard</div>
            <button type="button" class="tws-btn-red" id="openAddCourseModalBtn">Add Course +</button>
          </div>

          <div class="tws-board-grid" id="hrActiveGrid">
            <% if (!list || !list.length) { %>
              <div class="tws-board-empty">No teaching workload sheets found.</div>
            <% } %>

            <% (list || []).forEach(function(tws) { %>
              <article
                class="tws-board-card hr-card <%= statusClass(tws.status || 'Draft') %>"
                data-name="<%= tws.faculty?.name || '' %>"
                data-department="<%= tws.faculty?.dept || '' %>"
                data-program="<%= tws.faculty?.program || tws.program || '' %>"
                data-term="<%= tws.faculty?.term || tws.term || '' %>"
                data-acad-year="<%= tws.faculty?.acadYear || tws.schoolYear || '' %>"
              >
                <div class="tws-board-card-hero"></div>
                <div class="tws-board-card-body">
                  <div class="tws-board-card-top">
                    <div>
                      <div class="tws-board-card-name"><%= tws.faculty?.name || 'Faculty' %></div>
                      <div class="tws-board-card-meta"><%= tws.faculty?.dept || '—' %> | <%= tws.faculty?.program || tws.program || '—' %></div>
                    </div>
                    <div class="tws-board-card-term"><%= tws.faculty?.term || tws.term || '—' %></div>
                  </div>
                  <div class="tws-board-card-status"><strong>Status:</strong> <span class="<%= statusClass(tws.status || 'Draft') %>"><%= tws.status || 'Draft' %></span></div>
                  <div class="tws-board-card-footer">
                    <div class="tws-board-card-date">Updated: <%= formatDate(tws.updatedAt || tws.createdAt) %></div>
                    <div class="tws-board-actions">
                      <a class="tws-board-icon-btn" href="/tws/summary/<%= tws.id %>?from=hr" title="View">
                        <span class="material-symbols-outlined">visibility</span>
                      </a>
                      <% if ((tws.status || '') === 'Approved') { %>
                        <form method="POST" action="/tws/send-to-hr/<%= tws.id %>" style="display:inline;">
                          <button class="tws-board-icon-btn -archive" type="submit" title="Archive">
                            <span class="material-symbols-outlined">archive</span>
                          </button>
                        </form>
                      <% } %>
                    </div>
                  </div>
                </div>
              </article>
            <% }) %>
          </div>

          <div class="tws-board-section-title">
            <button type="button" id="hrArchiveToggle">
              <span>Archive</span>
              <span class="material-symbols-outlined" id="hrArchiveIcon">expand_more</span>
            </button>
          </div>

          <div class="tws-board-grid" id="hrArchiveGrid">
            <% if (!archivedList || !archivedList.length) { %>
              <div class="tws-board-empty">No archived teaching workload sheets yet.</div>
            <% } %>

            <% (archivedList || []).forEach(function(tws) { %>
              <article
                class="tws-board-card hr-archived-card tws-status-archived"
                data-name="<%= tws.faculty?.name || '' %>"
                data-department="<%= tws.faculty?.dept || '' %>"
                data-program="<%= tws.faculty?.program || tws.program || '' %>"
                data-term="<%= tws.faculty?.term || tws.term || '' %>"
                data-acad-year="<%= tws.faculty?.acadYear || tws.schoolYear || '' %>"
              >
                <div class="tws-board-card-hero"></div>
                <div class="tws-board-card-body">
                  <div class="tws-board-card-top">
                    <div>
                      <div class="tws-board-card-name"><%= tws.faculty?.name || 'Faculty' %></div>
                      <div class="tws-board-card-meta"><%= tws.faculty?.dept || '—' %> | <%= tws.faculty?.program || tws.program || '—' %></div>
                    </div>
                    <div class="tws-board-card-term"><%= tws.faculty?.term || tws.term || '—' %></div>
                  </div>
                  <div class="tws-board-card-status"><strong>Status:</strong> <span class="tws-status-archived">Archived</span></div>
                  <div class="tws-board-card-footer">
                    <div class="tws-board-card-date">Archived: <%= formatDate(tws.archivedAt || tws.updatedAt) %></div>
                    <div class="tws-board-actions">
                      <a class="tws-board-icon-btn" href="/tws/summary/<%= tws.id %>?from=hr" title="View">
                        <span class="material-symbols-outlined">visibility</span>
                      </a>
                    </div>
                  </div>
                </div>
              </article>
            <% }) %>
          </div>
        </div>
      </div>
    </main>
  </div>

  <div class="tws-modal-bg" id="addCourseModal" style="display:none;">
    <div class="tws-modal">
      <div class="tws-modal-title">Add Course</div>

      <form class="tws-form-stack" method="POST" action="/tws/admin/add-course">
        <div class="tws-inline-grid">
          <div>
            <label>Course Code</label>
            <input type="text" name="code" id="addCourseCode" required />
          </div>

          <div>
            <label>Units</label>
            <input type="text" name="units" id="addCourseUnits" required />
          </div>
        </div>

        <div>
          <label>Course Details</label>
          <input type="text" name="title" id="addCourseDetails" required />
        </div>

        <div class="tws-modal-actions">
          <button class="tws-modal-cancel" type="button" onclick="closeAddCourseModal()">Cancel</button>
          <button class="tws-modal-add" type="submit">Add Course</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const hrSearch = document.getElementById('hrSearch');
    const hrDepartmentFilter = document.getElementById('hrDepartmentFilter');
    const hrProgramFilter = document.getElementById('hrProgramFilter');
    const hrAcademicYearFilter = document.getElementById('hrAcademicYearFilter');
    const hrTermFilter = document.getElementById('hrTermFilter');
    const hrArchiveToggle = document.getElementById('hrArchiveToggle');
    const hrArchiveGrid = document.getElementById('hrArchiveGrid');
    const hrArchiveIcon = document.getElementById('hrArchiveIcon');

    function populateHrPrograms() {
      const values = new Set();
      document.querySelectorAll('.hr-card, .hr-archived-card').forEach((card) => {
        const program = (card.dataset.program || '').trim();
        if (program) values.add(program);
      });
      [...values].sort().forEach((program) => {
        const option = document.createElement('option');
        option.value = program;
        option.textContent = program;
        hrProgramFilter.appendChild(option);
      });
    }

    function populateHrAcademicYears() {
      const values = new Set();
      document.querySelectorAll('.hr-card, .hr-archived-card').forEach((card) => {
        const ay = (card.dataset.acadYear || '').trim();
        if (ay) values.add(ay);
      });
      [...values].sort().forEach((ay) => {
        const option = document.createElement('option');
        option.value = ay;
        option.textContent = ay;
        hrAcademicYearFilter.appendChild(option);
      });
    }

    function applyHrFilters() {
      const search = (hrSearch.value || '').toLowerCase().trim();
      const department = (hrDepartmentFilter.value || '').toLowerCase();
      const program = (hrProgramFilter.value || '').toLowerCase();
      const term = (hrTermFilter.value || '').toLowerCase();
      const acadYear = (hrAcademicYearFilter.value || '').toLowerCase();

      document.querySelectorAll('.hr-card, .hr-archived-card').forEach((card) => {
        const name = (card.dataset.name || '').toLowerCase();
        const dept = (card.dataset.department || '').toLowerCase();
        const cardProgram = (card.dataset.program || '').toLowerCase();
        const cardTerm = (card.dataset.term || '').toLowerCase();
        const cardAcadYear = (card.dataset.acadYear || '').toLowerCase();

        const matches = (!search || name.includes(search))
          && (!department || dept === department)
          && (!program || cardProgram === program)
          && (!term || cardTerm === term)
          && (!acadYear || cardAcadYear === acadYear);

        card.style.display = matches ? '' : 'none';
      });
    }

    function openAddCourseModal() {
      const modal = document.getElementById('addCourseModal');
      if (modal) modal.style.display = 'flex';
    }

    function closeAddCourseModal() {
      const modal = document.getElementById('addCourseModal');
      if (modal) modal.style.display = 'none';
    }

    document.getElementById('openAddCourseModalBtn')?.addEventListener('click', function (e) {
      e.preventDefault();
      openAddCourseModal();
    });

    document.addEventListener('click', function (e) {
      const modal = document.getElementById('addCourseModal');
      if (e.target === modal) closeAddCourseModal();
    });

    populateHrPrograms();
    populateHrAcademicYears();
    hrSearch?.addEventListener('input', applyHrFilters);
    hrDepartmentFilter?.addEventListener('change', applyHrFilters);
    hrProgramFilter?.addEventListener('change', applyHrFilters);
    hrAcademicYearFilter?.addEventListener('change', applyHrFilters);
    hrTermFilter?.addEventListener('change', applyHrFilters);

    hrArchiveToggle?.addEventListener('click', () => {
      hrArchiveGrid.classList.toggle('tws-board-hidden');
      hrArchiveIcon.textContent = hrArchiveGrid.classList.contains('tws-board-hidden') ? 'chevron_right' : 'expand_more';
    });
  </script>
</body>
</html>