<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TWS - Program Chair</title>

  <link rel="stylesheet" href="/common/css/variables.css" />
  <link rel="stylesheet" href="/TWS/css/twsStyle.css" />
</head>

<body class="pc-body">
  <div class="pc-layout">
    <aside class="pc-sidebar">
      <%- include("../partials/sideMenuBar", { currentPageCategory: "tws" }) %>
    </aside>

    <main class="pc-main">
      <div class="pc-center">

        <div class="pc-title-pill">
          <h1>TWS - Program Chair</h1>
        </div>

        <% if (typeof errorMessage !== "undefined" && errorMessage) { %>
          <div style="margin: 0 0 12px 0; background: rgba(220,38,38,0.18); border:1px solid rgba(220,38,38,0.45); color:#fff; border-radius:12px; padding:10px 12px; font-size:12px;">
            <b>Action blocked:</b> <%= errorMessage %>
          </div>
        <% } %>

        <div class="pc-glass">

          <section class="pc-card pc-card-wide">
            <div class="pc-card-header">
              <div class="pc-card-title">Submitted Teaching Workload Sheets</div>

              <div class="pc-actions">
                <button class="pc-chip" type="button">Filter by Department</button>
                <button class="pc-chip" type="button" onclick="location.reload()">Refresh</button>
              </div>
            </div>

            <div class="pc-table">
              <div class="pc-row pc-head">
                <div>Faculty Name</div>
                <div>Department</div>
                <div>Academic Year</div>
                <div>Term</div>
                <div>Status</div>
                <div class="pc-action-col">Action</div>
              </div>

              <% if (!submitted || submitted.length === 0) { %>
                <div class="pc-row pc-empty">
                  <div style="grid-column: 1 / -1;">No submitted TWS yet.</div>
                </div>
              <% } %>

              <% (submitted || []).forEach(tws => { %>
                <div class="pc-row">
                  <div><%= tws.faculty?.name || "-" %></div>
                  <div><%= tws.faculty?.dept || "-" %></div>
                  <div><%= tws.faculty?.acadYear || "-" %></div>
                  <div><%= tws.faculty?.term || "-" %></div>

                  <div class="pc-status">
                    <%
                      const st = (tws.status || "Draft").toLowerCase();
                      const isReturned = st.includes("returned");
                      const isDeanStage = st === "sent to dean";
                      const statusText = tws.status || "Draft";
                    %>

                    <span class="pc-status-text <%= isReturned ? 'pc-red' : (isDeanStage ? '' : 'pc-yellow') %>">
                      <%= statusText %>
                      <% if (st === "sent to faculty" && tws.facultySigned) { %>
                        (Faculty Signed)
                      <% } %>
                    </span>
                  </div>

                  <div class="pc-btns">
                    <a class="pc-btn pc-white" href="/tws/created-teaching-workload/<%= tws.id %>?mode=view&from=program-chair">View</a>

                    <% const canChairSendToFaculty = ["Draft", "Returned to Program Chair"].includes(tws.status || ""); %>
                    <% const canChairSendToDean = (tws.status || "") === "Sent to Faculty" && !!tws.facultySigned; %>
                    <% const canChairReturnDraft = ["Returned to Program Chair", "Rejected"].includes(tws.status || ""); %>

                    <% if (canChairSendToFaculty) { %>
                    <form method="post" action="/tws/program-chair/action" class="pc-form-inline">
                      <input type="hidden" name="id" value="<%= tws.id %>" />
                      <input type="hidden" name="action" value="sendToFaculty" />
                      <button class="pc-btn pc-white" type="submit">Send to Faculty</button>
                    </form>
                    <% } %>

                    <% if (canChairSendToDean) { %>
                    <form method="post" action="/tws/program-chair/action" class="pc-form-inline">
                      <input type="hidden" name="id" value="<%= tws.id %>" />
                      <input type="hidden" name="action" value="sendToDean" />
                      <button class="pc-btn pc-white" type="submit">Send to Dean</button>
                    </form>
                    <% } %>

                    <% if (canChairReturnDraft) { %>
                    <form method="post" action="/tws/program-chair/action" class="pc-form-inline">
                      <input type="hidden" name="id" value="<%= tws.id %>" />
                      <input type="hidden" name="action" value="return" />
                      <button class="pc-btn pc-white" type="submit">Return to Draft</button>
                    </form>
                    <% } %>

                    <% if (!canChairSendToFaculty && !canChairSendToDean && !canChairReturnDraft) { %>
                      <% if ((tws.status || "") === "Sent to Faculty" && !tws.facultySigned) { %>
                        <span class="pc-btn pc-white pc-btn-disabled">Waiting Faculty Sign</span>
                      <% } else { %>
                        <span class="pc-btn pc-white pc-btn-disabled">No action</span>
                      <% } %>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            </div>
          </section>

          <section class="pc-card pc-card-small">
            <div class="pc-card-header">
              <div class="pc-card-title">TWS - PERSONAL COURSE LOAD</div>
            </div>

            <div class="pc-table pc-table-small">
              <div class="pc-row pc-head pc-row-small">
                <div>Faculty Name</div>
                <div>Department</div>
                <div>Term</div>
                <div class="pc-action-col">Action</div>
              </div>

              <% if (!personal || personal.length === 0) { %>
                <div class="pc-row pc-empty">
                  <div style="grid-column: 1 / -1;">No items yet.</div>
                </div>
              <% } %>

              <% (personal || []).forEach(tws => { %>
                <div class="pc-row pc-row-small">
                  <div><%= tws.faculty?.name || "-" %></div>
                  <div><%= tws.faculty?.dept || "-" %></div>
                  <div><%= tws.faculty?.term || "-" %></div>

                  <div class="pc-btns pc-btns-right">
                    <a class="pc-btn pc-white" href="/tws/created-teaching-workload/<%= tws.id %>?mode=view&from=program-chair">View</a>

                    <% const canPersonalSendToFaculty = ["Draft", "Returned to Program Chair"].includes(tws.status || ""); %>
                    <% const canPersonalSendToDean = (tws.status || "") === "Sent to Faculty" && !!tws.facultySigned; %>

                    <% if (canPersonalSendToFaculty) { %>
                    <form method="post" action="/tws/program-chair/action" class="pc-form-inline">
                      <input type="hidden" name="id" value="<%= tws.id %>" />
                      <input type="hidden" name="action" value="sendToFaculty" />
                      <button class="pc-btn pc-blue" type="submit">Send to Faculty</button>
                    </form>
                    <% } %>

                    <% if (canPersonalSendToDean) { %>
                    <form method="post" action="/tws/program-chair/action" class="pc-form-inline">
                      <input type="hidden" name="id" value="<%= tws.id %>" />
                      <input type="hidden" name="action" value="sendToDean" />
                      <button class="pc-btn pc-blue" type="submit">Send to Dean</button>
                    </form>
                    <% } %>

                    <% if (!canPersonalSendToFaculty && !canPersonalSendToDean) { %>
                      <% if ((tws.status || "") === "Sent to Faculty" && !tws.facultySigned) { %>
                        <span class="pc-btn pc-white pc-btn-disabled">Waiting Faculty Sign</span>
                      <% } else { %>
                        <span class="pc-btn pc-white pc-btn-disabled"><%= tws.status || "No action" %></span>
                      <% } %>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            </div>
          </section>

          <div class="pc-next-wrap">
            <a class="pc-next" href="/tws/dashboard">Refresh</a>
          </div>

        </div>

      </div>
    </main>
  </div>
</body>
</html>
