  <% } %>

  <script>
    function openSubjectPickerModal() {
      const modal = document.getElementById("subjectPickerModal");
      if (modal) modal.style.display = "flex";
    }

    function closeSubjectPickerModal() {
      const modal = document.getElementById("subjectPickerModal");
      if (modal) modal.style.display = "none";
    }

    function clearAddModalDayChecks() {
      document.querySelectorAll('#addModal input[name="days"]').forEach((cb) => {
        cb.checked = false;
      });
    }

    function resetAddModalFields() {
      document.querySelectorAll('#addModal input[name="days"]').forEach(cb => cb.checked = false);
      document.querySelectorAll('#addModal input[name="labDays"]').forEach(cb => cb.checked = false);

      const ids = [
        "add_startTime",
        "add_endTime",
        "add_section",
        "add_classroom",
        "add_labRoom",
        "add_labStartTime",
        "add_labEndTime"
      ];

      ids.forEach(id => {
        const el = document.getElementById(id);
        if (el) el.value = "";
      });

      const paired = document.getElementById("add_pairedRoomEnabled");
      if (paired) paired.checked = false;

      toggleLabScheduleFields();
    }

    function openAddModal(code, title, units) {
      const titleEl = document.getElementById("addModalTitle");
      const codeEl = document.getElementById("add_code");
      const subjectTitleEl = document.getElementById("add_title");
      const unitsEl = document.getElementById("add_units");
      const modalEl = document.getElementById("addModal");

      if (!titleEl || !codeEl || !subjectTitleEl || !unitsEl || !modalEl) return;

      titleEl.textContent = `Add Subject: ${code} - ${title}`;
      codeEl.value = code || "";
      subjectTitleEl.value = title || "";
      unitsEl.value = units || "";
      resetAddModalFields();
      modalEl.style.display = "flex";
    }

    function closeAddModal() {
      const modalEl = document.getElementById("addModal");
      if (modalEl) modalEl.style.display = "none";
    }

    function openEditModal(courseId, code, title, units, day, startTime, endTime, sectionRoom) {
      const titleEl = document.getElementById("editModalTitle");
      const courseIdEl = document.getElementById("edit_courseId");
      const codeEl = document.getElementById("edit_code");
      const subjectTitleEl = document.getElementById("edit_title");
      const unitsEl = document.getElementById("edit_units");
      const dayEl = document.getElementById("edit_day");
      const startEl = document.getElementById("edit_startTime");
      const endEl = document.getElementById("edit_endTime");
      const sectionEl = document.getElementById("edit_sectionRoom");
      const modalEl = document.getElementById("editModal");

      if (!titleEl || !courseIdEl || !codeEl || !subjectTitleEl || !unitsEl || !dayEl || !startEl || !endEl || !sectionEl || !modalEl) return;

      titleEl.textContent = `Edit Subject: ${code} - ${title}`;
      courseIdEl.value = courseId || "";
      codeEl.value = code || "";
      subjectTitleEl.value = title || "";
      unitsEl.value = units || "";
      dayEl.value = day || "";
      startEl.value = startTime || "";
      endEl.value = endTime || "";
      sectionEl.value = sectionRoom || "";
      modalEl.style.display = "flex";
    }

    function closeEditModal() {
      const modalEl = document.getElementById("editModal");
      if (modalEl) modalEl.style.display = "none";
    }

    const pageIsViewOnly = document.body.dataset.viewOnly === "true";
    let selectedSlot = null;

    document.getElementById("openSubjectPickerBtn")?.addEventListener("click", function () {
      if (pageIsViewOnly) return;
      openSubjectPickerModal();
    });

    document.querySelectorAll(".js-pick-subject").forEach((btn) => {
      btn.addEventListener("click", function () {
        closeSubjectPickerModal();

        openAddModal(
          this.dataset.code || "",
          this.dataset.title || "",
          this.dataset.units || ""
        );

        if (selectedSlot) {
          document.getElementById("add_startTime").value = selectedSlot.start || "";
          document.getElementById("add_endTime").value = selectedSlot.end || "";

          document.querySelectorAll('#addModal input[name="days"]').forEach((cb) => {
            cb.checked = cb.value === selectedSlot.day;
          });

          selectedSlot = null;
        }
      });
    });

    function openConsultationModal() {
      const modal = document.getElementById("consultationModal");
      if (modal) modal.style.display = "flex";
    }

    function closeConsultationModal() {
      const modal = document.getElementById("consultationModal");
      if (modal) modal.style.display = "none";
    }

    function resetConsultationModalFields() {
      document.querySelectorAll('#consultationModal input[name="days"]').forEach((cb) => {
        cb.checked = false;
      });

      const ids = [
        "consultation_startTime",
        "consultation_endTime",
        "consultation_classroom"
      ];

      ids.forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.value = "";
      });

      const sectionEl = document.getElementById("consultation_section");
      if (sectionEl) sectionEl.value = "Consultation";
    }

    document.getElementById("openConsultationModalBtn")?.addEventListener("click", function () {
      if (pageIsViewOnly) return;
      resetConsultationModalFields();
      openConsultationModal();
    });

    document.querySelectorAll(".tws-slot").forEach((slot) => {
      slot.addEventListener("click", function (e) {
        if (pageIsViewOnly) return;
        if (e.target.closest(".tws-block")) return;

        selectedSlot = {
          day: this.dataset.day || "",
          start: this.dataset.start || "",
          end: this.dataset.end || ""
        };

        openSubjectPickerModal();
      });
    });

    const subjectPickerSearch = document.getElementById("subjectPickerSearch");
    const subjectPickerRows = Array.from(document.querySelectorAll(".js-subject-picker-row"));
    const noSubjectPickerMatchRow = document.getElementById("noSubjectPickerMatchRow");

    function filterSubjectPickerRows() {
      const keyword = (subjectPickerSearch?.value || "").trim().toLowerCase();
      let visibleCount = 0;

      subjectPickerRows.forEach((row) => {
        const haystack = row.dataset.search || "";
        const matched = !keyword || haystack.includes(keyword);
        row.style.display = matched ? "" : "none";
        if (matched) visibleCount++;
      });

      if (noSubjectPickerMatchRow) {
        noSubjectPickerMatchRow.style.display = visibleCount === 0 ? "" : "none";
      }
    }

    subjectPickerSearch?.addEventListener("input", filterSubjectPickerRows);

    document.querySelectorAll(".js-edit-subject").forEach((el) => {
      el.addEventListener("click", function () {
        if (pageIsViewOnly) return;

        openEditModal(
          this.dataset.courseId || "",
          this.dataset.code || "",
          this.dataset.title || "",
          this.dataset.units || "",
          this.dataset.day || "",
          this.dataset.start || "",
          this.dataset.end || "",
          this.dataset.sectionRoom || ""
        );
      });
    });

    document.addEventListener("click", function (e) {
      const subjectPickerModal = document.getElementById("subjectPickerModal");
      const consultationModal = document.getElementById("consultationModal");
      const addModal = document.getElementById("addModal");
      const editModal = document.getElementById("editModal");

      if (e.target === subjectPickerModal) closeSubjectPickerModal();
      if (e.target === consultationModal) closeConsultationModal();
      if (e.target === addModal) closeAddModal();
      if (e.target === editModal) closeEditModal();
    });

  function toggleLabScheduleFields() {
  const pairedCheckbox = document.getElementById("add_pairedRoomEnabled");
  const labFields = document.getElementById("labScheduleFields");

  if (!pairedCheckbox || !labFields) return;

  if (pairedCheckbox.checked) {
      labFields.classList.add("is-visible");
    } else {
      labFields.classList.remove("is-visible");

      document.querySelectorAll('#addModal input[name="labDays"]').forEach(cb => cb.checked = false);

      const labRoom = document.getElementById("add_labRoom");
      const labStart = document.getElementById("add_labStartTime");
      const labEnd = document.getElementById("add_labEndTime");

      if (labRoom) labRoom.value = "";
      if (labStart) labStart.value = "";
      if (labEnd) labEnd.value = "";
    }
  }

  document.getElementById("add_pairedRoomEnabled")?.addEventListener("change", toggleLabScheduleFields);

  document.getElementById("removeSubjectBtn")?.addEventListener("click", function () {
    const courseId = document.getElementById("edit_courseId")?.value || "";
    const code = document.getElementById("edit_code")?.value || "";
    const title = document.getElementById("edit_title")?.value || "";

    if (!courseId) {
      alert("Unable to remove subject. Missing course ID.");
      return;
    }

    const confirmed = confirm(`Remove subject: ${code} - ${title}?`);
    if (!confirmed) return;

    document.getElementById("delete_courseId").value = courseId;
    document.getElementById("deleteSubjectForm").submit();
  });
  </script>
</body>
</html>