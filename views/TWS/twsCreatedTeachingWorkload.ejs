<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>TWS - Created Teaching Workload Sheet</title>
  <link rel="stylesheet" href="/common/css/variables.css" />
  <link rel="stylesheet" href="/TWS/css/twsStyle.css" />
  <link rel="icon" href="/common/img/chalkboardLogo.ico" type="image/x-icon">
  <style>
    .tws-block {
      grid-column: var(--col, auto);
      grid-row: var(--row, auto) / span var(--span, 1);
    }

    .tws-timetable .tws-block.tws-block-assigned {
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
      opacity: 1 !important;
    }

    .tws-timetable .tws-block.tws-block-conflict {
      background: #efc0c0 !important;
      border: 1px solid #d89c9c !important;
      color: #5d1d1d !important;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
      opacity: 1 !important;
    }

    .tws-block-clickable {
      cursor: pointer;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .tws-block-clickable:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 14px rgba(0, 0, 0, 0.12);
    }

    .tws-detail-item {
      padding: 8px 0;
      border-bottom: 1px solid var(--tws-border);
    }

    .tws-detail-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 10px;
    }

    .tws-detail-info {
      max-width: 210px;
    }

    .tws-detail-meta {
      opacity: .9;
      font-size: 11px;
      margin-top: 2px;
      line-height: 1.4;
    }

    .tws-detail-actions {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .tws-mini-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 58px;
      height: 28px;
      padding: 0 10px;
      border-radius: 999px;
      border: 1px solid var(--tws-border);
      background: #fff;
      color: var(--tws-text);
      font-size: 11px;
      font-weight: 800;
      cursor: pointer;
      line-height: 1;
      white-space: nowrap;
    }

    .tws-mini-btn-danger {
      background: #fff;
      color: #b42318;
    }

    .tws-inline-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .tws-modal-lg {
      width: min(920px, 94vw);
      max-height: 88vh;
      overflow-y: auto;
      background: #dfe3e8;
      border-radius: 18px;
      padding: 18px 16px;
      box-sizing: border-box;
    }

    .tws-day-checkboxes {
      display: flex;
      flex-wrap: wrap;
      gap: 10px 14px;
      margin-top: 8px;
    }

    .tws-day-checkboxes label {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      font-weight: 700;
    }

    .tws-day-checkboxes input[type="checkbox"] {
      accent-color: #b30000;
    }

    .tws-picker-row {
      display: grid;
      grid-template-columns: 1.5fr 2.5fr 1fr;
      gap: 12px;
      align-items: center;
      padding: 12px 10px;
      border-bottom: 1px solid var(--tws-border);
      font-size: 13px;
    }

    .tws-picker-row.tws-picker-head {
      font-weight: 800;
      background: rgba(255,255,255,0.45);
      position: sticky;
      top: 0;
      z-index: 1;
    }

    .tws-picker-table {
      border: 1px solid var(--tws-border);
      border-radius: 14px;
      overflow: hidden;
      background: rgba(255,255,255,0.35);
      margin-top: 12px;
    }

    .tws-picker-body {
      max-height: 380px;
      overflow: auto;
    }

    .tws-search-wrap {
      margin-top: 8px;
    }

    .tws-search-input {
      width: 100%;
      height: 42px;
      padding: 0 14px;
      border-radius: 999px;
      border: 1px solid var(--tws-border);
      background: #fff;
      outline: none;
      font-size: 13px;
    }

    .tws-search-input:focus {
      border-color: var(--tws-secondary);
      box-shadow: 0 0 0 2px rgba(13, 110, 253, 0.08);
    }

    .tws-empty-state {
      text-align: center;
      padding: 18px 12px;
      font-size: 13px;
      opacity: .85;
    }

    .tws-form-stack {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .tws-modal label {
      display: block;
      margin-bottom: 6px;
      font-size: 13px;
      font-weight: 800;
      color: var(--tws-text);
    }

    .tws-modal input[type="text"],
    .tws-modal select {
      width: 100%;
      height: 42px;
      border-radius: 14px;
      border: 1px solid var(--tws-input-border, #b8c1cc);
      background: #fff;
      color: var(--tws-input-text, #1f2937);
      padding: 0 14px;
      outline: none;
      font-size: 13px;
      box-sizing: border-box;
    }

    .tws-modal input[type="text"]:focus,
    .tws-modal select:focus {
      border-color: var(--tws-secondary);
      box-shadow: 0 0 0 2px rgba(13, 110, 253, 0.08);
    }

    .tws-modal-remove {
      height: 42px;
      padding: 0 18px;
      border: 1px solid #b42318;
      border-radius: 999px;
      background: #fff;
      color: #b42318;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      white-space: nowrap;
    }

    .tws-modal-remove:hover {
      background: #fff0f0;
    }

    .tws-checkbox-line {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 4px;
      font-size: 13px;
      font-weight: 700;
    }

    .tws-checkbox-line input[type="checkbox"] {
      accent-color: #b30000;
    }

    .tws-conditional-block {
      display: none;
      margin-top: 4px;
      padding-top: 4px;
    }

    .tws-conditional-block.is-visible {
      display: block;
    }

    .tws-modal-bg {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.38);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 16px;
      z-index: 9999;
    }

    .tws-modal {
      width: min(520px, 94vw);
      max-height: 88vh;
      background: #dfe3e8;
      border-radius: 18px;
      padding: 18px 16px;
      box-sizing: border-box;
      overflow-y: auto;
    }

    .tws-modal::-webkit-scrollbar,
    .tws-modal-lg::-webkit-scrollbar,
    .tws-picker-body::-webkit-scrollbar {
      width: 8px;
    }

    .tws-modal::-webkit-scrollbar-thumb,
    .tws-modal-lg::-webkit-scrollbar-thumb,
    .tws-picker-body::-webkit-scrollbar-thumb {
      background: #b9c0c8;
      border-radius: 999px;
    }

    .tws-modal::-webkit-scrollbar-track,
    .tws-modal-lg::-webkit-scrollbar-track,
    .tws-picker-body::-webkit-scrollbar-track {
      background: transparent;
    }

    .tws-slot {
      cursor: pointer;
    }

    .tws-slot:hover {
      background: rgba(13, 110, 253, 0.08);
    }

    @media (max-width: 850px) {
      .tws-picker-row {
        grid-template-columns: 1fr;
        gap: 8px;
      }
    }

    @media (max-width: 700px) {
      .tws-inline-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body class="tws-app-body" data-view-only="<%= isViewOnly ? 'true' : 'false' %>">
  <div class="tws-app-layout">

    <% const role = (user?.role || "").toLowerCase(); %>

    <aside class="tws-sidebar">
      <% if (role.includes("prog")) { %>
        
        <%- include("../MainPages/progChair/partials/progChairMenuBar", { currentPageCategory: "tws", user }) %>
      
      <% } else if (role.includes("dean")) { %>
        
        <%- include("../MainPages/dean/partials/deanMenuBar", { currentPageCategory: "tws", user }) %>
      
      <% } else if (role.includes("admin")) { %>
        
        <%- include("../MainPages/admin/partials/adminSideMenuBar", { currentPageCategory: "tws", user }) %>
      
      <% } else { %>
        
        <%- include("../partials/sideMenuBar", { currentPageCategory: "tws", user }) %>
      
        <% } %>
    </aside>

    <main class="tws-app-main">
      <div class="tws-app-center">

        <div class="tws-app-title-pill">
          <h1>TWS: Teaching Workload Sheet</h1>
          <div style="opacity:.9; font-size:12px; margin-top:4px;">
            Faculty: <b><%= (tws?.faculty?.name || "—") %></b>
            <% if (tws?.faculty?.dept) { %> • Dept: <b><%= tws.faculty.dept %></b><% } %>
          </div>
        </div>

        <section class="tws-card tws-card-wide tws-created-sheet">
          <div class="tws-card-title">Created Teaching Workload Sheet</div>

          <% if (typeof errorMessage !== "undefined" && errorMessage) { %>
            <div style="margin: 0 0 12px; background: rgba(220,38,38,0.2); border:1px solid rgba(220,38,38,0.45); color:#1f2937; border-radius:12px; padding:10px 12px; font-size:12px;">
              <b>Scheduling conflict:</b> <%= errorMessage %>
            </div>
          <% } %>

          <div class="tws-schedule-layout">

            <div class="tws-timetable">
              <%
                const days = ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"];
                const times = [
                  "7:00 AM","8:15 AM","9:30 AM","10:45 AM","12:00 PM",
                  "1:15 PM","2:30 PM","3:45 PM","5:00 PM","6:15 PM","7:30 PM","8:45 PM"
                ];
                const SLOT_MINUTES = 75;
              %>

              <div class="tws-cell tws-head tws-corner"></div>
              <% days.forEach(d => { %>
                <div class="tws-cell tws-head"><%= d %></div>
              <% }) %>

              <% times.forEach((t, rowIndex) => {
                   const row = rowIndex + 2;
              %>
                <div class="tws-cell tws-time" style="--row: <%= row %>;"><%= t %></div>
                <% for (let c = 0; c < 7; c++) { %>
                  <div
                    class="tws-cell tws-slot"
                    style="--row: <%= row %>; --col: <%= c + 2 %>;"
                    data-day="<%= days[c] %>"
                    data-start="<%= t %>"
                    data-end="<%= times[rowIndex + 1] || '10:00 PM' %>"
                  ></div>
                <% } %>
              <% }) %>

              <%
                const dayMap = { "Mon": 2, "Tue": 3, "Wed": 4, "Thu": 5, "Fri": 6, "Sat": 7, "Sun": 8 };
                const dayAlias = { mon: "Mon", tue: "Tue", wed: "Wed", thu: "Thu", fri: "Fri", sat: "Sat", sun: "Sun" };
                const GRID_START_MINUTES = 7 * 60;
                const GRID_MIN_ROW = 2;
                const GRID_MAX_SLOT = times.length - 1;

                function toMinutes(timeStr) {
                  if (!timeStr) return null;
                  const m = String(timeStr).trim().match(/^(\d{1,2}):(\d{2})\s*(AM|PM)$/i);
                  if (!m) return null;
                  let hour = Number(m[1]);
                  const minute = Number(m[2]);
                  const ampm = m[3].toUpperCase();
                  if (ampm === "PM" && hour !== 12) hour += 12;
                  if (ampm === "AM" && hour === 12) hour = 0;
                  return hour * 60 + minute;
                }

                function parseSchedule(workloadItem) {
                  const rawDay = String(workloadItem.day || "").trim();
                  const rawStart = String(workloadItem.startTime || "").trim();
                  const rawEnd = String(workloadItem.endTime || "").trim();
                  const rawSlot = String(workloadItem.timeSlot || "").trim();

                  let day = rawDay;
                  let startStr = rawStart;
                  let endStr = rawEnd;

                  if ((!startStr || !endStr) && rawSlot) {
                    const slotMatch = rawSlot.match(/^(?:(Mon|Tue|Wed|Thu|Fri|Sat|Sun)\s+)?(.+?)\s*-\s*(.+)$/i);
                    if (slotMatch) {
                      day = day || slotMatch[1] || "";
                      startStr = startStr || (slotMatch[2] || "").trim();
                      endStr = endStr || (slotMatch[3] || "").trim();
                    }
                  }

                  const startMin = toMinutes(startStr);
                  const endMin = toMinutes(endStr);
                  const normalizedDay = dayAlias[String(day).slice(0, 3).toLowerCase()] || day;

                  if (!dayMap[normalizedDay] || startMin === null || endMin === null || endMin <= startMin) {
                    return null;
                  }

                  const startSlot = Math.round((startMin - GRID_START_MINUTES) / SLOT_MINUTES);
                  const endSlot = Math.round((endMin - GRID_START_MINUTES) / SLOT_MINUTES);
                  const clampedStartSlot = Math.max(0, Math.min(GRID_MAX_SLOT, startSlot));
                  const clampedEndSlot = Math.max(
                    clampedStartSlot + 1,
                    Math.min(times.length, endSlot)
                  );
                  const row = clampedStartSlot + GRID_MIN_ROW;
                  const span = Math.max(1, clampedEndSlot - clampedStartSlot);

                  return { day: normalizedDay, startStr, endStr, startMin, endMin, row, span };
                }

                function getSubjectKey(item) {
                  return `${String(item.code || "").trim()}|${String(item.sectionRoom || "").trim()}`;
                }

                function buildColorMap(workload) {
                  const subjectColors = ["color-1", "color-2", "color-3", "color-4", "color-5", "color-6"];
                  const uniqueKeys = [];

                  (workload || []).forEach((item) => {
                    const key = getSubjectKey(item);
                    if (key && !uniqueKeys.includes(key)) {
                      uniqueKeys.push(key);
                    }
                  });

                  uniqueKeys.sort();

                  const colorMap = {};
                  uniqueKeys.forEach((key, index) => {
                    colorMap[key] = subjectColors[index % subjectColors.length];
                  });

                  return colorMap;
                }

                const parsedBlocks = (tws?.createdWorkload || []).map((item) => {
                  const parsed = parseSchedule(item);
                  return {
                    item,
                    parsed,
                    isConflict: false,
                  };
                });

                const subjectColorMap = buildColorMap(tws?.createdWorkload || []);

                for (let i = 0; i < parsedBlocks.length; i++) {
                  for (let j = i + 1; j < parsedBlocks.length; j++) {
                    const a = parsedBlocks[i].parsed;
                    const b = parsedBlocks[j].parsed;
                    if (!a || !b) continue;
                    if (a.day !== b.day) continue;
                    const overlaps = a.startMin < b.endMin && b.startMin < a.endMin;
                    if (overlaps) {
                      parsedBlocks[i].isConflict = true;
                      parsedBlocks[j].isConflict = true;
                    }
                  }
                }

                parsedBlocks.forEach((block) => {
                  const s = block.item;
                  const p = block.parsed;
                  if (!p) return;
                  const col = dayMap[p.day];
                  const row = p.row;

                  const assignedColorClass = subjectColorMap[getSubjectKey(s)] || "color-1";
                  const colorClass = block.isConflict ? "tws-block-conflict" : `${assignedColorClass} tws-block-assigned`;

                  const compactSectionRoom = String(s.sectionRoom || "").replace(/\s*\|\s*/g, "|");
                  const compactTimeRange = `${p.startStr} - ${p.endStr}`.replace(/\s*-\s*/g, "-");
              %>
              <div
                class="tws-block <%= isViewOnly ? '' : 'tws-block-clickable js-edit-subject' %> <%= colorClass %>"
                style="--col: <%= col %>; --row: <%= row %>; --span: <%= p.span %>;"
                data-course-id="<%= s.id || s._id || '' %>"
                data-code="<%= s.code || '' %>"
                data-title="<%= s.title || '' %>"
                data-units="<%= Number(s.units || 0).toFixed(2) %>"
                data-day="<%= s.day || p.day || '' %>"
                data-start="<%= s.startTime || p.startStr || '' %>"
                data-end="<%= s.endTime || p.endStr || '' %>"
                data-section-room="<%= s.sectionRoom || '' %>"
                title="<%= isViewOnly ? 'View only' : 'Click to edit subject' %>"
              >
                <div class="tws-block-code"><%= s.code %></div>
                <div class="tws-block-sub"><%= compactSectionRoom %></div>
                <div class="tws-block-sub"><%= compactTimeRange %></div>
              </div>
              <%
                });
              %>
            </div>

            <div class="tws-load-details">
              <div class="ld-title" style="display:flex; justify-content:space-between; align-items:center;">
                <span>Load Details</span>
                <% if (!isViewOnly) { %>
                <button type="button" class="tws-btn-white" id="openSubjectPickerBtn">
                  + Add Subject
                </button>
                <% } %>
              </div>

              <div class="ld-row">
                Teaching Hours
                <span><%= Number(tws?.teachingHours || 0).toFixed(2) %></span>
              </div>

              <div class="ld-row">
                Academic Units
                <span><%= Number(tws?.academicUnits || 0).toFixed(2) %></span>
              </div>

              <div class="ld-row">
                Equivalent Load
                <span><%= Number(tws?.totals?.equivLoad || 0).toFixed(2) %></span>
              </div>

              <div class="ld-divider"></div>

              <% if (!tws?.createdWorkload || tws.createdWorkload.length === 0) { %>
                <div style="opacity:.9; font-size:12px; padding: 10px 0;">
                  No subjects yet.
                </div>
              <% } %>

              <% (tws?.createdWorkload || []).forEach(s => { %>
                <div class="tws-detail-item">
                  <div class="tws-detail-top">
                    <div class="tws-detail-info">
                      <b><%= s.code %></b> - <%= s.title %>
                      <div class="tws-detail-meta">
                        <%= (String(s.timeSlot || "").trim() ? String(s.timeSlot || "").trim() + " (PHT)" : "No schedule (PHT)") %> • <%= s.sectionRoom || "— room" %>
                      </div>
                    </div>

                    <div class="tws-detail-actions">
                      <span><%= Number(s.units || 0).toFixed(2) %></span>

                      <% if (!isViewOnly) { %>
                        <button
                          type="button"
                          class="tws-mini-btn js-edit-subject"
                          data-course-id="<%= s.id || s._id || '' %>"
                          data-code="<%= s.code || '' %>"
                          data-title="<%= s.title || '' %>"
                          data-units="<%= Number(s.units || 0).toFixed(2) %>"
                          data-day="<%= s.day || '' %>"
                          data-start="<%= s.startTime || '' %>"
                          data-end="<%= s.endTime || '' %>"
                          data-section-room="<%= s.sectionRoom || '' %>"
                        >
                          Edit
                        </button>
                      <% } %>
                    </div>
                  </div>
                </div>
              <% }) %>

              <div class="ld-divider"></div>

              <div class="ld-row">
                <b>Total Units</b>
                <span><b><%= Number(tws?.totalUnits || 0).toFixed(2) %></b></span>
              </div>

              <div class="ld-row" style="border-bottom:none; padding-bottom:0;">
                <b>Total Hours</b>
                <span><b><%= Number(tws?.totalHours || 0).toFixed(2) %></b></span>
              </div>
            </div>

          </div>
        </section>

        <div class="tws-footer-actions">
          <% if (isViewOnly) { %>
            <a class="tws-btn-white" href="<%= viewBackUrl || '/tws/dashboard' %>">Back</a>
          <% } else { %>
            <a class="tws-btn-white" href="/tws/dashboard">Back</a>
            <a class="tws-next" href="/tws/summary/<%= tws.id %>">Next</a>
          <% } %>
        </div>

      </div>
    </main>

  </div>

  <% if (!isViewOnly) { %>
    <div class="tws-modal-bg" id="subjectPickerModal" style="display:none;">
      <div class="tws-modal tws-modal-lg">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:12px;">
          <div class="tws-modal-title" style="margin-bottom:0;">Add Subject</div>

          <button
            type="button"
            class="tws-btn-white"
            id="openConsultationModalBtn"
          >
            Add Consultation
          </button>
        </div>

        <div class="tws-search-wrap">
          <input
            id="subjectPickerSearch"
            class="tws-search-input"
            type="search"
            placeholder="Search by course code or title"
            aria-label="Search subjects"
          />
        </div>

        <div class="tws-picker-table">
          <div class="tws-picker-row tws-picker-head">
            <div>Course Code</div>
            <div>Course Title</div>
            <div>Add</div>
          </div>

          <div class="tws-picker-body">
            <% (subjects || []).forEach(function(subject) { 
                 const alreadyAdded = (tws?.createdWorkload || []).some(function(item) {
                   return String(item.code || "").trim().toUpperCase() === String(subject.code || "").trim().toUpperCase();
                 });
            %>
              <div
                class="tws-picker-row js-subject-picker-row"
                data-search="<%= String((subject.code || '') + ' ' + (subject.title || '')).toLowerCase() %>"
              >
                <div><%= subject.code %></div>
                <div><%= subject.title %></div>
                <div>
                  <button
                    type="button"
                    class="tws-mini-btn js-pick-subject"
                    <%= alreadyAdded ? "disabled" : "" %>
                    data-code="<%= subject.code || '' %>"
                    data-title="<%= subject.title || '' %>"
                    data-units="<%= Number(subject.units || 0).toFixed(2) %>"
                  >
                    <%= alreadyAdded ? "Added" : "Select" %>
                  </button>
                </div>
              </div>
            <% }) %>

            <div id="noSubjectPickerMatchRow" class="tws-empty-state" style="display:none;">
              No matching subject found.
            </div>
          </div>
        </div>

        <div class="tws-modal-actions">
          <button class="tws-modal-cancel" type="button" onclick="closeSubjectPickerModal()">Close</button>
        </div>
      </div>
    </div>

    <div class="tws-modal-bg" id="consultationModal" style="display:none;">
      <div class="tws-modal">
        <div class="tws-modal-title">Add Consultation</div>

        <form method="POST" action="/tws/create-teaching-workload/<%= tws.id %>/add-consultation" class="tws-form-stack">
          <input type="hidden" name="code" value="CONSULTATION" />
          <input type="hidden" name="title" value="Consultation" />
          <input type="hidden" name="units" value="0" />

          <div>
            <label>Choose Day(s)</label>
            <div class="tws-day-checkboxes">
              <label><input type="checkbox" name="days" value="Mon"> Mon</label>
              <label><input type="checkbox" name="days" value="Tue"> Tue</label>
              <label><input type="checkbox" name="days" value="Wed"> Wed</label>
              <label><input type="checkbox" name="days" value="Thu"> Thu</label>
              <label><input type="checkbox" name="days" value="Fri"> Fri</label>
              <label><input type="checkbox" name="days" value="Sat"> Sat</label>
              <label><input type="checkbox" name="days" value="Sun"> Sun</label>
            </div>
          </div>

          <div class="tws-inline-grid">
            <div>
              <label>Start Time</label>
              <select name="startTime" id="consultation_startTime" required>
                <option value="">-- Select Start Time --</option>
                <option value="7:00 AM">7:00 AM</option>
                <option value="8:15 AM">8:15 AM</option>
                <option value="9:30 AM">9:30 AM</option>
                <option value="10:45 AM">10:45 AM</option>
                <option value="12:00 PM">12:00 PM</option>
                <option value="1:15 PM">1:15 PM</option>
