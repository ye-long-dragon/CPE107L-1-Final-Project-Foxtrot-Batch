<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TWS: Teaching Workload Sheet</title>

  <link rel="stylesheet" href="/common/css/variables.css" />
  <link rel="stylesheet" href="/TWS/css/twsStyle.css" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons" />
  <link rel="icon" href="/common/img/chalkboardLogo.ico" type="image/x-icon">
</head>

<body class="tws-app-body">
  <div class="tws-app-layout">
    <aside class="tws-app-sidebar">
      <%- include("../partials/sideMenuBar", { currentPageCategory: "tws" }) %>
    </aside>

    <main class="tws-app-main">
      <div class="tws-dash-center">

        <h1 class="tws-dash-title">Teaching Workload Sheet</h1>

        <div class="tws-dash-card">
          <div class="tws-dash-table">

            <div
              class="tws-dash-row tws-dash-head"
              style="grid-template-columns: 1.4fr 1fr 0.8fr 1fr 1fr 1fr;"
            >
              <div>Faculty Name</div>
              <div>Academic Year</div>
              <div>Term</div>
              <div>Date Created</div>
              <div>Status</div>
              <div class="tws-dash-col-center">Actions</div>
            </div>

            <% if (!list || list.length === 0) { %>
              <div
                class="tws-dash-row tws-dash-empty"
                style="grid-template-columns: 1.4fr 1fr 0.8fr 1fr 1fr 1fr;"
              >
                <div style="grid-column: 1 / -1; text-align: center;">
                  No TWS yet. Click “Create New TWS”.
                </div>
              </div>
            <% } %>

            <%
              function formatDatePH(value) {
                var date = value ? new Date(value) : new Date();
                if (isNaN(date.getTime())) return "";
                return date.toLocaleDateString("en-US", {
                  month: "2-digit",
                  day: "2-digit",
                  year: "numeric",
                  timeZone: "Asia/Manila",
                });
              }
            %>

            <% (list || []).forEach(tws => { %>
              <div
                class="tws-dash-row"
                style="grid-template-columns: 1.4fr 1fr 0.8fr 1fr 1fr 1fr;"
              >
                <div><%= tws.faculty?.name || "—" %></div>
                <div><%= tws.faculty?.acadYear || tws.schoolYear || "" %></div>
                <div><%= tws.faculty?.term || tws.term || "" %></div>
                <div><%= formatDatePH(tws.createdAt) %></div>
                <div><%= tws.status || "Draft" %></div>
                <div class="tws-dash-actions">
                  <a class="tws-icon-btn" href="/tws/created-teaching-workload/<%= tws.id %>?mode=view" title="View">
                    <span class="material-icons">visibility</span>
                  </a>

                  <a class="tws-icon-btn" href="/tws/faculty/<%= tws.id %>" title="Edit">
                    <span class="material-icons">edit</span>
                  </a>

                  <form method="POST" action="/tws/<%= tws.id %>/delete" class="tws-icon-form" onsubmit="return confirm('Are you sure you want to delete this TWS? This cannot be undone.');">
                    <button class="tws-icon-btn tws-icon-btn-danger" type="submit" title="Delete">
                      <span class="material-icons">delete</span>
                    </button>
                  </form>
                </div>
              </div>
            <% }) %>

          </div>
        </div>

        <div class="tws-dash-footer">
          <a class="tws-dash-btn-create" href="/tws/create">+ Create New TWS</a>
          <div style="display:flex; gap:10px;">
            <a class="tws-dash-btn-refresh" href="/tws/dashboard">Refresh</a>
            <a class="tws-dash-btn-refresh" href="/tws/program-chair">Back</a>
          </div>
        </div>

      </div>
    </main>
  </div>
</body>
</html>