<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>TWS - Create Teaching Workload Sheet</title>
  <link rel="stylesheet" href="/common/css/variables.css" />
  <link rel="stylesheet" href="/TWS/css/twsStyle.css" />
  <style>
    .tws-inline-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .tws-added-list {
      margin-top: 14px;
      display: grid;
      gap: 10px;
    }

    .tws-added-item {
      border: 1px solid rgba(255,255,255,0.18);
      border-radius: 12px;
      padding: 10px 12px;
      background: rgba(255,255,255,0.05);
    }

    .tws-added-item b {
      display: block;
      margin-bottom: 4px;
    }

    .tws-added-meta {
      font-size: 12px;
      opacity: 0.92;
      line-height: 1.45;
    }
  </style>
</head>

<body class="tws-app-body">
<div class="tws-app-layout">

  <aside class="tws-app-sidebar">
    <%- include("../partials/sideMenuBar", { currentPageCategory: "tws" }) %>
  </aside>

  <main class="tws-app-main">
  <div class="tws-app-center">

    <div class="tws-app-title-pill">
      <h1>TWS - Teaching Workload Sheet</h1>
    </div>

    <section class="tws-card">

      <div class="tws-card-header">
        <div class="tws-card-title">Create Teaching Workload Sheet</div>

        <div class="pc-actions">
          <button class="pc-chip" type="button">Filter by Department</button>
          <button class="pc-chip" type="button">Search...</button>
          <button class="pc-chip" type="button" onclick="location.reload()">Refresh</button>
        </div>
      </div>

      <div class="tws-table tws-workload-table">
        <div class="tws-row tws-head tws-workload-row">
          <div>Course Code</div>
          <div>Course Title</div>
          <div>Units</div>
          <div class="tws-workload-col-head">Add</div>
          <div class="tws-workload-col-head">Remove</div>
        </div>

        <% (subjects || []).forEach(s => { 
            const alreadyAdded = (tws.createdWorkload || []).some(x => x.code === s.code);
        %>
          <div class="tws-row tws-workload-row">
            <div><%= s.code %></div>
            <div><%= s.title %></div>
            <div><%= Number(s.units).toFixed(2) %></div>

            <div class="tws-btns tws-workload-action-cell">
              <button
                class="tws-btn-white"
                type="button"
                <%= alreadyAdded ? "disabled" : "" %>
                onclick="openModal('<%= s.code %>', '<%= s.title.replace(/'/g, "\\'") %>', '<%= Number(s.units).toFixed(2) %>')"
              >
                <%= alreadyAdded ? "Added" : "Add" %>
              </button>
            </div>

            <div class="tws-btns tws-workload-action-cell">
              <form method="POST" action="/tws/create-teaching-workload/<%= tws.id %>/remove" style="display:inline;" onsubmit="return confirm('Remove this subject from the workload?');">
                <input type="hidden" name="code" value="<%= s.code %>" />
                <button
                  class="tws-btn-white tws-btn-danger"
                  type="submit"
                  <%= alreadyAdded ? "" : "disabled" %>
                >
                  Remove
                </button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>

      <div class="tws-added-list">
        <div style="font-size:13px; font-weight:800;">Added Subjects</div>

        <% if (!tws.createdWorkload || tws.createdWorkload.length === 0) { %>
          <div style="font-size:12px; opacity:.9;">No subjects added yet.</div>
        <% } else { %>
          <% tws.createdWorkload.forEach(item => { %>
            <div class="tws-added-item">
              <b><%= item.code %> - <%= item.title %></b>
              <div class="tws-added-meta">
                <div><strong>Schedule:</strong> <%= item.timeSlot || "—" %></div>
                <div><strong>Section / Room:</strong> <%= item.sectionRoom || "—" %></div>
                <div><strong>Units:</strong> <%= Number(item.units || 0).toFixed(2) %></div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

    </section>

    <div class="tws-footer-actions">
      <a class="tws-btn-white" href="/tws/faculty/<%= tws.id %>">Back</a>
      <a class="tws-next" href="/tws/created-teaching-workload/<%= tws.id %>">Next</a>
    </div>

  </div>
  </main>
</div>

<div class="tws-modal-bg" id="addModal">
  <div class="tws-modal">
    <div class="tws-modal-title" id="modalTitle">Add Subject</div>

    <form method="POST" action="/tws/create-teaching-workload/<%= tws.id %>/add">
      <input type="hidden" name="code" id="m_code" />
      <input type="hidden" name="title" id="m_title" />
      <input type="hidden" name="units" id="m_units" />

      <label>Choose Day</label>
      <select name="day" required>
        <option value="">-- Select --</option>
        <option value="Mon">Mon</option>
        <option value="Tue">Tue</option>
        <option value="Wed">Wed</option>
        <option value="Thu">Thu</option>
        <option value="Fri">Fri</option>
        <option value="Sat">Sat</option>
        <option value="Sun">Sun</option>
      </select>

      <div class="tws-inline-grid">
  <div>
    <label>Start Time</label>
    <select name="startTime" required>
      <option value="">-- Select Start Time --</option>
      <option value="7:00 AM">7:00 AM</option>
      <option value="8:15 AM">8:15 AM</option>
      <option value="9:30 AM">9:30 AM</option>
      <option value="10:45 AM">10:45 AM</option>
      <option value="12:00 PM">12:00 PM</option>
      <option value="1:15 PM">1:15 PM</option>
      <option value="2:30 PM">2:30 PM</option>
      <option value="3:45 PM">3:45 PM</option>
      <option value="5:00 PM">5:00 PM</option>
      <option value="6:15 PM">6:15 PM</option>
      <option value="7:30 PM">7:30 PM</option>
      <option value="8:45 PM">8:45 PM</option>
    </select>
  </div>

  <div>
    <label>End Time</label>
    <select name="endTime" required>
      <option value="">-- Select End Time --</option>
      <option value="8:15 AM">8:15 AM</option>
      <option value="9:30 AM">9:30 AM</option>
      <option value="10:45 AM">10:45 AM</option>
      <option value="12:00 PM">12:00 PM</option>
      <option value="1:15 PM">1:15 PM</option>
      <option value="2:30 PM">2:30 PM</option>
      <option value="3:45 PM">3:45 PM</option>
      <option value="5:00 PM">5:00 PM</option>
      <option value="6:15 PM">6:15 PM</option>
      <option value="7:30 PM">7:30 PM</option>
      <option value="8:45 PM">8:45 PM</option>
      <option value="10:00 PM">10:00 PM</option>
    </select>
  </div>
</div>
      <label style="margin-top:10px;">Choose Section</label>
      <select name="sectionRoom" required>
        <option value="">-- Select --</option>
        <option>A1531 | R611</option>
        <option>A1532 | R612</option>
        <option>A1533 | R613</option>
      </select>

      <div style="font-size:11px; opacity:.85; margin-top:10px; line-height:1.45;">
        Example formats:
        <br />
        7:00 AM
        <br />
        10:45 AM
      </div>

      <div class="tws-modal-actions">
        <button class="tws-modal-cancel" type="button" onclick="closeModal()">Cancel</button>
        <button class="tws-modal-add" type="submit">+ Add Subject</button>
      </div>
    </form>

  </div>
</div>

<script>
function openModal(code, title, units){
  document.getElementById("modalTitle").textContent = `Add Subject: ${code} - ${title}`;
  document.getElementById("m_code").value = code;
  document.getElementById("m_title").value = title;
  document.getElementById("m_units").value = units;
  document.getElementById("addModal").style.display = "flex";
}

function closeModal(){
  document.getElementById("addModal").style.display = "none";
}
</script>

</body>
</html>