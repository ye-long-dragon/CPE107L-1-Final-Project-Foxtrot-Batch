<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>TWS - Dean</title>

  <link rel="stylesheet" href="/TWS/css/twsDeanStyle.css" />
</head>

<body class="twsd-body">
  <div class="twsd-layout">
    <aside class="tws-sidebar">
      <%- include("../partials/sideMenuBar", { currentPageCategory: "tws" }) %>
    </aside>

    <main class="twsd-main">
      <div class="twsd-center">

        <div class="twsd-title-pill">
          <h1>TWS - Dean</h1>
        </div>

        <div class="twsd-glass">

          <section class="twsd-card twsd-card-wide">
            <div class="twsd-card-header">
              <div class="twsd-card-title">Pending Teaching Workload Sheets</div>

              <div class="twsd-chips">
                <a class="twsd-btn twsd-green" href="/tws/create">+ Create TWS</a>
                <button class="twsd-chip" type="button">Filter by Department</button>
                <button class="twsd-chip" type="button" onclick="location.reload()">Refresh</button>
              </div>
            </div>

            <div class="twsd-table">
              <div class="twsd-row twsd-head">
                <div>Faculty Name</div>
                <div>Department</div>
                <div>Academic Year</div>
                <div>Term</div>
                <div>Status</div>
                <div style="text-align:right;">Action</div>
              </div>

              <% if (!pending || pending.length === 0) { %>
                <div class="twsd-row twsd-empty">
                  <div style="grid-column: 1 / -1;">No pending TWS yet.</div>
                </div>
              <% } %>

              <% (pending || []).forEach(tws => { %>
                <div class="twsd-row">
                  <div><%= tws.faculty?.name || "—" %></div>
                  <div><%= tws.faculty?.dept || "—" %></div>
                  <div><%= tws.faculty?.acadYear || tws.schoolYear || "—" %></div>
                  <div><%= tws.faculty?.term || tws.term || "—" %></div>

                  <div class="twsd-status twsd-yellow">
                    <%= tws.approval?.status || "Pending" %>
                  </div>

                  <div class="twsd-btns">
                    <a class="twsd-btn twsd-white" href="/tws/summary/<%= tws.id %>">View</a>
                    <a class="twsd-btn twsd-white" href="/tws/approval/<%= tws.id %>">Approve</a>

                    <form method="POST" action="/tws/approval/<%= tws.id %>" style="display:inline;">
                      <input type="hidden" name="action" value="return" />
                      <button class="twsd-btn twsd-white" type="submit">Return</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            </div>
          </section>

          <section class="twsd-card twsd-card-wide">
            <div class="twsd-card-title">Approved TWS - Ready for HR Archive</div>

            <div class="twsd-table">
              <div class="twsd-row twsd-head twsd-row-4">
                <div>Faculty Name</div>
                <div>Department</div>
                <div>Term</div>
                <div style="text-align:right;">Action</div>
              </div>

              <% if (!details || details.length === 0) { %>
                <div class="twsd-row twsd-empty">
                  <div style="grid-column: 1 / -1;">No approved items yet.</div>
                </div>
              <% } %>

              <% (details || []).forEach(tws => { %>
                <div class="twsd-row twsd-row-4">
                  <div><%= tws.faculty?.name || "—" %></div>
                  <div><%= tws.faculty?.dept || "—" %></div>
                  <div><%= tws.faculty?.term || tws.term || "—" %></div>

                  <div class="twsd-btns">
                    <a class="twsd-btn twsd-white" href="/tws/summary/<%= tws.id %>">View</a>

                    <form method="POST" action="/tws/send-to-hr/<%= tws.id %>" style="display:inline;">
                      <button class="twsd-btn twsd-white" type="submit">Send to HR</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            </div>
          </section>

          <section class="twsd-card twsd-card-wide">
            <div class="twsd-card-header">
              <div class="twsd-card-title">My Teaching Workload Sheets</div>
            </div>

            <div class="twsd-table">
              <div class="twsd-row twsd-head" style="grid-template-columns: 1fr 0.55fr 0.9fr 0.9fr 1fr;">
                <div>Academic Year</div>
                <div>Term</div>
                <div>Date Created</div>
                <div>Status</div>
                <div style="text-align:right;">Action</div>
              </div>

              <% if (!personal || personal.length === 0) { %>
                <div class="twsd-row twsd-empty" style="grid-template-columns: 1fr;">
                  <div>No TWS yet. Click "Create TWS" to start.</div>
                </div>
              <% } %>

              <%
                function formatDatePH(value) {
                  var date = value ? new Date(value) : new Date();
                  if (isNaN(date.getTime())) return "—";
                  return date.toLocaleDateString("en-US", {
                    month: "2-digit",
                    day: "2-digit",
                    year: "numeric",
                    timeZone: "Asia/Manila",
                  });
                }
              %>

              <% (personal || []).forEach(tws => { %>
                <div class="twsd-row" style="grid-template-columns: 1fr 0.55fr 0.9fr 0.9fr 1fr;">
                  <div><%= tws.faculty?.acadYear || tws.schoolYear || "—" %></div>
                  <div><%= tws.faculty?.term || tws.term || "—" %></div>
                  <div><%= formatDatePH(tws.createdAt) %></div>
                  <div><%= tws.status || "Draft" %></div>

                  <div class="twsd-btns">
                    <a class="twsd-btn twsd-white" href="/tws/created-teaching-workload/<%= tws.id %>?mode=view&from=dean">View</a>
                    <a class="twsd-btn twsd-white" href="/tws/faculty/<%= tws.id %>">Edit</a>
                    <form method="POST" action="/tws/<%= tws.id %>/delete" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this TWS? This cannot be undone.');">
                      <button class="twsd-btn twsd-white" type="submit">Delete</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            </div>
          </section>

          <div class="twsd-next-wrap">
            <a class="twsd-next" href="/tws/review-details">Next</a>
          </div>

        </div>

      </div>
    </main>
  </div>
</body>
</html>