<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TWS - Submission Status</title>

  <link rel="stylesheet" href="/common/css/variables.css" />
  <link rel="stylesheet" href="/TWS/css/twsStyle.css" />
  <link rel="icon" href="/common/img/chalkboardLogo.ico" type="image/x-icon">
</head>

<body class="tws-app-body">
  <div class="tws-app-layout">
    <% const role = user.role.toLowerCase(); %>

    <aside class="tws-sidebar">
      <% if (role.includes("prog")) { %>

        <%- include("../MainPages/progChair/partials/progChairMenuBar", { currentPageCategory: "tws", user }) %>

      <% } else if (role.includes("dean")) { %>

        <%- include("../MainPages/dean/partials/deanMenuBar", { currentPageCategory: "tws", user }) %>

      <% } else if (role.includes("admin")) { %>

        <%- include("../MainPages/admin/partials/adminSideMenuBar", { currentPageCategory: "tws", user }) %>

      <% } else { %>

        <%- include("../partials/sideMenuBar", { currentPageCategory: "tws", user }) %>

      <% } %>
    </aside>

    <main class="tws-app-main">
      <div class="tws-app-center">

        <div class="tws-app-title-pill">
          <h1>TWS - Submission Status</h1>
        </div>

        <section class="tws-card">
          <div class="tws-card-title" style="margin-bottom:10px;">
            Your Teaching Workload Sheet has been <b><%= tws.status || "Submitted" %></b>.
          </div>

          <!-- Stepper (dynamic from stepperState) -->
          <div class="tws-stepper">
            <%
              const steps = (tws.stepperState && tws.stepperState.steps) || [
                { label: "Submitted", state: "done" },
                { label: "Secretary Review", state: "pending" },
                { label: "Chair Endorsement", state: "pending" },
                { label: "Dean Approval", state: "wait" },
              ];
            %>
            <% steps.forEach((step, idx) => { %>
              <% if (idx > 0) { %><div class="tws-line"></div><% } %>
              <div class="tws-step tws-step-<%= step.state %>">
                <div class="tws-dot"><%= step.state === "done" ? "✔" : "" %></div>
                <div class="tws-step-text"><%= step.label %></div>
              </div>
            <% }) %>
          </div>

          <!-- Metrics -->
          <div class="tws-metrics">
            <div>Total Units:</div><div><%= tws.totals?.totalUnits ?? 0 %></div>
            <div>Total Hours:</div><div><%= tws.totals?.totalHours ?? 0 %></div>
          </div>

          <div class="tws-footer-actions">
            <a class="tws-next" href="/tws/approval/<%= tws.id %>">Next</a>
            <a class="tws-btn-white" href="/tws/dashboard">Back to Dashboard</a>
          </div>
        </section>

      </div>
    </main>
  </div>
</body>
</html>