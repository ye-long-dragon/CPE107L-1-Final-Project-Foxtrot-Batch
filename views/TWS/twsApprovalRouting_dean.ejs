<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>TWS - Approval Routing</title>

  <link rel="stylesheet" href="/common/css/variables.css" />
  <link rel="stylesheet" href="/TWS/css/twsDeanStyle.css" />
  <link rel="icon" href="/common/img/chalkboardLogo.ico" type="image/x-icon">
</head>

<body class="twsd-body">
  <div class="twsd-layout">
    <% const role = user.role.toLowerCase(); %>

    <aside class="tws-sidebar">
      <% if (role.includes("prog")) { %>

        <%- include("../MainPages/progChair/partials/progChairMenuBar", { currentPageCategory: "tws", user }) %>

      <% } else if (role.includes("dean")) { %>

        <%- include("../MainPages/dean/partials/deanMenuBar", { currentPageCategory: "tws", user }) %>

      <% } else if (role.includes("admin")) { %>

        <%- include("../MainPages/admin/partials/adminSideMenuBar", { currentPageCategory: "tws", user }) %>

      <% } else { %>

        <%- include("../partials/sideMenuBar", { currentPageCategory: "tws", user }) %>

      <% } %>
    </aside>

    <main class="twsd-main">
      <div class="twsd-center">

        <div class="twsd-title-pill">
          <h1>TWS - Approval Routing</h1>
        </div>

        <div class="twsd-glass">
          <div class="twsd-approval-wrap">

            <div class="twsd-approval-top">
              <h2>APPROVED BY:</h2>
              <div style="font-weight:900; margin-top:2px;">DEAN</div>

              <div class="small">Faculty: <b><%= tws.faculty?.name || "-" %></b></div>
              <div class="small">Department: <b><%= tws.faculty?.dept || "-" %></b></div>
              <div class="small">Current Status: <b><%= tws.status || "Pending" %></b></div>
              <div class="small">Faculty Signature: <b><%= tws.facultySigned ? "Complete" : "Missing" %></b></div>
              <div class="small">Program Chair Signature: <b><%= tws.programChairSigned ? "Complete" : "Missing" %></b></div>
            </div>

            <div class="twsd-approval-bottom">
              <div class="twsd-approve-line">
                <span class="twsd-arrow">v</span>
                <span>Dean Decision</span>
                <div class="twsd-line"></div>
              </div>

              <% if (typeof errorMessage !== "undefined" && errorMessage) { %>
                <div style="margin: 0 0 12px 0; background: rgba(220,38,38,0.2); border:1px solid rgba(220,38,38,0.45); color:#fff; border-radius:12px; padding:10px 12px; font-size:12px;">
                  <b>Action blocked:</b> <%= errorMessage %>
                </div>
              <% } %>

              <form method="POST" action="/tws/approval/<%= tws.id %>">
                <div style="margin: 12px 0 18px 0;">
                  <textarea
                    name="remarks"
                    placeholder="Remarks (optional)"
                    style="width:100%; min-height:120px; border:none; border-radius:18px; padding:14px; outline:none;"
                  ><%= tws.approval?.remarks || "" %></textarea>
                </div>

                <div class="twsd-approval-actions">
                  <button class="twsd-btn twsd-green" type="submit" name="action" value="approve">Approve</button>
                  <button class="twsd-btn twsd-white" type="submit" name="action" value="reject">Reject</button>
                  <button class="twsd-btn twsd-white" type="submit" name="action" value="return">Return</button>
                </div>
              </form>

              <div style="margin-top:16px; display:flex; gap:8px; flex-wrap:wrap;">
                <a class="twsd-btn twsd-white" href="/tws/dean" style="text-decoration:none;">Back</a>
                <a class="twsd-btn twsd-white" href="/tws/signature-settings" style="text-decoration:none;">E-Signature Settings</a>
              </div>
            </div>

          </div>
        </div>

      </div>
    </main>
  </div>
</body>
</html>
