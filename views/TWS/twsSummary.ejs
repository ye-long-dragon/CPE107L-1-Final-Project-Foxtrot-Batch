<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TWS - Summary</title>

  <link rel="stylesheet" href="/common/css/variables.css" />
  <link rel="stylesheet" href="/TWS/css/twsStyle.css" />
  <link rel="icon" href="/common/img/chalkboardLogo.ico" type="image/x-icon">
  <style>
    .tws-block {
      grid-column: var(--col, auto);
      grid-row: var(--row, auto) / span var(--span, 1);
    }
  </style>
</head>

<body class="tws-app-body">
  <div class="tws-app-layout">
    <aside class="tws-app-sidebar">
      <%- include("../partials/sideMenuBar", { currentPageCategory: "tws" }) %>
    </aside>

    <main class="tws-app-main">
      <div class="tws-app-center">

        <div class="tws-app-title-pill">
          <h1>Teaching Workload Sheet Summary</h1>
        </div>

        <section class="tws-card tws-created-sheet">
          <% const currentStatus = tws.status || "Draft"; %>
          <% const isChair = !!canManageAsChair; %>
          <% const isProfessor = !!(user && user.role === "Professor"); %>
          <% const isProgramChair = !!(user && user.role === "Program-Chair"); %>
          <% const isDean = !!(user && user.role === "Dean"); %>
          <% const canFacultyReview = isProfessor && ["Sent to Faculty", "Faculty Approved"].includes(currentStatus); %>
          <% const canFacultySign = isProfessor && currentStatus === "Sent to Faculty" && !tws.facultySigned; %>
          <% const canFacultyReturn = canFacultyReview; %>
          <% const canFacultySaveNotes = canFacultyReview; %>
          <% const canSendToFaculty = isChair && !selfAssignedProgramChair && ["Draft", "Returned to Program Chair", "Rejected"].includes(currentStatus); %>          
          <% const canSendToDean = isChair && isProgramChair && (
            (selfAssignedProgramChair && ["Draft", "Returned to Program Chair", "Rejected"].includes(currentStatus)) ||
            (["Sent to Faculty", "Faculty Approved"].includes(currentStatus) && !!tws.facultySigned)
          ); %>
          <% const canEdit = isChair && ["Draft", "Returned to Program Chair", "Rejected"].includes(currentStatus); %>
          <% const canDownloadPdf = currentStatus === "Approved" || currentStatus === "Archived"; %>

          <% if (typeof errorMessage !== "undefined" && errorMessage) { %>
            <div style="margin-bottom:12px; background: rgba(220,38,38,0.2); border:1px solid rgba(220,38,38,0.45); color:#1f2937; border-radius:12px; padding:10px 12px; font-size:12px;">
              <b>Action blocked:</b> <%= errorMessage %>
            </div>
          <% } %>

          <% if (typeof noteSaved !== "undefined" && noteSaved) { %>
            <div style="margin-bottom:12px; background: rgba(22,163,74,0.2); border:1px solid rgba(22,163,74,0.45); color:#1f2937; border-radius:12px; padding:10px 12px; font-size:12px;">
              <b>Saved:</b> Faculty notes were updated successfully.
            </div>
          <% } %>

          <form method="POST" action="/tws/summary/<%= tws.id %>">

            <div style="display:flex; gap:18px; align-items:flex-start; justify-content:space-between; flex-wrap:wrap;">
              <div style="flex: 1; min-width: 520px;">

                <div class="tws-card-title" style="margin-bottom:10px;">Instructor Information</div>

                <div style="display:grid; grid-template-columns: 180px 1fr; gap:10px 14px; font-size:12px;">
                  <div style="font-weight:800;">Faculty Name:</div><div><%= tws.faculty?.name || "—" %></div>
                  <div style="font-weight:800;">Employee ID:</div><div><%= tws.faculty?.empId || "—" %></div>
                  <div style="font-weight:800;">Faculty Email:</div><div><%= tws.faculty?.email || "—" %></div>
                  <div style="font-weight:800;">Department:</div><div><%= tws.faculty?.dept || "—" %></div>
                  <div style="font-weight:800;">Academic Year:</div><div><%= tws.faculty?.acadYear || "—" %></div>
                  <div style="font-weight:800;">Term:</div><div><%= tws.faculty?.term || "—" %></div>
                  <div style="font-weight:800;">Employment Status:</div><div><%= tws.faculty?.empStatus || "—" %></div>
                  <div style="font-weight:800;">Current Status:</div><div><%= tws.status || "Draft" %></div>

                  <% if (tws.facultySigned) { %>
                    <div style="font-weight:800;">Faculty Signature Status:</div>
                    <div>
                      Signed
                      <% if (tws.facultySignedAt) { %>
                        - <%= new Date(tws.facultySignedAt).toLocaleString("en-US", { timeZone: "Asia/Manila" }) %> (PHT)
                      <% } %>
                    </div>
                  <% } %>

                  <% if (tws.programChairSigned) { %>
                    <div style="font-weight:800;">Program Chair Signature:</div>
                    <div>
                      Signed
                      <% if (tws.programChairSignedAt) { %>
                        - <%= new Date(tws.programChairSignedAt).toLocaleString("en-US", { timeZone: "Asia/Manila" }) %> (PHT)
                      <% } %>
                    </div>
                  <% } %>

                  <% if (tws.deanSigned) { %>
                    <div style="font-weight:800;">Dean Signature:</div>
                    <div>
                      Signed
                      <% if (tws.deanSignedAt) { %>
                        - <%= new Date(tws.deanSignedAt).toLocaleString("en-US", { timeZone: "Asia/Manila" }) %> (PHT)
                      <% } %>
                    </div>
                  <% } %>

                  <% if (tws.facultyNotes) { %>
                    <div style="font-weight:800;">Faculty Notes:</div>
                    <div class="tws-faculty-notes-display"><%= tws.facultyNotes %></div>

                    <div style="font-weight:800;">Notes Updated:</div>
                    <div>
                      <%= tws.facultyNotesUpdatedAt ? new Date(tws.facultyNotesUpdatedAt).toLocaleString("en-US", { timeZone: "Asia/Manila" }) + " (PHT)" : "—" %>
                      <% if (tws.facultyNotesUpdatedBy) { %>
                        by <%= tws.facultyNotesUpdatedBy %>
                      <% } %>
                    </div>
                  <% } %>
                </div>

                <div class="tws-card-title" style="margin-top:18px;">Teaching Load Overview</div>

                <div style="display:grid; grid-template-columns: 180px 1fr 220px 1fr; gap:10px 14px; font-size:12px; margin-top:10px;">
                  <div style="font-weight:800;">Total Units:</div><div><%= Number(tws.totals?.totalUnits || 0).toFixed(2) %></div>
                  <div style="font-weight:800;">Total Hours:</div><div><%= Number(tws.totals?.totalHours || 0).toFixed(2) %></div>

                  <div style="font-weight:800;">Equivalent Load:</div><div><%= Number(tws.totals?.equivLoad || 0).toFixed(2) %></div>
                  <div style="font-weight:800;">Approval Status:</div><div><%= tws.approval?.status || "Not Submitted" %></div>
                </div>
              </div>

              <div style="width: 260px; display:flex; flex-direction:column; gap:12px; align-items:flex-end;">

                <% if (canSendToFaculty) { %>
                  <button
                    type="submit"
                    name="action"
                    value="sendToFaculty"
                    style="border:none; cursor:pointer; background: #3b82f6; color:#fff; border-radius:999px; padding: 14px 22px; font-weight:900; width:100%;"
                  >
                    Send to Faculty
                  </button>
                <% } %>

                <% if (canSendToDean) { %>
                  <button
                    type="submit"
                    name="action"
                    value="sendToDean"
                    style="border:none; cursor:pointer; background:#22c55e; color:#fff; border-radius:999px; padding: 14px 22px; font-weight:900; width:100%;"
                  >
                    Send to Dean
                  </button>
                <% } %>

                <% if (isChair && !canSendToFaculty && !canSendToDean) { %>
                  <div class="tws-status-note">
                    Current status is <b><%= currentStatus %></b>.
                    <% if (isProgramChair && currentStatus === "Sent to Faculty" && !tws.facultySigned) { %>
                      Waiting for faculty signature before sending to Dean.
                    <% } else { %>
                      This record cannot be re-sent from this page.
                    <% } %>
                  </div>
                <% } %>

                <% if (isDean && tws.status === "Approved") { %>
                  <button
                    type="submit"
                    formaction="/tws/send-to-hr/<%= tws.id %>"
                    formmethod="POST"
                    class="tws-btn-white"
                    style="width:100%; font-weight:900;"
                  >
                    Send Approved TWS to HR Archive
                  </button>
                <% } %>

                <% if (canDownloadPdf) { %>
                  <a
                    href="/tws/pdf/<%= tws.id %>"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="tws-btn-white"
                    style="text-decoration:none; text-align:center; width:100%;"
                  >
                    View PDF
                  </a>
                <% } else { %>
                  <button class="tws-btn-white" type="button" disabled style="width:100%;">
                    View PDF (Final Approval Required)
                  </button>
                <% } %>

                <% if (canEdit) { %>
                  <button
                    type="submit"
                    name="action"
                    value="edit"
                    class="tws-btn-white"
                    style="cursor:pointer; width:100%;"
                  >
                    Edit
                  </button>
                <% } %>

                <a href="<%= viewBackUrl || '/tws/dashboard' %>" class="tws-btn-white" style="text-decoration:none; text-align:center; width:100%;">
                  Back
                </a>

                <% if (canFacultySign) { %>
                  <button
                    type="submit"
                    formaction="/tws/signature"
                    formmethod="POST"
                    class="tws-btn-white"
                    style="cursor:pointer; width:100%;"
                    onclick="return confirm('Use your saved e-signature for this TWS?')"
                  >
                    Sign TWS
                  </button>
                <% } %>

                <% if (canFacultyReturn) { %>
                  <button
                    type="submit"
                    formaction="/tws/faculty-return/<%= tws.id %>"
                    formmethod="POST"
                    class="tws-btn-white"
                    style="cursor:pointer; width:100%;"
                    onclick="return confirm('Return this TWS for revision?')"
                  >
                    Return for Revision
                  </button>
                <% } %>
              </div>
            </div>

            <% if (canFacultySign) { %>
              <input type="hidden" name="id" value="<%= tws.id %>" />
            <% } %>

            <% if (canFacultySaveNotes) { %>
              <div class="tws-revision-box">
                <label for="facultyReturnRemarks" class="tws-revision-label">Revision Notes (optional)</label>
                <div class="tws-revision-help">
                  If you want changes in your schedule, write the requested revisions here before returning this TWS to the Program Chair.
                </div>
                <textarea
                  id="facultyReturnRemarks"
                  name="remarks"
                  rows="3"
                  placeholder="State what needs to be revised before approval."
                  class="tws-revision-textarea"
                ><%= tws.facultyNotes || "" %></textarea>

                <div class="tws-revision-actions">
                  <button
                    type="submit"
                    formaction="/tws/faculty-note/<%= tws.id %>"
                    formmethod="POST"
                    class="tws-btn-white"
                    style="cursor:pointer;"
                  >
                    Save Notes
                  </button>
                </div>
              </div>
            <% } %>

            <div class="tws-card-title" style="margin-top:18px;">Weekly Schedule</div>

            <div class="tws-schedule-layout" style="margin-top:10px;">
              <div class="tws-timetable">
                <%
                  const days = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];
                  const times = [
                    "7:00 AM", "8:15 AM", "9:30 AM", "10:45 AM", "12:00 PM",
                    "1:15 PM", "2:30 PM", "3:45 PM", "5:00 PM", "6:15 PM", "7:30 PM", "8:45 PM"
                  ];
                  const SLOT_MINUTES = 75;
                %>

                <div class="tws-cell tws-head tws-corner"></div>
                <% days.forEach(function(day) { %>
                  <div class="tws-cell tws-head"><%= day %></div>
                <% }) %>

                <% times.forEach(function(time, rowIndex) {
                     const row = rowIndex + 2;
                %>
                  <div class="tws-cell tws-time" style="--row: <%= row %>;"><%= time %></div>
                  <% for (let c = 0; c < 7; c++) { %>
                    <div class="tws-cell tws-slot" style="--row: <%= row %>; --col: <%= c + 2 %>;"></div>
                  <% } %>
                <% }) %>

                <%
                  const dayMap = { Mon: 2, Tue: 3, Wed: 4, Thu: 5, Fri: 6, Sat: 7, Sun: 8 };
                  const dayAlias = { mon: "Mon", tue: "Tue", wed: "Wed", thu: "Thu", fri: "Fri", sat: "Sat", sun: "Sun" };
                  const GRID_START_MINUTES = 7 * 60;
                  const GRID_MIN_ROW = 2;
                  const GRID_MAX_SLOT = times.length - 1;

                  function toMinutes(timeStr) {
                    if (!timeStr) return null;
                    const match = String(timeStr).trim().match(/^(\d{1,2}):(\d{2})\s*(AM|PM)$/i);
                    if (!match) return null;
                    let hour = Number(match[1]);
                    const minute = Number(match[2]);
                    const ampm = match[3].toUpperCase();
                    if (ampm === "PM" && hour !== 12) hour += 12;
                    if (ampm === "AM" && hour === 12) hour = 0;
                    return hour * 60 + minute;
                  }

                  function parseSchedule(item) {
                    const rawDay = String(item.day || "").trim();
                    const rawStart = String(item.startTime || "").trim();
                    const rawEnd = String(item.endTime || "").trim();
                    const rawSlot = String(item.timeSlot || "").trim();

                    let day = rawDay;
                    let startStr = rawStart;
                    let endStr = rawEnd;

                    if ((!startStr || !endStr) && rawSlot) {
                      const slotMatch = rawSlot.match(/^(?:(Mon|Tue|Wed|Thu|Fri|Sat|Sun)\s+)?(.+?)\s*-\s*(.+)$/i);
                      if (slotMatch) {
                        day = day || slotMatch[1] || "";
                        startStr = startStr || (slotMatch[2] || "").trim();
                        endStr = endStr || (slotMatch[3] || "").trim();
                      }
                    }

                    const startMin = toMinutes(startStr);
                    const endMin = toMinutes(endStr);
                    const normalizedDay = dayAlias[String(day).slice(0, 3).toLowerCase()] || day;

                    if (!dayMap[normalizedDay] || startMin === null || endMin === null || endMin <= startMin) {
                      return null;
                    }

                    const startSlot = Math.round((startMin - GRID_START_MINUTES) / SLOT_MINUTES);
                    const endSlot = Math.round((endMin - GRID_START_MINUTES) / SLOT_MINUTES);
                    const clampedStartSlot = Math.max(0, Math.min(GRID_MAX_SLOT, startSlot));
                    const clampedEndSlot = Math.max(
                      clampedStartSlot + 1,
                      Math.min(times.length, endSlot)
                    );
                    const row = clampedStartSlot + GRID_MIN_ROW;
                    const span = Math.max(1, clampedEndSlot - clampedStartSlot);

                    return {
                      day: normalizedDay,
                      startStr: startStr,
                      endStr: endStr,
                      startMin: startMin,
                      endMin: endMin,
                      row: row,
                      span: span
                    };
                  }

                  function getSubjectKey(item) {
  return `${String(item.code || "").trim()}|${String(item.sectionRoom || "").trim()}`;
}

                  function buildColorMap(workload) {
                    const subjectColors = ["color-1", "color-2", "color-3", "color-4", "color-5", "color-6"];
                    const uniqueKeys = [];

                    (workload || []).forEach((item) => {
                      const key = getSubjectKey(item);
                      if (key && !uniqueKeys.includes(key)) {
                        uniqueKeys.push(key);
                      }
                    });

                    uniqueKeys.sort();

                    const colorMap = {};
                    uniqueKeys.forEach((key, index) => {
                      colorMap[key] = subjectColors[index % subjectColors.length];
                    });

                    return colorMap;
                  }

                  const parsedBlocks = (tws?.createdWorkload || []).map(function(item) {
                    return {
                      item: item,
                      parsed: parseSchedule(item),
                      isConflict: false,
                    };
                  });

                  const subjectColorMap = buildColorMap(tws?.createdWorkload || []);

                  for (let i = 0; i < parsedBlocks.length; i++) {
                    for (let j = i + 1; j < parsedBlocks.length; j++) {
                      const a = parsedBlocks[i].parsed;
                      const b = parsedBlocks[j].parsed;
                      if (!a || !b || a.day !== b.day) continue;
                      const overlaps = a.startMin < b.endMin && b.startMin < a.endMin;
                      if (overlaps) {
                        parsedBlocks[i].isConflict = true;
                        parsedBlocks[j].isConflict = true;
                      }
                    }
                  }

                  parsedBlocks.forEach(function(block) {
                    const p = block.parsed;
                    if (!p) return;
                    const col = dayMap[p.day];
                    const row = p.row;
                    const assignedColorClass = subjectColorMap[getSubjectKey(block.item)] || "color-1";
                    const colorClass = block.isConflict ? "tws-block-conflict" : `${assignedColorClass} tws-block-assigned`;
                    const compactSectionRoom = String(block.item.sectionRoom || "").replace(/\s*\|\s*/g, "|");
                    const compactTimeRange = `${p.startStr} - ${p.endStr}`.replace(/\s*-\s*/g, "-");
                %>
                  <div
                    class="tws-block <%= colorClass %>"
                    style="--col: <%= col %>; --row: <%= row %>; --span: <%= p.span %>;"
                  >
                    <div class="tws-block-code"><%= block.item.code || "—" %></div>
                    <div class="tws-block-sub"><%= compactSectionRoom %></div>
                    <div class="tws-block-sub"><%= compactTimeRange %></div>
                  </div>
                <%
                  });
                %>
              </div>

              <div class="tws-load-details">
                <div class="ld-title">Load Details</div>

                <div class="ld-row">
                  Total Teaching Hours
                  <span><%= Number(tws?.teachingHours || tws?.totals?.totalHours || 0).toFixed(2) %></span>
                </div>

                <div class="ld-divider"></div>

                <% if (!tws?.createdWorkload || tws.createdWorkload.length === 0) { %>
                  <div style="opacity:.9; font-size:12px; padding:10px 0;">
                    No subjects found for this TWS record.
                  </div>
                <% } %>

                <% (tws?.createdWorkload || []).forEach(function(subject) { %>
                  <div class="ld-row" style="gap:10px;">
                    <div style="max-width:220px;">
                      <b><%= subject.code || "—" %></b>
                      <div style="opacity:.9; font-size:11px; margin-top:2px;">
                        <%= subject.timeSlot || "No schedule" %> • <%= subject.sectionRoom || "—" %>
                      </div>
                    </div>
                    <span><%= Number(subject.units || 0).toFixed(2) %></span>
                  </div>
                <% }) %>

                <div class="ld-divider"></div>

                <div class="ld-row">
                  <b>Total Hours</b>
                  <span><b><%= Number(tws?.totalHours || tws?.totals?.totalHours || 0).toFixed(2) %></b></span>
                </div>

                <div class="ld-row" style="border-bottom:none; padding-bottom:0;">
                  <b>Unit Distribution</b>
                  <span></span>
                </div>

                <div class="ld-row">
                  Academic Units
                  <span><%= Number(tws?.academicUnits || tws?.totals?.totalUnits || 0).toFixed(2) %></span>
                </div>

                <div class="ld-row">
                  PE Units
                  <span><%= Number(tws?.peUnits || 0).toFixed(2) %></span>
                </div>

                <div class="ld-row">
                  Values Units
                  <span>0.00</span>
                </div>

                <div class="ld-row">
                  NSTP Units
                  <span><%= Number(tws?.nstpUnits || 0).toFixed(2) %></span>
                </div>

                <div class="ld-row">
                  Deloading Units
                  <span><%= Number(tws?.deloadingUnits || 0).toFixed(2) %></span>
                </div>

                <div class="ld-divider"></div>

                <div class="ld-row">
                  <b>Total Units</b>
                  <span><b><%= Number(tws?.totalUnits || tws?.totals?.totalUnits || 0).toFixed(2) %></b></span>
                </div>
              </div>
            </div>

          </form>
        </section>

      </div>
    </main>
  </div>

  <%- include("./partials/twsNotifications") %>
</body>
</html>