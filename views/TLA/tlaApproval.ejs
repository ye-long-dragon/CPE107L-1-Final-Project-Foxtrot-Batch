<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TLA | Approval Review</title>

    <!-- School palette variables -->
    <link rel="stylesheet" href="/common/css/variables.css">
    <!-- Material icons -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <!-- Approval page styles -->
    <link rel="stylesheet" href="/TLA/css/tlaApproval.css">
</head>
<body>

    <main class="main-content">
        <div class="background-overlay"></div>

        <!-- ═══════════════════════════════════════════════════════════
             HEADER BAR — Course Info + School Logo
        ═══════════════════════════════════════════════════════════ -->
        <header class="approval-header">
            <div class="header-logo">
                <img src="/common/img/schoolLogo.png" alt="School Logo">
            </div>
            <div class="header-divider"></div>
            <div class="header-info">
                <h1 class="course-name"><%= locals.courseName || '[COURSE NAME]' %></h1>
                <p class="course-meta">
                    <span class="meta-item"><%= locals.courseCode || '[COURSE CODE]' %></span>
                    <span class="meta-divider">|</span>
                    <span class="meta-item"><%= locals.section || '[COURSE SECTION]' %></span>
                    <span class="meta-divider">|</span>
                    <span class="meta-item"><%= locals.academicYear || '[ACADEMIC YEAR]' %></span>
                </p>
            </div>
        </header>

        <!-- ═══════════════════════════════════════════════════════════
             BODY LAYOUT — Left (Document) + Right (Sidebar Panel)
        ═══════════════════════════════════════════════════════════ -->
        <div class="approval-body">

            <!-- ─── LEFT: Document Preview ──────────────────────────── -->
            <section class="document-panel">

                <!-- Back button -->
                <a href="<%= locals.user && user.role === 'HR' ? '/tla/hr' : (locals.user && ['Technical','Program-Chair','Dean','Admin','Super-Admin'].includes(user.role) ? '/tla/admin-overview' : '/tla/overview') %>" class="back-btn">
                    <span class="material-symbols-outlined">arrow_back</span> BACK
                </a>

                <div class="file-type-badge">
                    <%= locals.fileType || '[FILE TYPE]' %>
                </div>

                <h2 class="section-title">Basic Information</h2>

                <!-- ── TLA Read-Only Form Preview ── -->
                <div class="document-preview">
                    <% if (locals.tla) { %>

                        <div class="preview-row two-col">
                            <div class="preview-field">
                                <label>NAME</label>
                                <p><%= locals.facultyName || '—' %></p>
                            </div>
                            <div class="preview-field">
                                <label>Faculty Member Facilitating Digital Session</label>
                                <p><%= tla.facultyFacilitating || '—' %></p>
                            </div>
                        </div>

                        <div class="preview-row two-col">
                            <div class="preview-field">
                                <label>Section(s)</label>
                                <p><%= tla.section || '—' %></p>
                            </div>
                            <div class="preview-field">
                                <label>Course Code</label>
                                <p><%= tla.courseCode || '—' %></p>
                            </div>
                        </div>

                        <div class="preview-row two-col">
                            <div class="preview-field">
                                <label>Date of Digital Day</label>
                                <p><%= tla.dateofDigitalDay || '—' %></p>
                            </div>
                            <div class="preview-field">
                                <label>Week Number</label>
                                <p><%= tla.weekNumber || '—' %></p>
                            </div>
                        </div>

                        <div class="preview-row">
                            <div class="preview-field full-width">
                                <label>Course Outcome(s)</label>
                                <p><%= tla.courseOutcomes || '—' %></p>
                            </div>
                        </div>

                        <div class="preview-row">
                            <div class="preview-field full-width">
                                <label>Mediating / Intended Learning Outcome(s)</label>
                                <p><%= tla.mediatingOutcomes || '—' %></p>
                            </div>
                        </div>

                        <!-- Pre-Digital Session -->
                        <h3 class="sub-section-title">PRE-DIGITAL SESSION</h3>
                        <div class="preview-row two-col">
                            <div class="preview-field">
                                <label>MO/ILO Code</label>
                                <p><%= locals.preDigital && preDigital.moIloCode ? preDigital.moIloCode : '—' %></p>
                            </div>
                            <div class="preview-field">
                                <label>Teaching Learning Activity</label>
                                <p><%= locals.preDigital && preDigital.teacherLearningActivity ? preDigital.teacherLearningActivity : '—' %></p>
                            </div>
                        </div>
                        <div class="preview-row two-col">
                            <div class="preview-field">
                                <label>LMS / Digital Tool</label>
                                <p><%= locals.preDigital && preDigital.lmsDigitalTool ? preDigital.lmsDigitalTool : '—' %></p>
                            </div>
                            <div class="preview-field">
                                <label>Assessment</label>
                                <p><%= locals.preDigital && preDigital.assessment ? preDigital.assessment : '—' %></p>
                            </div>
                        </div>

                        <!-- Post-Digital Session -->
                        <h3 class="sub-section-title">POST-DIGITAL SESSION</h3>
                        <div class="preview-row two-col">
                            <div class="preview-field">
                                <label>MO/ILO Code</label>
                                <p><%= locals.postDigital && postDigital.moIloCode ? postDigital.moIloCode : '—' %></p>
                            </div>
                            <div class="preview-field">
                                <label>Participant Turnout</label>
                                <p><%= locals.postDigital && postDigital.participantTurnout ? postDigital.participantTurnout : '—' %></p>
                            </div>
                        </div>
                        <div class="preview-row two-col">
                            <div class="preview-field">
                                <label>Assessment Results</label>
                                <p><%= locals.postDigital && postDigital.assessmentResults ? postDigital.assessmentResults : '—' %></p>
                            </div>
                            <div class="preview-field">
                                <label>Remarks</label>
                                <p><%= locals.postDigital && postDigital.remarks ? postDigital.remarks : '—' %></p>
                            </div>
                        </div>

                    <% } else { %>
                        <div class="no-data-placeholder">
                            <p>[FORMS FROM THE RESPECTIVE GROUPS (EX. TLA FORMS, SYLLABUS FORMS)]</p>
                        </div>
                    <% } %>
                </div>
            </section>

            <!-- ─── RIGHT: Approval Sidebar ─────────────────────────── -->
            <aside class="approval-sidebar">

                <h3 class="sidebar-title">
                    <%= locals.user ? user.role : '[USER PERMISSION]' %>
                    <% if (locals.macroStatus) { %>
                        <span class="macro-status-chip <%=
                            locals.macroStatus === 'Pending' ? 'chip-pending' :
                            locals.macroStatus === 'Tech-Approved' ? 'chip-tech-approved' :
                            locals.macroStatus === 'Chair-Approved' ? 'chip-chair-approved' :
                            locals.macroStatus === 'Dean-Approved' ? 'chip-dean-approved' :
                            locals.macroStatus === 'Archived' ? 'chip-archived' :
                            locals.macroStatus === 'Returned' ? 'chip-returned' : ''
                        %>"><%= locals.macroStatus %></span>
                    <% } %>
                </h3>

                <div class="approval-tracker">
                    <%
                        // Build tracker steps with per-step data from the controller
                        // approvalSteps: { faculty, technical, programChair, dean, hr }
                        // stepData is the current user's step doc (pre-filled remarks)

                        // Helper to format date
                        function fmtDate(d) {
                            if (!d) return '';
                            try { return new Date(d).toLocaleDateString('en-PH', { month:'short', day:'numeric', year:'numeric' }); }
                            catch(e) { return ''; }
                        }

                        const steps = [
                            {
                                role:   'Faculty',
                                label:  'Submitted',
                                status: locals.approvalSteps ? approvalSteps.faculty : 'pending',
                                detail: ''
                            },
                            {
                                role:   'Technical',
                                label:  'Assessed',
                                status: locals.approvalSteps ? approvalSteps.technical : 'pending',
                                detail: locals.approvalStatusId && tla ? '' : ''
                            },
                            {
                                role:   'Program Chair',
                                label:  'Reviewed',
                                status: locals.approvalSteps ? approvalSteps.programChair : 'pending',
                                detail: ''
                            },
                            {
                                role:   'Dean',
                                label:  'Approved',
                                status: locals.approvalSteps ? approvalSteps.dean : 'pending',
                                detail: ''
                            },
                            {
                                role:   'HR',
                                label:  'Archived',
                                status: locals.approvalSteps ? approvalSteps.hr : 'pending',
                                detail: ''
                            }
                        ];
                    %>

                    <div class="tracker-steps">
                        <% steps.forEach(function(step, idx) { %>
                            <div class="tracker-step">
                                <div class="step-dot step-<%= step.status %>"></div>
                                <% if (idx < steps.length - 1) { %>
                                    <div class="step-line line-<%= step.status %>"></div>
                                <% } %>
                                <div class="step-labels">
                                    <span class="step-role"><%= step.role %></span>
                                    <span class="step-sublabel"><%= step.label %></span>
                                    <% if (step.detail) { %>
                                        <span class="step-detail"><%= step.detail %></span>
                                    <% } %>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>

                <!-- ── Comments ── -->
                <div class="sidebar-section">
                    <label class="sidebar-label">
                        <% if (locals.activeStep) { %>
                            Your Remarks / Comments
                        <% } else { %>
                            Review Comments (Read-Only)
                        <% } %>
                    </label>
                    <textarea id="approval-comments" class="comments-box" rows="5"
                              placeholder="<%= locals.activeStep ? 'Add your remarks...' : 'No active comments for your role.' %>"
                              <%= locals.activeStep ? '' : 'readonly' %>><%= locals.existingComment || '' %></textarea>
                </div>

                <!-- ── Role Action Panel ── -->
                <% if (locals.activeStep) { %>
                    <%
                        const stepLabels = {
                            technical:    'Technical Assessment',
                            programChair: 'Program Chair Approval',
                            dean:         "Dean's Approval",
                            hr:           'HR Archival'
                        };
                    %>
                    <div class="sidebar-section role-action-panel">
                        <p class="action-panel-title">
                            <span class="material-symbols-outlined">verified_user</span>
                            <%= stepLabels[locals.activeStep] || 'Review' %>
                        </p>
                        <p class="action-panel-hint">
                            <% if (locals.activeStep === 'hr') { %>
                                You are archiving this TLA permanently on behalf of HR.
                            <% } else { %>
                                Select your verdict and submit. A <strong>Returned</strong> verdict will send
                                the submission back to the faculty member.
                            <% } %>
                        </p>

                        <!-- Verdict dropdown (hidden for HR — HR only archives) -->
                        <% if (locals.activeStep !== 'hr') { %>
                        <div class="sidebar-section">
                            <label class="sidebar-label">Verdict</label>
                            <div class="status-select-wrapper">
                                <span class="status-indicator" id="status-indicator"></span>
                                <select id="approval-status" class="status-select">
                                    <option value="Approved">Approved</option>
                                    <option value="Returned">Returned</option>
                                </select>
                            </div>
                        </div>
                        <% } %>

                        <!-- E-Signature -->
                        <div class="sidebar-section">
                            <label class="sidebar-label">E-Signature</label>
                            <div class="signature-wrapper">
                                <div class="signature-box" id="signature-box">
                                    <% if (locals.signatureUrl) { %>
                                        <img src="<%= signatureUrl %>" alt="Signature" class="signature-img">
                                    <% } else { %>
                                        <span class="signature-placeholder">Click to upload signature</span>
                                    <% } %>
                                    <input type="file" id="signature-upload" accept="image/*" hidden>
                                </div>
                                <button type="button" class="signature-remove-btn" id="signature-remove"
                                        title="Remove signature" style="display: none;">
                                    <span class="material-symbols-outlined">cancel</span>
                                </button>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="sidebar-actions">
                            <button type="button" class="btn-action btn-pdf" id="btn-save-pdf">
                                <span class="material-symbols-outlined">picture_as_pdf</span>
                                Save as PDF
                            </button>
                            <% if (locals.activeStep !== 'hr') { %>
                            <button type="button" class="btn-action btn-draft" id="btn-save-draft">
                                <span class="material-symbols-outlined">save</span>
                                Save Draft
                            </button>
                            <button type="button" class="btn-action btn-submit" id="btn-submit">
                                <span class="material-symbols-outlined">send</span>
                                Submit Verdict
                            </button>
                            <% } else { %>
                            <!-- HR: Archive button posts to dedicated route -->
                            <form method="POST" action="/tla/hr/archive/<%= locals.tla ? tla._id : '' %>"
                                  onsubmit="return confirm('Archive this TLA permanently? This action cannot be undone.');
                                  " class="hr-archive-form">
                                <input type="hidden" name="comment" id="hr-comment-hidden" value="">
                                <button type="submit" class="btn-action btn-archive-submit"
                                        onclick="document.getElementById('hr-comment-hidden').value = document.getElementById('approval-comments').value;">
                                    <span class="material-symbols-outlined">archive</span>
                                    Archive TLA
                                </button>
                            </form>
                            <% } %>
                        </div>
                    </div>

                <% } else { %>
                    <!-- ── Read-Only Viewer Panel ── -->
                    <div class="sidebar-section readonly-panel">
                        <p class="readonly-title">
                            <span class="material-symbols-outlined">info</span>
                            Read-Only View
                        </p>
                        <p class="readonly-hint">
                            <% if (locals.macroStatus === 'Not Submitted') { %>
                                This TLA has not been submitted by the faculty yet.
                            <% } else if (locals.macroStatus === 'Archived') { %>
                                This TLA has been fully archived. No further action is required.
                            <% } else { %>
                                This TLA is currently at a different review step. Your role will be
                                able to act once it reaches your stage.
                            <% } %>
                        </p>
                        <div class="sidebar-actions">
                            <button type="button" class="btn-action btn-pdf" id="btn-save-pdf">
                                <span class="material-symbols-outlined">picture_as_pdf</span>
                                Save as PDF
                            </button>
                        </div>
                    </div>
                <% } %>
            </aside>
        </div>
    </main>

    <!-- ═══════════════════════════════════════════════════════════
         Hidden data attributes for JS
    ═══════════════════════════════════════════════════════════ -->
    <script>
        const APPROVAL_DATA = {
            tlaID:      '<%= locals.tla ? tla._id : "" %>',
            statusID:   '<%= locals.approvalStatusId || "" %>',
            userRole:   '<%= locals.user ? user.role : "" %>',
            activeStep: '<%= locals.activeStep || "" %>',
            macroStatus:'<%= locals.macroStatus || "" %>'
        };
    </script>
    <script src="/TLA/js/tlaApproval.js"></script>
</body>
</html>
