<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TLA | <%= tla ? 'Edit Form' : 'Create Form' %></title>
    <link rel="icon" type="image/x-icon" href="/common/img/chalkboardLogo.ico">

    <!-- Material Icons -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />

    <!--inside the public file, for colors-->
    <link rel="stylesheet" href="/common/css/variables.css">

    <link rel="stylesheet" href="/TLA/css/tlaForm.css">
</head>
<body>

    <%- include('../partials/sideMenuBar') %>
    
    <main class="main-content">
        <div class="background-overlay"></div>
        
        <div class="form-container">

            <h1>COLLEGE TEACHING-LEARNING ACTIVITY</h1>

            <!-- Status badge for non-editable records -->
            <% if (status && ['Pending','Chair-Approved','Dean-Approved','HR-Approved','Approved','Archived'].includes(status.status)) { %>
                <div class="status-badge status-badge--locked">
                    <% if (status.status === 'Pending') { %>
                        &#9203; This TLA is <strong>Pending</strong> Program Chair review. Pre-digital section is locked.
                    <% } else if (status.status === 'Chair-Approved') { %>
                        &#9203; This TLA is <strong>Chair-Approved</strong>, awaiting Dean review.
                    <% } else if (status.status === 'Dean-Approved') { %>
                        &#9203; This TLA is <strong>Dean-Approved</strong>, awaiting HR/HRMO review.
                    <% } else if (status.status === 'HR-Approved') { %>
                        &#9203; This TLA is <strong>HR-Approved</strong>, awaiting VPAA final approval.
                    <% } else if (status.status === 'Approved') { %>
                        &#9989; This TLA has been <strong>Approved</strong> by VPAA. Fully complete.
                    <% } else { %>
                        &#128274; This TLA is <strong><%= status.status %></strong> and cannot be edited.
                    <% } %>
                </div>
            <% } %>

            <%
                const formAction = tla ? '/tla/form/' + tla._id : '/tla/form';
                // Pre-digital locked when in approval chain or fully approved
                const isLocked   = status && ['Pending','Chair-Approved','Dean-Approved','HR-Approved','Approved','Archived'].includes(status.status);
                const backToOverviewLink = (locals.syllabusId && String(locals.syllabusId).trim())
                    ? ('/tla/overview/' + locals.syllabusId)
                    : '/tla/overview';
            %>
            
            <form id="tla-form" action="<%= formAction %>" method="POST">
                <% if (tla) { %>
                <input type="hidden" name="_tlaId" value="<%= tla._id %>">
                <% } %>
                <div class="form-section top-section">
                    <div class="form-row two-col">
                        <div class="form-group">
                            <label>NAME</label>
                            <input type="text" name="_name" value="<%= user ? user.firstName + ' ' + user.lastName : '' %>" disabled="disabled">
                        </div>
                        <div class="form-group">
                            <label>Faculty Member Facilitating Digital Session</label>
                            <input type="text" name="facultyFacilitating"
                                   value="<%= tla && tla.facultyFacilitating ? tla.facultyFacilitating : '' %>"
                                   <%= isLocked ? 'disabled' : '' %>>
                        </div>
                    </div>
                    
                    <div class="form-row two-col">
                        <div class="form-group">
                            <label>Section(s)</label>
                            <input type="text" name="section"
                                   value="<%= tla && tla.section ? tla.section : '' %>"
                                   <%= isLocked ? 'disabled' : '' %>>
                        </div>
                        <div class="form-group">
                            <label>Course Code</label>
                            <input type="text" name="courseCode"
                                   value="<%= tla && tla.courseCode ? tla.courseCode : (locals.prefillCourseCode || '') %>"
                                   <%= isLocked ? 'disabled' : '' %>>
                        </div>
                    </div>

                    <div class="form-row two-col">
                        <div class="form-group">
                            <label>Date of Digital Day</label>
                            <input type="date" name="dateofDigitalDay"
                                   value="<%= tla && tla.dateofDigitalDay ? tla.dateofDigitalDay : '' %>"
                                   <%= isLocked ? 'disabled' : '' %>>
                        </div>
                        <div class="form-group">
                            <label>Week Number</label>
                            <input type="number" name="weekNumber" min="1" max="18"
                                   value="<%= tla && tla.weekNumber ? tla.weekNumber : (locals.prefillWeekNumber || '') %>"
                                   <%= isLocked ? 'disabled' : '' %>>
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group full-width">
                            <label>Course Outcome(s)</label>
                            <textarea name="courseOutcomes" rows="2" <%= isLocked ? 'disabled' : '' %>><%= tla && tla.courseOutcomes ? tla.courseOutcomes : '' %></textarea>
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group full-width">
                            <label>MEDIATING/INTENDED LEARNING OUTCOME(S) AND CODES (ADD ROWS AS NEEDED)</label>
                            <textarea name="mediatingOutcomes" rows="5" <%= isLocked ? 'disabled' : '' %>><%= tla && tla.mediatingOutcomes ? tla.mediatingOutcomes : '' %></textarea>
                        </div>
                    </div>
                </div>
                
                <%
                    // Post-digital unlocks ONLY after Program-Chair approves
                    // (status reaches Chair-Approved or beyond in the chain)
                    const postApprovedStatuses = ['Chair-Approved', 'Dean-Approved', 'HR-Approved', 'Approved'];
                    const postUnlocked = status && postApprovedStatuses.includes(status.status);
                    const postDisabled = !postUnlocked;
                %>

                <div class="form-sections-row">
                    <div class="form-section half-section">
                        <h3>PRE-DIGITAL SESSION</h3>
                        <div class="form-group">
                            <label>MO/ILO CODE</label>
                            <input type="text" name="pre_moIloCode"
                                   value="<%= preDigital && preDigital.moIloCode ? preDigital.moIloCode : '' %>"
                                   <%= isLocked ? 'disabled' : '' %>>
                        </div>
                        <div class="form-group">
                            <label>Teaching Learning Activity</label>
                            <input type="text" name="pre_teacherLearningActivity"
                                   value="<%= preDigital && preDigital.teacherLearningActivity ? preDigital.teacherLearningActivity : '' %>"
                                   <%= isLocked ? 'disabled' : '' %>>
                        </div>
                        <div class="form-group">
                            <label>LMS Tool / Digital Tool used to Deliver the TLA</label>
                            <input type="text" name="pre_lmsDigitalTool"
                                   value="<%= preDigital && preDigital.lmsDigitalTool ? preDigital.lmsDigitalTool : '' %>"
                                   <%= isLocked ? 'disabled' : '' %>>
                        </div>
                        <div class="form-group">
                            <label>ASSESSMENT</label>
                            <input type="text" name="pre_assessment"
                                   value="<%= preDigital && preDigital.assessment ? preDigital.assessment : '' %>"
                                   <%= isLocked ? 'disabled' : '' %>>
                        </div>
                        <div class="signature-block" id="pre-signature-block">
                            <label>SIGNATURE <span class="sig-format-hint">(PNG only)</span></label>
                            <div class="signature-upload-area" id="pre-sig-area">
                                <% const existingSig = (tla && tla.professorSignature) ? tla.professorSignature : (user && user.signatureImage ? user.signatureImage : ''); %>
                                <% if (existingSig) { %>
                                    <img src="<%= existingSig %>" alt="Signature" class="sig-preview-img" id="pre-sig-preview">
                                <% } else { %>
                                    <span class="sig-placeholder" id="pre-sig-placeholder">Click to upload PNG signature</span>
                                <% } %>
                                <input type="file" accept="image/png" class="sig-file-input" id="pre-sig-input" <%= isLocked ? 'disabled' : '' %>>
                            </div>
                            <% if (!isLocked) { %>
                            <div class="sig-actions">
                                <button type="button" class="sig-upload-btn" id="pre-sig-btn" onclick="document.getElementById('pre-sig-input').click()">
                                    <span class="material-symbols-outlined">upload</span> Upload PNG
                                </button>
                                <button type="button" class="sig-remove-btn" id="pre-sig-remove" style="display: <%= existingSig ? 'inline-flex' : 'none' %>">
                                    <span class="material-symbols-outlined">delete</span> Remove
                                </button>
                            </div>
                            <% } %>
                            <div class="sig-error" id="pre-sig-error" style="display:none"></div>
                        </div>
                    </div>
                    
                    <div class="form-section half-section post-digital-section <%= postDisabled ? 'post-locked' : '' %>">
                        <h3>POST-DIGITAL SESSION</h3>

                        <% if (postDisabled) { %>
                        <div class="post-lock-notice">
                            <% if (status && status.status === 'Pending') { %>
                                &#9203; Waiting for Program-Chair approval before Post-Digital Session can be filled.
                            <% } else { %>
                                &#128274; Post-Digital Session becomes available after Program-Chair approves the Pre-Digital Session.
                            <% } %>
                        </div>
                        <% } %>

                        <div class="form-group">
                            <label>MO/ILO CODE</label>
                            <input type="text" name="post_moIloCode"
                                   value="<%= postDigital && postDigital.moIloCode ? postDigital.moIloCode : '' %>"
                                   <%= postDisabled ? 'disabled' : '' %>>
                        </div>
                        <div class="form-group">
                            <label>PARTICIPANT TURNOUT</label>
                            <input type="text" name="post_participantTurnout"
                                   value="<%= postDigital && postDigital.participantTurnout ? postDigital.participantTurnout : '' %>"
                                   <%= postDisabled ? 'disabled' : '' %>>
                        </div>
                        <div class="form-group">
                            <label>ASSESSMENT RESULTS</label>
                            <input type="text" name="post_assessmentResults"
                                   value="<%= postDigital && postDigital.assessmentResults ? postDigital.assessmentResults : '' %>"
                                   <%= postDisabled ? 'disabled' : '' %>>
                        </div>
                        <div class="form-group">
                            <label>REMARKS</label>
                            <input type="text" name="post_remarks"
                                   value="<%= postDigital && postDigital.remarks ? postDigital.remarks : '' %>"
                                   <%= postDisabled ? 'disabled' : '' %>>
                        </div>
                        <div class="signature-block" id="post-signature-block">
                            <label>SIGNATURE <span class="sig-format-hint">(PNG only)</span></label>
                            <div class="signature-upload-area" id="post-sig-area">
                                <span class="sig-placeholder" id="post-sig-placeholder">Click to upload PNG signature</span>
                                <input type="file" accept="image/png" class="sig-file-input" id="post-sig-input" <%= postDisabled ? 'disabled' : '' %>>
                            </div>
                            <% if (!postDisabled) { %>
                            <div class="sig-actions">
                                <button type="button" class="sig-upload-btn" id="post-sig-btn" onclick="document.getElementById('post-sig-input').click()">
                                    <span class="material-symbols-outlined">upload</span> Upload PNG
                                </button>
                                <button type="button" class="sig-remove-btn" id="post-sig-remove" style="display:none">
                                    <span class="material-symbols-outlined">delete</span> Remove
                                </button>
                            </div>
                            <% } %>
                            <div class="sig-error" id="post-sig-error" style="display:none"></div>
                        </div>
                    </div>
                </div>
                
                <div class="form-actions">
                    <% const currentStatus = status ? status.status : null; %>

                    <% if (currentStatus === 'Approved' || currentStatus === 'Archived') { %>
                        <!-- Fully approved / archived: read-only -->
                        <button type="button" class="btn-save" onclick="window.location.href='<%= backToOverviewLink %>'">BACK TO DASHBOARD</button>
                        <button type="button" class="btn-pdf" onclick="viewTLAForm()">VIEW PDF</button>
                        <button type="button" class="btn-pdf" onclick="printTLAForm()">DOWNLOAD AS PDF</button>

                    <% } else if (postUnlocked && tla && tla.userID && tla.userID.toString() === user.id) { %>
                        <!-- Post-digital unlocked (Chair-Approved+): professor can fill post-digital -->
                        <button type="button" class="btn-save" onclick="window.location.href='<%= backToOverviewLink %>'">BACK TO DASHBOARD</button>
                        <button type="button" class="btn-pdf" onclick="printTLAForm()">DOWNLOAD AS PDF</button>
                        <button type="submit" name="action" value="submit-post" class="btn-submit">SUBMIT POST-DIGITAL</button>

                    <% } else if (['Pending','Chair-Approved','Dean-Approved','HR-Approved'].includes(currentStatus)) { %>
                        <!-- In approval chain: waiting for review, no edits -->
                        <button type="button" class="btn-save" onclick="window.location.href='<%= backToOverviewLink %>'">BACK TO DASHBOARD</button>
                        <button type="button" class="btn-pdf" onclick="printTLAForm()">DOWNLOAD AS PDF</button>

                    <% } else { %>
                        <!-- Draft / Returned / Not Submitted / new: normal edit -->
                        <button type="submit" name="action" value="draft" class="btn-save">SAVE AS DRAFT</button>
                        <button type="button" class="btn-pdf" onclick="viewTLAForm()">VIEW PDF</button>
                        <button type="button" class="btn-pdf" onclick="printTLAForm()">DOWNLOAD AS PDF</button>
                        <button type="submit" name="action" value="submit" class="btn-submit">SUBMIT</button>
                    <% } %>
                </div>
            </form>
        </div>
    </main>

    <script src="/TLA/js/tlaForm.js"></script>
</body>
</html>
