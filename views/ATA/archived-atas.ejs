<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mapúa MCM - Archived ATAs</title>
    <link rel="icon" type="image/x-icon" href="/common/img/chalkboardLogo.ico">
    <link rel="stylesheet" href="/ATA/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* ── Base Layout ──────────────────────────────── */
        body.dashboard-bg {
            display: block !important;
            padding: 0 !important;
        }
        .main-content {
            padding: 20px !important; 
            height: 100vh;
            box-sizing: border-box;
            overflow: hidden; 
            position: relative;
            z-index: 2;
        }
        .archive-container {
            height: 100%; 
            width: 100%;  
            display: flex;
            flex-direction: column;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.6);
            box-sizing: border-box;
        }
        .inner-title {
            font-size: 28px;
            font-weight: 700;
            color: #fff;
            margin: 0 0 15px 0;
            padding-bottom: 10px;
            border-bottom: 2px solid #444;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        /* ── Filter Bar ──────────────────────────────── */
        .filter-bar {
            display: flex;
            gap: 12px;
            align-items: center;
            flex-wrap: wrap;
            margin-bottom: 20px;
            flex-shrink: 0;
        }
        .filter-bar input,
        .filter-bar select {
            background: #2b2b2b;
            color: #fff;
            border: 1px solid #444;
            border-radius: 5px;
            padding: 9px 13px;
            font-size: 0.88rem;
            outline: none;
            transition: border-color 0.2s;
        }
        .filter-bar input:focus, .filter-bar select:focus { border-color: #17a2b8; }

        /* ── Accordion Folders ───────────────────────── */
        .scrollable-folders {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding-right: 10px;
        }
        .program-folder {
            margin-bottom: 15px;
            background: #222;
            border: 1px solid #444;
            border-radius: 8px;
            overflow: hidden;
            transition: border-color 0.3s;
        }
        .program-folder:hover {
            border-color: #17a2b8;
        }
        .folder-header {
            padding: 15px 20px;
            background: #2a2a2a;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            user-select: none;
            transition: background 0.3s;
        }
        .folder-header:hover { background: #333; }
        
        .folder-title {
            font-size: 1.2rem;
            font-weight: 600;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .folder-badge {
            background: #17a2b8;
            color: #fff;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: bold;
        }
        
        .folder-body {
            display: none; 
            padding: 0;
            border-top: 1px solid #444;
            background: #1a1a1a;
        }
        .folder-body.open {
            display: block; 
        }

        /* ── Inner Table ─────────────────────────────── */
        .archive-table {
            width: 100%;
            border-collapse: collapse;
            color: #ddd;
        }
        .archive-table th {
            padding: 12px 20px;
            text-align: left;
            color: #888;
            font-weight: 600;
            font-size: 0.85rem;
            background: #222;
            text-transform: uppercase;
        }
        .archive-table td {
            padding: 15px 20px;
            border-bottom: 1px solid #333;
            vertical-align: middle;
        }
        .archive-table tr:last-child td { border-bottom: none; }
        .archive-table tbody tr:hover { background: rgba(255,255,255,0.03); }

        /* ── Buttons ─────────────────────────────────── */
        .btn-action {
            padding: 8px 15px;
            border-radius: 5px;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
            color: #fff;
            border: none;
            transition: background 0.2s;
            font-family: inherit;
        }
        .btn-view { background: #17a2b8; }
        .btn-view:hover { background: #138496; }
        .btn-download { background: #28a745; }
        .btn-download:hover { background: #218838; }
        
        .bottom-actions {
            flex-shrink: 0; 
            padding-top: 15px;
            margin-top: 15px;
            border-top: 2px solid #444;
            display: flex;
            gap: 15px;
        }
    </style>
</head>

<body class="dashboard-bg" 
      data-role="<%= typeof role !== 'undefined' ? role : 'Admin' %>"
      data-employment="<%= (typeof user !== 'undefined' && user.employmentType) ? user.employmentType : 'Full-Time' %>"
      data-practicum="<%= (typeof user !== 'undefined' && user.isPracticumCoordinator) ? 'true' : 'false' %>"
      data-user-sig="<%= (typeof user !== 'undefined' && user.signatureImage) ? user.signatureImage : '' %>">

    <% 
        if (typeof role !== 'undefined') {
            if (['Admin', 'VPAA', 'HR', 'HRMO'].includes(role)) { %>
                <%- include('../MainPages/admin/partials/adminSideMenuBar') %>
            <% } else if (role === 'Dean') { %>
                <%- include('../MainPages/dean/partials/deanMenuBar') %>
            <% } else if (role === 'Program-Chair') { %>
                <%- include('../MainPages/progChair/partials/progChairMenuBar') %>
            <% } else { %>
                <%- include('../partials/sideMenuBar') %>
            <% } 
        } else { %>
            <%- include('../partials/sideMenuBar') %>
        <% }
    %>

    <main class="main-content" style="margin-left: 260px; width: calc(100vw - 260px);">

        <div class="archive-container">
            
            <div class="inner-title">
                <div>
                    <i class="fas fa-box-archive" style="color: #17a2b8;"></i> HR Archived ATAs
                </div>
                <div style="font-size: 1rem; color: #aaa; font-weight: normal;">
                    Total Records: <span id="totalCountBadge" style="color: #17a2b8; font-weight: bold;"><%= totalCount %></span>
                </div>
            </div>

            <div class="filter-bar">
                <input type="text" id="searchInput" placeholder="🔍 Search faculty name..." oninput="applyFilters()">
                
                <select id="yearFilter" onchange="applyFilters()">
                    <option value="">All Academic Years</option>
                    <option value="2025-2026">2025–2026</option>
                    <option value="2024-2025">2024–2025</option>
                </select>

                <select id="termFilter" onchange="applyFilters()">
                    <option value="">All Terms</option>
                    <option value="1st Term">1st Term</option>
                    <option value="2nd Term">2nd Term</option>
                    <option value="Summer">Summer</option>
                </select>
            </div>

            <div class="scrollable-folders" id="accordionContainer">
                </div>

            <div class="bottom-actions">
                <a href="/admin/ata" class="form-btn secondary-btn" style="text-decoration: none;">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>

        </div>

    </main>

    <script src="/ATA/js/ata_client.js"></script>
    <script>
    window.__FORMS__ = <%- JSON.stringify(forms) %>;

    function toggleFolder(folderId) {
        const body = document.getElementById(folderId);
        const icon = document.getElementById('icon-' + folderId);
        
        if (body.classList.contains('open')) {
            body.classList.remove('open');
            icon.classList.replace('fa-folder-open', 'fa-folder');
        } else {
            body.classList.add('open');
            icon.classList.replace('fa-folder', 'fa-folder-open');
        }
    }

    function renderAccordion(formsToRender) {
        const container = document.getElementById('accordionContainer');
        container.innerHTML = '';

        if (formsToRender.length === 0) {
            container.innerHTML = `
                <div style="text-align: center; padding: 50px; color: #777;">
                    <i class="fas fa-box-open" style="font-size: 3rem; margin-bottom: 15px;"></i>
                    <p>No archived records match your search.</p>
                </div>
            `;
            return;
        }

        const groupedData = {};
        formsToRender.forEach(form => {
            const groupName = form.program ? form.program : (form.college ? form.college : "Uncategorized");
            if (!groupedData[groupName]) {
                groupedData[groupName] = [];
            }
            groupedData[groupName].push(form);
        });

        Object.keys(groupedData).sort().forEach((groupName, index) => {
            const formsInGroup = groupedData[groupName];
            const folderId = `folder-${index}`;

            const rowsHtml = formsInGroup.map(form => {
                const dateArchived = new Date(form.archivedAt || form.updatedAt).toLocaleDateString();
                const safeName = (form.facultyName || "Faculty").replace(/\s+/g, '_');
                
                return `
                    <tr>
                        <td style="font-weight: bold; color: #fff; font-size: 1.05rem;">${form.facultyName}</td>
                        <td>${form.term} <span style="color:#aaa; font-size: 0.85rem;">(${form.academicYear})</span></td>
                        <td style="color: #aaa;">${dateArchived}</td>
                        <td>
                            <div style="display: flex; gap: 8px;">
                                <a href="/ata/view-submission/${form._id}" class="btn-action btn-view">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                
                                <button data-form-id="${form._id}" data-safe-name="${safeName}" class="btn-action btn-download smart-download-btn">
                                    <i class="fas fa-download"></i> <span>Download</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');

            const folderHtml = `
                <div class="program-folder">
                    <div class="folder-header" onclick="toggleFolder('${folderId}')">
                        <div class="folder-title">
                            <i id="icon-${folderId}" class="fas fa-folder" style="color: #17a2b8;"></i> 
                            ${groupName}
                        </div>
                        <div class="folder-badge">${formsInGroup.length} Records</div>
                    </div>
                    <div id="${folderId}" class="folder-body">
                        <table class="archive-table">
                            <thead>
                                <tr>
                                    <th style="width: 35%">Faculty Name</th>
                                    <th style="width: 25%">Term & Year</th>
                                    <th style="width: 20%">Date Archived</th>
                                    <th style="width: 20%">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${rowsHtml}
                            </tbody>
                        </table>
                    </div>
                </div>
            `;
            container.innerHTML += folderHtml;
        });
    }

    function applyFilters() {
        const search = document.getElementById('searchInput').value.toLowerCase().trim();
        const year = document.getElementById('yearFilter').value;
        const term = document.getElementById('termFilter').value;

        const filtered = window.__FORMS__.filter(f => {
            const nameMatch = !search || (f.facultyName || '').toLowerCase().includes(search);
            const yearMatch = !year   || f.academicYear === year;
            const termMatch = !term   || (f.term || '').includes(term);
            return nameMatch && yearMatch && termMatch;
        });

        document.getElementById('totalCountBadge').innerText = filtered.length;
        renderAccordion(filtered);
    }

    document.addEventListener('DOMContentLoaded', () => {
        renderAccordion(window.__FORMS__);
    });

    // 👇 EVENT DELEGATION: Listens for clicks on ANY smart-download-btn, even newly generated ones!
    document.addEventListener('click', async (e) => {
        const btn = e.target.closest('.smart-download-btn');
        if (!btn) return; // If they clicked something else, ignore it.

        const icon = btn.querySelector('i');
        const text = btn.querySelector('span');
        const formId = btn.getAttribute('data-form-id');
        const safeName = btn.getAttribute('data-safe-name');

        // 1. Turn on Loading State
        btn.disabled = true;
        btn.style.opacity = '0.7';
        btn.style.cursor = 'not-allowed';
        icon.className = 'fas fa-spinner fa-spin';
        text.innerText = 'Wait...';

        try {
            // 2. Fetch the PDF in the background
            const response = await fetch(`/ata/pdf/${formId}`);
            if (!response.ok) throw new Error('Download failed');
            
            // 3. Force browser to save the blob
            const blob = await response.blob();
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.style.display = 'none';
            a.href = url;
            a.download = `ATA_${safeName}.pdf`;
            document.body.appendChild(a);
            a.click();
            
            // Clean up memory
            window.URL.revokeObjectURL(url);
            a.remove();
        } catch (error) {
            console.error("Error downloading PDF:", error);
            alert("Failed to download PDF. Please check your connection and try again.");
        } finally {
            // 4. Turn off Loading State
            btn.disabled = false;
            btn.style.opacity = '1';
            btn.style.cursor = 'pointer';
            icon.className = 'fas fa-download';
            text.innerText = 'Download';
        }
    });
    </script>
</body>
</html>

