<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mapúa MCM - New ATA Form</title>
    <link rel="stylesheet" href="/ATA/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Fix native dropdown menu colors for dark theme */
        select.form-input option, select.table-input option {
            background-color: #2b2b2b; /* Dark gray background */
            color: #ffffff; /* Crisp white text */
            padding: 5px;
        }
        
        select.form-input optgroup {
            background-color: #1a1a1a; /* Darker background for group headers */
            color: #a0a0a0; /* Light gray for the category name */
            font-weight: bold;
        }

        /* Make disabled options (like Other Colleges) grayed out */
        select.form-input option:disabled, select.table-input option:disabled {
            color: #666666; /* Faded dark gray */
            font-style: italic;
        }

        /* Table Dropdown UI Fix */
        select.table-input {
            background-color: rgba(255,255,255,0.1); 
            color: white; 
            border: 1px solid rgba(255,255,255,0.2); 
            border-radius: 4px;
            padding: 6px;
            width: 100%;
            cursor: pointer;
        }

        /* Gives the bottom of the form space so menus open downwards */
        .ata-form {
            padding-bottom: 150px; 
        }
    </style>
</head>
<body data-role="<%= typeof role !== 'undefined' ? role : '' %>" 
      data-employment="<%= typeof employmentType !== 'undefined' ? employmentType : '' %>"
      data-practicum="<%= typeof isPracticumCoordinator !== 'undefined' ? isPracticumCoordinator : 'false' %>">

    <%- include('../partials/sideMenuBar') %>

    <main class="form-bg-fixed" id="multiStepSection" style="margin-left: 260px; width: calc(100vw - 260px); position: relative; display: flex; flex-direction: column;">

        <div class="form-title-box" id="formTitle">
            <h1>ATA form: Personal Details</h1>
        </div>

        <div class="progress-container">
            <div class="progress-steps">
                <span class="progress-dot filled" id="step1Dot" data-label="Personal Details">●</span>
                <span class="progress-dot" id="step2Dot" data-label="Teaching Load">○</span>
                <span class="progress-dot" id="step3Dot" data-label="Admin & Practicum">○</span>
                <span class="progress-dot" id="step4Dot" data-label="Outside Employment">○</span>
                <span class="progress-dot" id="step5Dot" data-label="Remedial Modules">○</span>
                <span class="progress-dot" id="step6Dot" data-label="Review">○</span>
                <span class="progress-dot" id="step7Dot" data-label="Approval">○</span>
            </div>
        </div>

        <div class="form-cards-container" style="flex: 1;">
            
            <div class="form-card-scrollable" id="form1">
                <div class="ata-form">
                    
                    <div class="form-row">
                        <div class="form-label">NAME:</div>
                        <div class="form-field">
                            <input type="text" class="form-input" id="facultyName" value="<%= user.name %>">
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-label">POSITION:</div>
                        <div class="form-field">
                            <select class="form-input" id="position" style="background-color: rgba(255,255,255,0.1); color: white;">
                                <option value="" disabled <%= !role ? 'selected' : '' %>>Select your position</option>
                                <option value="Professor" <%= role === 'Professor' ? 'selected' : '' %>>Professor</option>
                                <option value="Assistant Professor" <%= role === 'Assistant Professor' ? 'selected' : '' %>>Assistant Professor</option>
                                <option value="Associate Professor" <%= role === 'Associate Professor' ? 'selected' : '' %>>Associate Professor</option>
                                <option value="Program-Chair" <%= role === 'Program-Chair' ? 'selected' : '' %>>Program Chair</option>
                                <option value="Dean" <%= role === 'Dean' ? 'selected' : '' %>>Dean</option>
                                <option value="Practicum-Coordinator" <%= role === 'Practicum-Coordinator' ? 'selected' : '' %>>Practicum Coordinator</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-label">COLLEGE/PROGRAM:</div>
                        <div class="form-field">
                            <select class="form-input" id="college" style="background-color: rgba(255,255,255,0.1); color: white;">
                                <option value="" disabled <%= !user.program && role !== 'Dean' ? 'selected' : '' %>>Select your College or Program</option>
                                
                                <option value="CEA" <%= role === 'Dean' || user.program === 'CEA' ? 'selected' : '' %>>College of Engineering & Architecture (CEA)</option>
                                
                                <optgroup label="College of Engineering & Architecture (CEA)">
                                    <option value="CpE" <%= user.program === 'CpE' ? 'selected' : '' %>>Computer Engineering (CpE)</option>
                                    <option value="CE" <%= user.program === 'CE' ? 'selected' : '' %>>Civil Engineering (CE)</option>
                                    <option value="EE" <%= user.program === 'EE' ? 'selected' : '' %>>Electrical Engineering (EE)</option>
                                    <option value="ECE" <%= user.program === 'ECE' ? 'selected' : '' %>>Electronics Engineering (ECE)</option>
                                    <option value="IE" <%= user.program === 'IE' ? 'selected' : '' %>>Industrial Engineering (IE)</option> 
                                    <option value="ME" <%= user.program === 'ME' ? 'selected' : '' %>>Mechanical Engineering (ME)</option>
                                    <option value="AR" <%= user.program === 'AR' ? 'selected' : '' %>>Architecture (AR)</option>
                                </optgroup>
                                <optgroup label="Other Colleges">
                                    <option value="CCIS" disabled>College of Computing and Information Sciences (CCIS)</option>
                                    <option value="CAS" disabled>College of Arts and Sciences (CAS)</option>
                                    <option value="ETYCB" disabled>E.T. Yuchengco College of Business (ETYCB)</option>
                                    <option value="CHS" disabled>College of Health Sciences (CHS)</option>
                                </optgroup>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-label">EMPLOYMENT STATUS:</div>
                        <div class="form-field">
                            <select class="form-input" id="employmentStatus" style="background-color: rgba(255,255,255,0.1); color: white;">
                                <option value="" disabled selected>Select Status...</option>
                                <option value="Regular">Regular</option>
                                <option value="Probationary">Probationary</option>
                                <option value="Fixed-Term">Fixed-Term</option>
                                <option value="Contractual">Contractual</option>
                                <option value="Guest Lecturer">Guest Lecturer</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-label">EMPLOYMENT TYPE:</div>
                        <div class="form-field radio-group">
                            <label class="radio-label">
                                <input type="radio" name="employment" value="Full-Time" id="radioFullTime"> FULL TIME
                            </label>
                            <label class="radio-label">
                                <input type="radio" name="employment" value="Part-Time" id="radioPartTime"> PART TIME
                            </label>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-label">ADDRESS:</div>
                        <div class="form-field">
                            <input type="text" class="form-input" placeholder="" id="address">
                        </div>
                    </div>

                    <div id="sectionA_Container">
                        <div class="form-section-divider">
                            (A) TOTAL TEACHING UNITS SERVED FOR A.Y.<br>
                            <span class="sub-text">(For Admin and Faculty with Admin Only)</span>
                        </div>

                        <div class="form-row units-row">
                            <div class="form-label"></div>
                            <div class="form-field units-field">
                                <input type="number" class="form-input units-input" placeholder="Enter total units..." id="teachingUnits1">
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="form-card-scrollable" id="form2" style="display: none;">
                <div class="ata-form">
                    
                    <div class="form-section-header">
                        (B) COURSES WITHIN ASSIGNED COLLEGE
                    </div>

                    <div class="table-header">
                        <div class="table-col">Course</div>
                        <div class="table-col">Section</div>
                        <div class="table-col">Units</div>
                        <div class="table-col">Effective Date</div>
                        <div class="table-col">Actions</div>
                    </div>

                    <div class="course-row">
                        <div class="table-col"><input type="text" class="table-input" placeholder="Course code"></div>
                        <div class="table-col"><input type="text" class="table-input" placeholder="Section"></div>
                        <div class="table-col">
                            <select class="table-input" required>
                                <option value="" disabled selected>Units</option>
                                <option value="1">1</option>
                                <option value="2">2</option>
                                <option value="3">3</option>
                                <option value="4">4</option>
                                <option value="5">5</option>
                                <option value="6">6</option>
                            </select>
                        </div>
                        <div class="table-col">
                            <div class="date-input-group">
                                <input type="text" class="table-input date-input" placeholder="DD/MM/YYYY">
                            </div>
                        </div>
                        <div class="table-col action-col">
                            <button class="action-btn remove-btn"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>

                    <div class="course-row">
                        <div class="table-col"><input type="text" class="table-input" placeholder="Course code"></div>
                        <div class="table-col"><input type="text" class="table-input" placeholder="Section"></div>
                        <div class="table-col">
                            <select class="table-input" required>
                                <option value="" disabled selected>Units</option>
                                <option value="1">1</option>
                                <option value="2">2</option>
                                <option value="3">3</option>
                                <option value="4">4</option>
                                <option value="5">5</option>
                                <option value="6">6</option>
                            </select>
                        </div>
                        <div class="table-col">
                            <div class="date-input-group">
                                <input type="text" class="table-input date-input" placeholder="DD/MM/YYYY">
                            </div>
                        </div>
                        <div class="table-col action-col">
                            <button class="action-btn remove-btn"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>

                    <div class="add-course-btn">
                        <button class="secondary-btn small-btn">+ Add Course</button>
                    </div>

                    <div class="total-units-row">
                        <span class="total-label">Total Units (B):</span>
                        <span class="total-value">0</span>
                    </div>

                    <div class="form-divider"></div>

                    <div class="form-section-header">
                        (C) COURSES FROM OTHER COLLEGE
                    </div>

                    <div class="table-header">
                        <div class="table-col">Course</div>
                        <div class="table-col">Section</div>
                        <div class="table-col">Units</div>
                        <div class="table-col">Effective Date</div>
                        <div class="table-col">Dean Sig.</div>
                    </div>

                    <div class="course-row">
                        <div class="table-col"><input type="text" class="table-input" placeholder="Course code"></div>
                        <div class="table-col"><input type="text" class="table-input" placeholder="Section"></div>
                        <div class="table-col">
                            <select class="table-input" required>
                                <option value="" disabled selected>Units</option>
                                <option value="1">1</option>
                                <option value="2">2</option>
                                <option value="3">3</option>
                                <option value="4">4</option>
                                <option value="5">5</option>
                                <option value="6">6</option>
                            </select>
                        </div>
                        <div class="table-col">
                            <div class="date-input-group">
                                <input type="text" class="table-input date-input" placeholder="DD/MM/YYYY">
                            </div>
                        </div>
                        <div class="table-col">
                            <span class="pending-badge">Pending</span>
                        </div>
                    </div>

                    <div class="add-course-btn">
                        <button class="secondary-btn small-btn">+ Add Course</button>
                    </div>

                    <div class="total-units-row">
                        <span class="total-label">Total Units (C):</span>
                        <span class="total-value">0</span>
                    </div>

                </div>
            </div>

            <div class="form-card-scrollable" id="form3" style="display: none;">
                <div class="ata-form">
                    
                    <div id="sectionD_Container">
                        <div class="form-section-header">
                            (D) ADMINISTRATIVE/ RESEARCH WORK
                        </div>

                        <div class="admin-header">
                            <div class="admin-col work-desc">Work Description</div>
                            <div class="admin-col units">Units</div>
                            <div class="admin-col date">Effective Date</div>
                            <div class="admin-col actions">Actions</div>
                        </div>

                        <div class="admin-row">
                            <div class="admin-col work-desc">
                                <input type="text" class="table-input" placeholder="Work description">
                            </div>
                            <div class="admin-col units">
                                <select class="table-input" required>
                                    <option value="" disabled selected>Units</option>
                                    <option value="1">1</option>
                                    <option value="2">2</option>
                                    <option value="3">3</option>
                                    <option value="4">4</option>
                                    <option value="5">5</option>
                                    <option value="6">6</option>
                                </select>
                            </div>
                            <div class="admin-col date">
                                <div class="date-input-group">
                                    <input type="text" class="table-input date-input" placeholder="DD/MM/YYYY">
                                </div>
                            </div>
                            <div class="admin-col actions">
                                <button class="action-btn remove-btn"><i class="fas fa-trash"></i></button>
                            </div>
                        </div>

                        <div class="add-course-btn">
                            <button class="secondary-btn small-btn">+ Add Work</button>
                        </div>

                        <div class="total-units-row">
                            <span class="total-label">Total Units (D):</span>
                            <span class="total-value">0</span>
                        </div>

                        <div class="form-divider"></div>
                    </div>
                    
                    <div class="form-section-header">
                        (E) PRACTICUM ADVISING
                    </div>

                    <div class="practicum-header">
                        <div class="practicum-col">Course Code</div>
                        <div class="practicum-col">No. of Students</div>
                        <div class="practicum-col">Coordinator</div>
                        <div class="practicum-col">Actions</div>
                    </div>

                    <div class="practicum-row">
                        <div class="practicum-col">
                            <input type="text" class="table-input" placeholder="Course code">
                        </div>
                        <div class="practicum-col">
                            <input type="text" class="table-input" placeholder="#">
                        </div>
                        <div class="practicum-col">
                            <select class="table-input" required>
                                <option value="" disabled selected>Select Coordinator</option>
                                
                                <% if (typeof coordinators !== 'undefined' && coordinators.length > 0) { %>
                                    <% coordinators.forEach(function(name) { %>
                                        <option value="<%= name %>"><%= name %></option>
                                    <% }); %>
                                <% } else { %>
                                    <option value="" disabled>No Coordinators Found</option>
                                <% } %>

                            </select>
                        </div>
                        <div class="practicum-col action-col">
                            <button class="action-btn remove-btn"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>

                    <div class="add-course-btn">
                        <button class="secondary-btn small-btn">+ Add Practicum</button>
                    </div>

                </div>
            </div>

            <div class="form-card-scrollable" id="form4" style="display: none;">
                <div class="ata-form">
                    
                    <div class="form-section-header">
                        (F) EMPLOYMENT OUTSIDE MAPUA MCM
                    </div>

                    <div class="form-subtitle">
                        (Part-Time Only)
                    </div>

                    <div class="employment-header">
                        <div class="employment-col employer">Employer University</div>
                        <div class="employment-col position">Position/Status</div>
                        <div class="employment-col course">Course/Units</div>
                        <div class="employment-col hours">Hrs/Wk</div>
                        <div class="employment-col actions">Actions</div>
                    </div>

                    <div class="employment-row">
                        <div class="employment-col employer">
                            <input type="text" class="table-input" placeholder="University name">
                        </div>
                        <div class="employment-col position">
                            <input type="text" class="table-input" placeholder="Position">
                        </div>
                        <div class="employment-col course">
                            <input type="text" class="table-input" placeholder="Course/Units">
                        </div>
                        <div class="employment-col hours">
                            <input type="text" class="table-input" placeholder="Hours">
                        </div>
                        <div class="employment-col actions">
                            <button class="action-btn remove-btn"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>

                    <div class="add-course-btn">
                        <button class="secondary-btn small-btn">+ Add Employment</button>
                    </div>

                </div>
            </div>

            <div class="form-card-scrollable" id="form5" style="display: none;">
                <div class="ata-form">
                    
                    <div class="form-section-header">
                        (G) REMEDIAL MODULE TEACHING ASSIGNMENT
                    </div>

                    <div class="remedial-header">
                        <div class="remedial-col">Course ID</div>
                        <div class="remedial-col">Module Code</div>
                        <div class="remedial-col">Section</div>
                        <div class="remedial-col">Units</div>
                        <div class="remedial-col">Students</div>
                        <div class="remedial-col">Actions</div>
                    </div>

                    <div class="remedial-row">
                        <div class="remedial-col">
                            <input type="text" class="table-input" placeholder="Course ID">
                        </div>
                        <div class="remedial-col">
                            <input type="text" class="table-input" placeholder="Module Code">
                        </div>
                        <div class="remedial-col">
                            <input type="text" class="table-input" placeholder="Section">
                        </div>
                        <div class="remedial-col">
                            <select class="table-input" required>
                                <option value="" disabled selected>Units</option>
                                <option value="1">1</option>
                                <option value="2">2</option>
                                <option value="3">3</option>
                                <option value="4">4</option>
                                <option value="5">5</option>
                                <option value="6">6</option>
                            </select>
                        </div>
                        <div class="remedial-col">
                            <input type="text" class="table-input" placeholder="#">
                        </div>
                        <div class="remedial-col">
                            <select class="table-input type-select" required>
                                <option value="" disabled selected>Type...</option>
                                <option value="lecture">Lecture</option>
                                <option value="lab">Lab</option>
                            </select>
                        </div>
                        <div class="remedial-col action-col">
                            <button class="action-btn remove-btn"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>

                    <div class="add-course-btn">
                        <button class="secondary-btn small-btn">+ Add Module</button>
                    </div>

                    <div class="remedial-note">
                        Note: Remedial units are not included in bonus/summer pay
                    </div>
                    <div id="remedialErrorDiv" style="color: #dc3545; font-weight: bold; margin-top: 15px; padding: 10px; border: 1px solid #dc3545; border-radius: 5px; background: rgba(220, 53, 69, 0.1); display: none;">
                        <i class="fas fa-exclamation-triangle"></i> ERROR: Maximum limit of 6 effective units exceeded. Please reduce your remedial load.
                    </div>

                </div>
            </div>

            <div class="form-card-scrollable" id="form6" style="display: none;">
                <div class="ata-form review-form">
                    
                    <div class="review-title">REVIEW & SUBMIT</div>

                    <div class="summary-table">
                        <div class="summary-header">
                            <div class="summary-col section">SECTION</div>
                            <div class="summary-col units">UNITS</div>
                            <div class="summary-col effective">EFFECTIVE UNITS</div>
                        </div>

                        <div class="summary-row" id="sumRowA" style="display: none;">
                            <div class="summary-col section">(A) Admin Served Units</div>
                            <div class="summary-col units">0</div>
                            <div class="summary-col effective">N/A</div>
                        </div>

                        <div class="summary-row">
                            <div class="summary-col section">(B) Courses Within College</div>
                            <div class="summary-col units" id="sumUnitsB">0</div>
                            <div class="summary-col effective" id="sumEffB">0</div>
                        </div>

                        <div class="summary-row">
                            <div class="summary-col section">(C) Courses Other Colleges</div>
                            <div class="summary-col units" id="sumUnitsC">0</div>
                            <div class="summary-col effective" id="sumEffC">0</div>
                        </div>

                        <div class="summary-row" id="sumRowD" style="display: none;">
                            <div class="summary-col section">(D) Administrative Work</div>
                            <div class="summary-col units" id="sumUnitsD">0</div>
                            <div class="summary-col effective" id="sumEffD">0</div>
                        </div>

                        <div class="summary-total">
                            <div class="summary-col section">TOTAL REGULAR LOAD</div>
                            <div class="summary-col units" id="grandTotalUnits">0</div>
                            <div class="summary-col effective" id="grandTotalEff">0</div>
                        </div>

                        <div class="summary-row" style="border-top: 2px solid #444; margin-top: 10px; padding-top: 10px;">
                            <div class="summary-col section">(G) Remedial Modules</div>
                            <div class="summary-col units" id="sumUnitsG">0</div>
                            <div class="summary-col effective" id="sumEffG">0</div>
                        </div>
                    </div>
                    <div class="pdf-preview-row" style="display: flex; justify-content: center; margin-top: 20px; margin-bottom: 20px;">
                        <button type="button" id="previewPdfBtn" class="form-btn secondary-btn" style="background-color: #17a2b8; color: white; display: flex; align-items: center; gap: 8px; padding: 10px 20px;">
                            <i class="fas fa-file-pdf"></i> View Form (PDF Preview)
                        </button>
                    </div>

                    <div class="acceptance-row">
                        <input type="checkbox" id="acceptCheckbox" class="acceptance-checkbox">
                        <label for="acceptCheckbox" class="acceptance-label">
                            I hereby accept the above teaching assignment/s.
                        </label>
                    </div>

                    <div class="signature-row">
                        <div class="signature-label">SIGNATURE OF FACULTY:</div>
                        <div class="signature-field">
                            <button class="upload-btn">Upload File</button>
                        </div>
                    </div>

                    <div class="signature-row">
                        <div class="signature-label">DATE:</div>
                        <div class="signature-field">
                            <div class="date-input-group">
                                <input type="text" class="table-input date-input" placeholder="DD/MM/YYYY">
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="form-card-scrollable" id="form7" style="display: none;">
                <div class="ata-form admin-form">
                    
                    <div class="form-section-header">
                        (H) RECOMMENDING APPROVAL
                    </div>

                    <div class="justification-row">
                        <div class="justification-label">Justification for overload (if applicable):</div>
                        <div class="justification-field">
                            <textarea class="form-input justification-input" id="justificationText" name="justification" rows="3" placeholder="Enter justification..."></textarea>
                        </div>
                    </div>

                    <div class="admin-signature-row">
                        <div class="admin-signature-label">
                            <% if (role === 'Dean') { %>
                                SIGNATURE OF DEAN:
                            <% } else { %>
                                SIGNATURE OF PROGRAM CHAIR:
                            <% } %>
                        </div>
                        <div class="admin-signature-field">
                            <button class="upload-btn">Upload File</button>
                        </div>
                    </div>

                    <div class="admin-signature-row">
                        <div class="admin-signature-label">DATE:</div>
                        <div class="admin-signature-field">
                            <div class="date-input-group">
                                <input type="text" class="table-input date-input" placeholder="DD/MM/YYYY">
                            </div>
                        </div>
                    </div>

                    <div class="form-divider-light"></div>
                </div>
            </div>

        </div>

        <div class="form-navigation-outside">
            <button class="form-btn secondary-btn" id="backBtn">Return to Dashboard</button>
            <button class="form-btn primary-btn" id="nextBtn">Next</button>
        </div>

    </main>

    <script src="/ATA/js/ata_client.js"></script>

</body>
</html>