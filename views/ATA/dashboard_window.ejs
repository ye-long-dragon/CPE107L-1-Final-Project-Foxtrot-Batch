<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chalkboard | TLA </title>
    <link rel="icon" type="image/x-icon" href="/common/img/chalkboardLogo.ico">
    <link rel="stylesheet" href="/ATA/css/style.css">
    <link rel="stylesheet" href="/common/css/variables.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body data-role="<%= typeof role !== 'undefined' ? role : (typeof user !== 'undefined' && user.role ? user.role : 'Professor') %>" 
      data-employment="<%= (typeof user !== 'undefined' && user.employmentType) ? user.employmentType : 'Full-Time' %>"
      data-practicum="<%= (typeof user !== 'undefined' && user.isPracticumCoordinator) ? 'true' : 'false' %>">
    
    <% 
        if (typeof role !== 'undefined') {
            if (['Admin', 'VPAA', 'HR', 'HRMO'].includes(role)) { %>
                <%- include('../MainPages/admin/partials/adminSideMenuBar') %>
            <% } else if (role === 'Dean') { %>
                <%- include('../MainPages/dean/partials/deanMenuBar') %>
            <% } else if (role === 'Program-Chair') { %>
                <%- include('../MainPages/progChair/partials/progChairMenuBar') %>
            <% } else { %>
                <%- include('../partials/sideMenuBar') %>
            <% } 
        } else { %>
            <%- include('../partials/sideMenuBar') %>
        <% }
    %>
    
    <main class="dashboard-bg" style="margin-left: 260px; width: calc(100vw - 260px); min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding-top: 6vh;">

        <div class="dashboard-title">ACCEPTANCE OF TEACHING ASSIGNMENT</div>

        <div class="welcome-box">
            <h2>
                Welcome, <%= typeof user !== 'undefined' ? user.name : 'Faculty' %> | <%= typeof role !== 'undefined' ? role : 'Professor' %>
                <% if (typeof role !== 'undefined' && role === 'Dean') { %>
                    | CEA
                <% } else if (typeof user !== 'undefined' && user.program) { %>
                    | <%= user.program %>
                <% } %>
            </h2>
        </div>

      <%
        const currentRole = typeof role !== 'undefined' ? role : 'Professor';
        const isExecutive = ['VPAA', 'HR', 'HRMO'].includes(currentRole);
        const isAdmin = ['Program-Chair', 'Dean', 'Admin', 'VPAA', 'HR', 'HRMO'].includes(currentRole);
        const canViewArchived = ['HR', 'HRMO'].includes(currentRole);
        const isPracCoord = typeof user !== 'undefined' && user.isPracticumCoordinator;
      %>

        <div class="action-cards">

            <% if (!isExecutive) { %>
                <a href="/ata/new" class="action-card-link-wrapper">
                    <div class="action-card">
                        <div class="action-card-title">Start New ATA Form</div>
                    </div>
                </a>

                <a href="/ata/submissions?filter=pending" class="action-card-link-wrapper">
                    <div class="action-card pending-card">
                        <div class="action-card-title">My Pending Forms (<span id="myPendingCount"><%= typeof myPendingCount !== 'undefined' ? myPendingCount : 0 %></span>)</div>
                        <div class="action-card-link">View My Forms →</div>
                    </div>
                </a>

                <a href="/ata/submissions?filter=approved" class="action-card-link-wrapper">
                    <div class="action-card approved-card">
                        <div class="action-card-title">My Approved Forms (<span id="myApprovedCount"><%= typeof myApprovedCount !== 'undefined' ? myApprovedCount : 0 %></span>)</div>
                        <div class="action-card-link">View My Forms →</div>
                    </div>
                </a>
            <% } %>

            <% if (['Program-Chair', 'Dean', 'Admin'].includes(currentRole)) { %>
                <a href="/admin/courses" id="adminCourseBtn" class="action-card-link-wrapper">
                    <div class="action-card" style="background-color: #721c24;">
                        <div class="action-card-title"><i class="fas fa-database"></i> Manage Courses</div>
                    </div>
                </a>
            <% } %>

            <% if (isAdmin || isPracCoord) { %>
                <a href="/ata/pending" id="ataInboxCard" class="action-card-link-wrapper">
                    <div class="action-card" style="background-color: #d39e00; color: #333;">
                        <div class="action-card-title"><i class="fas fa-inbox"></i> Forms to Approve</div>
                        <div class="action-card-link">Review Faculty Submissions →</div>
                    </div>
                </a>

                <a href="/ata/admin-history" id="adminHistoryCard" class="action-card-link-wrapper">
                    <div class="action-card" style="background-color: #28a745; color: white;">
                        <div class="action-card-title"><i class="fas fa-history"></i> Approved History</div>
                        <div class="action-card-link">View Processed Forms →</div>
                    </div>
                </a>
            <% } %>

            <% if (canViewArchived) { %>
                <a href="/ata/archived-atas" class="action-card-link-wrapper">
                    <div class="action-card" style="background-color: #17a2b8; color: white;">
                        <div class="action-card-title">
                            <i class="fas fa-box-archive"></i> Archived ATAs
                        </div>
                        <div class="action-card-link">View All Archived Records →</div>
                    </div>
                </a>
            <% } %>

        </div>

        <% if (!isExecutive) { %>
            <div class="info-box">
                <div class="info-row">
                    Last Submission: <strong><%= typeof lastSubmissionDate !== 'undefined' ? lastSubmissionDate : 'None' %></strong> | 
                    Status: <strong><%= typeof lastStatus !== 'undefined' ? lastStatus : 'None' %></strong>
                </div>
                <div class="info-row">
                    Total Units: <strong><%= typeof totalUnits !== 'undefined' ? totalUnits : 0 %></strong> | 
                    Effective Units: <strong><%= typeof effectiveUnits !== 'undefined' ? effectiveUnits : 0 %></strong>
                </div>
            </div>
        <% } %>
        
    </main>
    <script src="/ATA/js/ata_client.js"></script>
</body>
</html>