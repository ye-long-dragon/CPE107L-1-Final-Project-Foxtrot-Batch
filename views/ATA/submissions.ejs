<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mapúa MCM - My Submissions</title>
    <link rel="stylesheet" href="/ATA/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* 👇 MAXIMIZED LAYOUT - NO HORIZONTAL SCROLL */
        .main-content {
            padding: 10px !important; /* Maximizes background space */
            height: 100vh;
            box-sizing: border-box;
            overflow: hidden; 
        }
        .form-cards-container {
            height: 100%; 
            width: 100%;  
            max-width: 100% !important; 
            display: flex;
            flex-direction: column;
            background: rgba(0, 0, 0, 0.85); /* Slightly darker for readability */
            backdrop-filter: blur(10px);
            border-radius: 8px;
            padding: 20px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.6);
            box-sizing: border-box;
        }
        .inner-title {
            font-size: 28px;
            font-weight: 700;
            color: #fff;
            margin: 0 0 15px 0;
            padding-bottom: 10px;
            border-bottom: 2px solid #444;
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .table-wrapper {
            flex: 1; 
            overflow-y: auto; 
            overflow-x: hidden; /* STRICTLY PREVENTS HORIZONTAL SCROLL */
            border: 1px solid #444;
            border-radius: 6px;
            background: #1a1a1a;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            color: white;
            table-layout: fixed; /* Forces columns to obey width percentages */
        }
        th, td {
            word-wrap: break-word;
            overflow-wrap: break-word;
        }
        .bottom-actions {
            flex-shrink: 0; 
            padding-top: 15px;
            margin-top: 15px;
            border-top: 2px solid #444;
            display: flex;
            gap: 15px;
            align-items: center;
        }
    </style>
</head>
<body class="dashboard-bg">
    
    <% 
        if (typeof role !== 'undefined') {
            if (['Admin', 'VPAA', 'HR', 'HRMO'].includes(role)) { %>
                <%- include('../MainPages/admin/partials/adminSideMenuBar') %>
            <% } else if (role === 'Dean') { %>
                <%- include('../MainPages/dean/partials/deanMenuBar') %>
            <% } else if (role === 'Program-Chair') { %>
                <%- include('../MainPages/progChair/partials/progChairMenuBar') %>
            <% } else { %>
                <%- include('../partials/sideMenuBar') %>
            <% } 
        } else { %>
            <%- include('../partials/sideMenuBar') %>
        <% }
    %>

    <main class="main-content" style="margin-left: 260px; width: calc(100vw - 260px);">
        
        <div class="form-cards-container">
            
            <div class="inner-title">
                <% if (filterType === 'approved') { %>
                    <i class="fas fa-check-circle" style="color: #28a745;"></i> My Approved Forms
                <% } else if (filterType === 'pending') { %>
                    <i class="fas fa-clock" style="color: #ffaa4a;"></i> My Pending Forms
                <% } else { %>
                    <i class="fas fa-folder" style="color: #4a9eff;"></i> My Form Submissions
                <% } %>
            </div>
            
            <div class="table-wrapper">
                <table>
                    <thead style="border-bottom: 2px solid #555; background: #333; position: sticky; top: 0; z-index: 10;">
                        <tr>
                            <th style="padding: 12px 10px; width: 12%;">Date Submitted</th>
                            <th style="padding: 12px 10px; width: 14%;">Term</th>
                            <th style="padding: 12px 10px; width: 8%;">Units</th>
                            <th style="padding: 12px 10px; width: 14%;">Status</th>
                            <th style="padding: 12px 10px; width: 40%;">Approval Track</th>
                            <th style="padding: 12px 10px; width: 12%; text-align: center;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (!forms || forms.length === 0) { %>
                            <tr>
                                <td colspan="6" style="padding: 50px; text-align: center; color: #aaa; font-size: 1.2rem;">
                                    <% if (filterType === 'approved') { %>
                                        <i class="fas fa-folder-open" style="font-size: 3rem; margin-bottom: 15px; display: block;"></i>
                                        You don't have any fully approved forms yet.
                                    <% } else { %>
                                        <i class="fas fa-inbox" style="font-size: 3rem; margin-bottom: 15px; display: block;"></i>
                                        You don't have any pending forms at the moment.
                                    <% } %>
                                </td>
                            </tr>
                        <% } else { %>
                            <% forms.forEach(form => { %>
                                <tr style="border-bottom: 1px solid #333; vertical-align: top;">
                                    <td style="padding: 15px 10px;"><%= new Date(form.createdAt).toLocaleDateString() %></td>
                                    <td style="padding: 15px 10px; font-size: 0.95rem;"><%= form.term %> <br> <span style="font-size: 0.8rem; color:#aaa;"><%= form.academicYear %></span></td>
                                    <td style="padding: 15px 10px; font-weight: bold; font-size: 1.1rem;"><%= form.totalEffectiveUnits %></td>
                                    
                                    <td style="padding: 15px 10px;">
                                        <span class="pending-badge" style="background-color: <%= form.status === 'FINALIZED' ? '#28a745' : '#ffc107' %>; color: <%= form.status === 'FINALIZED' ? '#fff' : '#000' %>; padding: 6px 10px; border-radius: 6px; font-weight: bold; font-size: 0.85rem; display: inline-block;">
                                            <%= form.status.replace('_', ' ') %>
                                        </span>
                                    </td>

                                    <td style="padding: 12px 10px;">
                                        <% if (form.approvalHistory && form.approvalHistory.length > 0) { %>
                                            <div style="font-size: 0.85rem; color: #aaa; background: #2a2a2a; padding: 10px; border-radius: 6px; border-left: 4px solid #b30000; box-shadow: inset 0 2px 5px rgba(0,0,0,0.2);">
                                                <% form.approvalHistory.forEach(log => { %>
                                                    <div style="margin-bottom: 6px;">
                                                        <% if (log.approvalStatus === 'RETURNED' || log.approvalStatus === 'REJECTED') { %>
                                                            <i class="fas fa-times-circle" style="color: #dc3545; margin-right: 5px;"></i>
                                                        <% } else { %>
                                                            <i class="fas fa-check-circle" style="color: #28a745; margin-right: 5px;"></i>
                                                        <% } %>
                                                        <strong style="color: #ddd; font-size: 0.9rem;"><%= log.approverName || log.approverRole %></strong> 
                                                        (<span style="color: #bbb;"><%= log.approvalStatus %></span>)
                                                        <span style="font-size: 0.75rem; color: #777; margin-left: 10px;">
                                                            <%= new Date(log.date).toLocaleDateString() %>
                                                        </span>
                                                        <% if (log.approvalStatus === 'RETURNED' && log.remarks) { %>
                                                            <div style="margin-top: 4px; margin-left: 20px; padding: 6px 10px; background-color: rgba(220, 53, 69, 0.15); border-left: 3px solid #dc3545; color: #ff9999; font-size: 0.8rem; border-radius: 4px;">
                                                                <strong>Reason:</strong> <%= log.remarks %>
                                                            </div>
                                                        <% } %>
                                                    </div>
                                                <% }) %>
                                            </div>
                                        <% } else { %>
                                            <div style="font-size: 0.9rem; color: #777; font-style: italic;">No signatures yet.</div>
                                        <% } %>
                                    </td>

                                    <td style="padding: 15px 10px;">
                                       <div style="display: flex; flex-direction: column; gap: 8px;">
                                            <a href="/ata/view-submission/<%= form._id %>" class="form-btn primary-btn" style="text-decoration: none; text-align: center; width: 100%; box-sizing: border-box; padding: 8px 0;">
                                                View PDF
                                            </a>

                                            <% if (form.status === 'DRAFT') { %>
                                                <a href="/ata/edit/<%= form._id %>" class="form-btn" style="text-decoration: none; background-color: #ffc107; color: #000; font-weight: bold; text-align: center; width: 100%; box-sizing: border-box; padding: 8px 0;">
                                                    <i class="fas fa-edit"></i> Edit
                                                </a>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <div class="bottom-actions">
                <a href="<%= (typeof role !== 'undefined' && ['Admin', 'VPAA', 'HR', 'HRMO'].includes(role)) ? '/admin/ata' : '/ata/dashboard/window' %>" class="form-btn secondary-btn" style="text-decoration: none;">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>

        </div>
    </main>
</body>
</html>