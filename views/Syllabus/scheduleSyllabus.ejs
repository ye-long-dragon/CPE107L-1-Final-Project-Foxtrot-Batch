<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Syllabus Schedule</title>
    <link rel="icon" type="image/x-icon" href="/common/img/chalkboardLogo.ico">
    <link rel="stylesheet" href="/Syllabus/css/infoSyllabus.css?v=<%= new Date().getTime() %>" />
    <link rel="stylesheet" href="/Syllabus/css/outcomesTable.css?v=<%= new Date().getTime() %>" />
    <link rel="stylesheet" href="/Syllabus/css/scheduleSyllabus.css?v=<%= new Date().getTime() %>" />
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
</head>

<body>
    <div class="dashboard">

        <main class="main-content">
            <div class="syllabus-top-bar">
                <button type="button" class="back-btn" onclick="window.history.back()">
                    <span class="material-symbols-outlined">arrow_back</span>
                    <span>Back</span>
                </button>
            </div>

            <div class="syllabus-scroll-area">
                <div class="syllabus-banner">
                    <span class="syllabus-banner-title">SYLLABUS FORM</span>
                </div>

                <div class="syllabus-content-section" style="max-width: 1400px; margin: 0 auto;">
                    <h2 class="college-header-outside">COURSE SCHEDULE</h2>

                    <!-- Toolbar Pill -->
                    <div class="outcomes-toolbar no-pdf">
                        <div class="toolbar-group">
                            <button type="button" class="toolbar-btn" onclick="execCmd('bold')" title="Bold">
                                <span class="material-symbols-outlined">format_bold</span>
                            </button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" class="toolbar-btn" onclick="execCmd('insertOrderedList')"
                                title="Numbering">
                                <span class="material-symbols-outlined">format_list_numbered</span>
                            </button>
                            <button type="button" class="toolbar-btn" onclick="execCmd('insertUnorderedList')"
                                title="Bullets">
                                <span class="material-symbols-outlined">format_list_bulleted</span>
                            </button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" class="toolbar-btn" onclick="execCmd('justifyLeft')"
                                title="Align Left">
                                <span class="material-symbols-outlined">format_align_left</span>
                            </button>
                            <button type="button" class="toolbar-btn" onclick="execCmd('justifyCenter')"
                                title="Align Center">
                                <span class="material-symbols-outlined">format_align_center</span>
                            </button>
                            <button type="button" class="toolbar-btn" onclick="execCmd('justifyRight')"
                                title="Align Right">
                                <span class="material-symbols-outlined">format_align_right</span>
                            </button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" class="toolbar-btn" onclick="addScheduleRow()" title="Add Row">
                                <span class="material-symbols-outlined">add_box</span>
                            </button>
                            <button type="button" class="toolbar-btn" onclick="deleteScheduleRow()" title="Delete Row">
                                <span class="material-symbols-outlined">indeterminate_check_box</span>
                            </button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" class="toolbar-btn" onclick="toggleMerge()" title="Merge Cells">
                                <span class="material-symbols-outlined">cell_merge</span>
                            </button>
                            <div class="color-picker-dropdown">
                                <button type="button" class="toolbar-btn split-btn-main" onclick="applyActiveColor()"
                                    title="Fill Color">
                                    <span class="material-symbols-outlined icon-with-color">
                                        format_color_fill
                                        <span class="active-color-bar" id="active-color-bar"></span>
                                    </span>
                                </button>
                                <button type="button" class="toolbar-btn split-btn-arrow"
                                    onclick="toggleColorPalette(event)" title="More Colors">
                                    <span class="material-symbols-outlined"
                                        style="font-size: 16px;">arrow_drop_down</span>
                                </button>

                                <div id="color-palette-menu" class="color-palette-menu">
                                    <div class="palette-section">
                                        <div class="palette-label">Theme Colors</div>
                                        <div class="palette-grid" id="theme-colors-grid"></div>
                                    </div>
                                    <div class="palette-section">
                                        <div class="palette-label">Standard Colors</div>
                                        <div class="palette-grid" id="standard-colors-grid"></div>
                                    </div>
                                    <div class="palette-divider"></div>
                                    <button class="palette-option-btn" onclick="selectPaletteColor('transparent')">
                                        <span class="material-symbols-outlined">format_color_reset</span>
                                        No Fill
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Course Schedule Table -->
                    <div class="outcomes-table-container">
                        <table class="schedule-editor-table">
                            <thead>
                                <tr>
                                    <th colspan="12" class="schedule-header-main">COURSE SCHEDULE</th>
                                </tr>
                                <tr>
                                    <th rowspan="2" class="col-week">Week</th>
                                    <th colspan="3">Outcomes</th>
                                    <th rowspan="2" class="col-day">Day</th>
                                    <th rowspan="2" class="col-coverage">Coverage Topic/s</th>
                                    <th colspan="2">Teaching Learning Activities</th>
                                    <th colspan="2">Assessment Tasks</th>
                                    <th rowspan="2" class="col-textbook">Textbook Chapters</th>
                                    <th rowspan="2" class="col-date">Date Covered</th>
                                </tr>
                                <tr>
                                    <th class="col-outcomes">CO</th>
                                    <th class="col-outcomes">MO</th>
                                    <th class="col-outcomes">ILO</th>
                                    <th class="col-tla-mode">Mode</th>
                                    <th class="col-tla-activities">Activities</th>
                                    <th class="col-at-mode">Mode</th>
                                    <th class="col-at-task">T</th>
                                </tr>
                            </thead>
                            <tbody id="schedule-editor-body">
                                <!-- Rows added by JS -->
                            </tbody>
                        </table>
                        <div id="table-selection-box">
                            <div class="selection-handle"></div>
                        </div>
                    </div>

                    <h2 class="college-header-outside">COURSE EVALUATION</h2>
                    <p class="evaluation-instruction">The final grade of the student is based on the following
                        components:</p>

                    <!-- Evaluation Toolbar -->
                    <div class="outcomes-toolbar no-pdf">
                        <div class="toolbar-group">
                            <button type="button" class="toolbar-btn" onclick="execCmd('bold')" title="Bold">
                                <span class="material-symbols-outlined">format_bold</span>
                            </button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" class="toolbar-btn" onclick="execCmd('insertOrderedList')"
                                title="Numbered List">
                                <span class="material-symbols-outlined">format_list_numbered</span>
                            </button>
                            <button type="button" class="toolbar-btn" onclick="execCmd('insertUnorderedList')"
                                title="Bulleted List">
                                <span class="material-symbols-outlined">format_list_bulleted</span>
                            </button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" class="toolbar-btn" onclick="execCmd('justifyLeft')"
                                title="Align Left">
                                <span class="material-symbols-outlined">format_align_left</span>
                            </button>
                            <button type="button" class="toolbar-btn" onclick="execCmd('justifyCenter')"
                                title="Align Center">
                                <span class="material-symbols-outlined">format_align_center</span>
                            </button>
                            <button type="button" class="toolbar-btn" onclick="execCmd('justifyRight')"
                                title="Align Right">
                                <span class="material-symbols-outlined">format_align_right</span>
                            </button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" class="toolbar-btn" onclick="addEvaluationRow()" title="Add Row">
                                <span class="material-symbols-outlined">add_box</span>
                            </button>
                            <button type="button" class="toolbar-btn" onclick="deleteEvaluationRow()"
                                title="Delete Row">
                                <span class="material-symbols-outlined">indeterminate_check_box</span>
                            </button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" class="toolbar-btn" onclick="toggleMerge()" title="Merge Cells">
                                <span class="material-symbols-outlined">cell_merge</span>
                            </button>
                            <div class="color-picker-dropdown">
                                <button type="button" class="toolbar-btn split-btn-main" onclick="applyActiveColor()"
                                    title="Fill Color">
                                    <span class="material-symbols-outlined icon-with-color">
                                        format_color_fill
                                        <span class="active-color-bar" id="active-color-bar"></span>
                                    </span>
                                </button>
                                <button type="button" class="toolbar-btn split-btn-arrow"
                                    onclick="toggleColorPalette(event)" title="More Colors">
                                    <span class="material-symbols-outlined"
                                        style="font-size: 16px;">arrow_drop_down</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="outcomes-table-container" id="evaluation-table-container" style="margin-bottom: 40px;">
                        <table class="schedule-editor-table evaluation-editor-table">
                            <thead>
                                <tr>
                                    <th rowspan="2" class="col-module-code">Module Code</th>
                                    <th rowspan="2" class="col-co-small">CO</th>
                                    <th rowspan="2" class="col-mediating-large">Mediating Outcomes / Laboratory Tasks
                                    </th>
                                    <th colspan="2" class="col-weight">Assessment Weighting, %</th>
                                    <th rowspan="2" class="col-weight">Modular Weighting, %</th>
                                    <th rowspan="2" class="col-weight">Final Weighting, %</th>
                                </tr>
                                <tr>
                                    <th class="col-sub">LT</th>
                                    <th class="col-sub">PE</th>
                                </tr>
                            </thead>
                            <tbody id="evaluation-editor-body">
                                <!-- Rows added by JS -->
                            </tbody>
                        </table>
                    </div>

                    <p style="margin-top: 40px; margin-bottom: 10px;"><b>Course Outcomes Assessment</b></p>
                    <p style="margin-bottom: 20px; font-size: 14px;">Achievement of course outcomes is based on the
                        following:</p>

                    <!-- Assessment Toolbar -->
                    <div class="outcomes-toolbar no-pdf">
                        <div class="toolbar-group">
                            <button type="button" class="toolbar-btn" onclick="execCmd('bold')" title="Bold">
                                <span class="material-symbols-outlined">format_bold</span>
                            </button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" class="toolbar-btn" onclick="execCmd('insertOrderedList')"
                                title="Numbered List">
                                <span class="material-symbols-outlined">format_list_numbered</span>
                            </button>
                            <button type="button" class="toolbar-btn" onclick="execCmd('insertUnorderedList')"
                                title="Bulleted List">
                                <span class="material-symbols-outlined">format_list_bulleted</span>
                            </button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" class="toolbar-btn" onclick="execCmd('justifyLeft')"
                                title="Align Left">
                                <span class="material-symbols-outlined">format_align_left</span>
                            </button>
                            <button type="button" class="toolbar-btn" onclick="execCmd('justifyCenter')"
                                title="Align Center">
                                <span class="material-symbols-outlined">format_align_center</span>
                            </button>
                            <button type="button" class="toolbar-btn" onclick="execCmd('justifyRight')"
                                title="Align Right">
                                <span class="material-symbols-outlined">format_align_right</span>
                            </button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" class="toolbar-btn" onclick="addAssessmentRow()" title="Add Row">
                                <span class="material-symbols-outlined">add_box</span>
                            </button>
                            <button type="button" class="toolbar-btn" onclick="deleteAssessmentRow()"
                                title="Delete Row">
                                <span class="material-symbols-outlined">indeterminate_check_box</span>
                            </button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" class="toolbar-btn" onclick="toggleMerge()" title="Merge Cells">
                                <span class="material-symbols-outlined">cell_merge</span>
                            </button>
                            <div class="color-picker-dropdown">
                                <button type="button" class="toolbar-btn split-btn-main" onclick="applyActiveColor()"
                                    title="Fill Color">
                                    <span class="material-symbols-outlined icon-with-color">
                                        format_color_fill
                                        <span class="active-color-bar" id="active-color-bar"></span>
                                    </span>
                                </button>
                                <button type="button" class="toolbar-btn split-btn-arrow"
                                    onclick="toggleColorPalette(event)" title="More Colors">
                                    <span class="material-symbols-outlined"
                                        style="font-size: 16px;">arrow_drop_down</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="outcomes-table-container" id="assessment-table-container" style="margin-bottom: 60px;">
                        <table class="schedule-editor-table assessment-editor-table">
                            <thead>
                                <tr>
                                    <th class="col-assessment-co">COURSE OUTCOMES</th>
                                    <th class="col-assessment-tasks">ASSESSMENT TASKS</th>
                                    <th class="col-assessment-msp">MINIMUM SATISFACTORY PERFORMANCE</th>
                                </tr>
                            </thead>
                            <tbody id="assessment-editor-body">
                                <!-- Rows added by JS -->
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>

            <!-- ── Signature Modal for Program Chair and Dean ── -->
            <div id="submit-signature-modal-overlay" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
                <div id="submit-signature-section" style="background: white; padding: 30px; border-radius: 8px; border-top: 5px solid #a00100; box-shadow: 0 4px 20px rgba(0,0,0,0.2); width: 90%; max-width: 550px; position: relative;">
                    <button type="button" id="submit-signature-close" style="position: absolute; top: 15px; right: 15px; background: none; border: none; font-size: 24px; cursor: pointer; color: #888;">&times;</button>
                    <h3 style="margin-top: 0; font-size: 1.2rem; color: #333; margin-bottom: 10px; display: flex; align-items: center; gap: 8px;">
                        <span class="material-symbols-outlined" style="color: #a00100;">edit_document</span>
                        E-Signature Required
                    </h3>
                    <p style="font-size: 0.95rem; color: #555; margin-bottom: 25px;">As a Program Chair or Dean, your syllabus draft will be automatically endorsed/approved upon submission. Please provide your e-signature.</p>

                    <div style="display: flex; flex-direction: column; gap: 20px;">
                        <div>
                            <label style="display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 8px; color: #333;">Signatory Name <span style="color:red">*</span></label>
                            <input type="text" id="submit-signatory-name" class="syllabus-input" placeholder="e.g. Dr. Juan dela Cruz" style="width: 100%; border: 1px solid #ccc; border-radius: 4px; padding: 10px; box-sizing: border-box;">
                        </div>

                        <div>
                            <label style="display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 8px; color: #333;">E-Signature <span style="color:red">*</span></label>
                            <div style="display: flex; gap: 10px; margin-bottom: 15px;">
                                <button type="button" id="submit-tab-upload" style="padding: 8px 16px; border: none; background: #a00100; color: white; border-radius: 4px; cursor: pointer; font-size: 0.85rem; transition: background 0.2s;">Upload Image</button>
                                <button type="button" id="submit-tab-draw" style="padding: 8px 16px; border: 1px solid #ccc; background: #fff; color: #333; border-radius: 4px; cursor: pointer; font-size: 0.85rem; transition: background 0.2s;">Draw Signature</button>
                            </div>

                            <!-- Upload Tab Content -->
                            <div id="submit-content-upload">
                                <div id="submit-signature-box" style="width: 100%; min-height: 140px; border: 2px dashed #bbb; border-radius: 6px; display: flex; align-items: center; justify-content: center; cursor: pointer; position: relative; background: #fafafa; overflow: hidden; transition: border-color 0.2s;">
                                    <span id="submit-signature-placeholder" style="color: #777; font-size: 0.95rem;"><span class="material-symbols-outlined" style="vertical-align: middle; margin-right: 5px;">upload</span>Click to upload signature</span>
                                    <input type="file" id="submit-signature-upload" accept="image/*" style="display: none;">
                                    <img id="submit-signature-preview" src="" style="display: none; max-width: 100%; max-height: 136px; object-fit: contain; pointer-events: none;">
                                    <button type="button" id="submit-signature-remove" style="display: none; position: absolute; top: 8px; right: 8px; background: rgba(0,0,0,0.6); color: white; border: none; border-radius: 50%; width: 26px; height: 26px; cursor: pointer; align-items: center; justify-content: center; font-size: 16px;">&times;</button>
                                </div>
                            </div>

                            <!-- Draw Tab Content -->
                            <div id="submit-content-draw" style="display: none;">
                                <div style="border: 2px solid #bbb; border-radius: 6px; background: #fff; overflow: hidden;">
                                    <canvas id="submit-signature-canvas" width="496" height="150" style="display: block; width: 100%; touch-action: none; cursor: crosshair;"></canvas>
                                </div>
                                <div style="margin-top: 10px; display: flex; gap: 10px;">
                                    <button type="button" id="submit-clear-canvas" style="padding: 8px 16px; border: 1px solid #ccc; background: white; cursor: pointer; border-radius: 4px; font-size: 0.85rem;">Clear</button>
                                    <button type="button" id="submit-use-drawn" style="padding: 8px 16px; border: none; background: #28a745; color: white; cursor: pointer; border-radius: 4px; font-size: 0.85rem;">Save Drawn Signature</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div style="margin-top: 30px; display: flex; justify-content: flex-end; gap: 15px;">
                        <button type="button" id="submit-signature-cancel" style="padding: 10px 24px; border: 1px solid #ccc; background: #fff; cursor: pointer; border-radius: 4px; font-weight: 600; font-size: 0.95rem;">Cancel</button>
                        <button type="button" id="submit-signature-confirm" style="padding: 10px 24px; border: none; background: #a00100; color: white; cursor: pointer; border-radius: 4px; font-weight: 600; font-size: 0.95rem;">Confirm & Submit</button>
                    </div>
                </div>
            </div>

            <div class="button-footer-outer">
                <button class="next-btn-rect" onclick="window.history.back()" type="button">
                    <span class="material-symbols-outlined">arrow_back</span>
                    <span>BACK</span>
                </button>

                <button class="next-btn-rect" onclick="submitSyllabus()" type="button">
                    <span>SUBMIT</span>
                    <span class="material-symbols-outlined">arrow_forward</span>
                </button>
            </div>
        </main>
    </div>

    <script>
        window.CURRENT_SYLLABUS_ID = "<%= locals.syllabusId || '' %>";
        window.USER_ROLE = "<%= locals.userRole || '' %>";
        window.USER_ID = "<%= locals.userId || '' %>";
        window.SERVER_SYLLABUS_DATA = {
            schedules: <%- JSON.stringify(locals.schedules || []) %>,
            evaluation: <%- JSON.stringify(locals.evaluation || []) %>,
            assessment: <%- JSON.stringify(locals.assessment || []) %>
        };
    </script>
    <script src="/Syllabus/js/scheduleSyllabus.js?v=<%= new Date().getTime() %>"></script>
</body>

</html>